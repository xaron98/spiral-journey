{
  "sourceLanguage": "en",
  "strings": {
    "": {},
    "%@ → %@": {
      "comment": "A label showing the bedtime and wakeup time that was logged. The first argument is the string “%1$02d:%2$02d”. The second argument is the string “%1$02d:%2$02d”.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ → %2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ → %2$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A text label displaying the composite score, centered in a circle",
      "isCommentAutoGenerated": true
    },
    "✓ %@": {
      "comment": "A confirmation label that appears when a circadian event is logged, showing the type of event. The argument is the label for the logged event.",
      "isCommentAutoGenerated": true
    },
    "Consistencia": {
      "comment": "A label displayed alongside a circadian consistency score.",
      "isCommentAutoGenerated": true
    },
    "R²": {
      "comment": "A label displayed next to the cosine regression R² value in the watch day view.",
      "isCommentAutoGenerated": true
    },
