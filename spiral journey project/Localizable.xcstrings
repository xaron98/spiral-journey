    "dna.range.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فقط الليالي ضمن النطاق تُغذّي اللولب ثلاثي الأبعاد. العروض الأخرى لا تتأثر."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Només les nits dins del rang alimenten l'hèlix 3D. La resta de vistes no es veuen afectades."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur Nächte innerhalb des Bereichs fließen in die 3D-Helix. Andere Ansichten bleiben unberührt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only nights inside the range feed the 3D helix. Other views stay unaffected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo las noches dentro del rango alimentan la hélice 3D. El resto de vistas no se ven afectadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seules les nuits dans la plage alimentent l'hélice 3D. Les autres vues ne sont pas affectées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "範囲内の夜だけが3Dヘリックスに反映されます。他のビューには影響しません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有范围内的夜晚会进入 3D 螺旋,其他视图不受影响。"
          }
        }
      }
    },
