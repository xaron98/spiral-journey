    "coach.issue.delayedPhase.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعرض للضوء الساطع في الصباح (الساعة 07:00-09:00) وتجنب الضوء الأزرق بعد الساعة 21:00."
          }
        },
        "ca" : {
          "stringUnit" : {
