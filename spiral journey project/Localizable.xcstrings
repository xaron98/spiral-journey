    "coach.issue.advancedPhase.reason" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وقت نومك أبكر بكثير مما هو مثالي، وقد تستيقظ مبكراً جداً بشكل لا إرادي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
