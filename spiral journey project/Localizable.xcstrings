    "dna.helix.needs_data" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مطلوب 3 ليالٍ على الأقل لبناء اللولب"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necessites almenys 3 nits per generar l'hèlix"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mindestens 3 Nächte nötig, um die Helix zu bauen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At least 3 nights needed to build the helix"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necesitas al menos 3 noches para generar la hélice"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Au moins 3 nuits nécessaires pour construire l'hélice"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "らせんの生成には少なくとも3晩必要"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生成螺旋至少需要3晚数据"
          }
        }
      }
    },
    "dna.help.data.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن بناء لولب أساسي من 7 ليالٍ متتالية. يُوصى بـ 14 ليلة أو أكثر لاكتشاف أنماط موثوقة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A partir de 7 nits consecutives es pot construir una hèlix bàsica. Per detectar patrons fiables es recomanen 14 o més."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine grundlegende Helix benötigt 7 aufeinanderfolgende Nächte. Für zuverlässige Mustererkennung werden 14 oder mehr empfohlen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A basic helix needs 7 consecutive nights. For reliable pattern detection, 14 nights or more are recommended."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A partir de 7 noches consecutivas se puede construir una hélice básica. Para detectar patrones fiables se recomiendan 14 o más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une hélice basique nécessite 7 nuits consécutives. Pour une détection fiable des motifs, 14 nuits ou plus sont recommandées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基本的ならせんには連続7晩必要。信頼性の高いパターン検出には14晩以上を推奨。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基本螺旋需要连续7晚。可靠的模式检测建议14晚或更多。"
          }
        }
      }
    },
    "dna.help.data.title" : {
      "localizations" : {
