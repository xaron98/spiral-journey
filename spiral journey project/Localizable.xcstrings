        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقدّم بوقت نومك 15 دقيقة كل ليلة حتى تصل إلى هدف مدة النوم."
          }
        },
        "ca" : {
          "stringUnit" : {
