    },
    "%@  →  %@" : {
      "comment" : "A title that shows the predicted bedtime and wake-up time for the current week. The first argument is the string “%1$02d:%2$02d”. The second argument is the string “%1$02d:%2$02d”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
