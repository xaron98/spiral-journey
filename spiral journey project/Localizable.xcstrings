    "settings.notifications.weekly.desc": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استلم ملخصًا كل اثنين في الساعة 9:00 مع اتساق نومك ونتيجتك الأسبوعية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Rep un resum cada dilluns a les 9:00 amb la teva consistència i puntuació setmanal de son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalten Sie jeden Montag um 9:00 Uhr eine Zusammenfassung Ihrer wöchentlichen Schlafkonsistenz und Bewertung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Receive a summary every Monday at 9:00 AM with your weekly sleep consistency and score."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe un resumen cada lunes a las 9:00 con tu consistencia y puntuación semanal de sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recevez un résumé chaque lundi à 9h00 avec votre consistance et score hebdomadaire de sommeil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎週月曜日の午前9時に睡眠の一貫性とスコアの週間サマリーを受け取ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每周一上午 9:00 收到您的睡眠一致性和得分的周总结。"
          }
        }
      }
    },
