    "coach.issue.sleepTooCloseToContext.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاول الاستيقاظ قبل 60 دقيقة على الأقل من %@ للسماح بانتقال صباحي مناسب."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta despertar-te almenys 60 minuts abans del teu %@ per a una transició matutina adequada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche, mindestens 60 Minuten vor deinem %@ aufzuwachen für einen guten Morgenübergang."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try to wake at least 60 minutes before your %@ to allow proper morning transition."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta despertar al menos 60 minutos antes de tu %@ para una transición matutina adecuada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de vous réveiller au moins 60 minutes avant votre %@ pour une transition matinale correcte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の少なくとも60分前に起きて、朝の移行をスムーズにしましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试在%@开始前至少60分钟醒来，以便进行适当的早晨过渡。"
          }
        }
      }
    },
    "coach.issue.sleepTooCloseToContext.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فترة فاصلة بين الاستيقاظ والالتزامات تقلل ارتفاع الكورتيزول وتحسن اليقظة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Un marge entre despertar i les obligacions redueix els pics de cortisol i millora l'alerta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Puffer zwischen Aufwachen und Verpflichtungen reduziert Cortisolspitzen und verbessert die Wachheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A buffer between waking and obligations reduces cortisol spikes and improves alertness."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un margen entre despertar y las obligaciones reduce los picos de cortisol y mejora la alerta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un tampon entre le réveil et les obligations réduit les pics de cortisol et améliore la vigilance."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "起床と義務の間のバッファはコルチゾールスパイクを減らし、覚醒度を向上させます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "醒来与义务之间的缓冲时间可减少皮质醇峰值并提高警觉性。"
          }
        }
      }
    },
    "coach.issue.sleepTooCloseToContext.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تستيقظ قبل %@ دقيقة فقط من بداية %@."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Et despertes només %@ minuts abans que comenci el teu %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wachst nur %@ Minuten vor deinem %@-Beginn auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You wake up only %@ minutes before your %@ starts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te despiertas solo %@ minutos antes de que empiece tu %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous vous réveillez seulement %@ minutes avant le début de votre %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の開始わずか%@分前に起床しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您在%@开始前仅%@分钟醒来。"
          }
        }
      }
    },
    "coach.issue.sleepTooCloseToContext.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاستيقاظ قريب جداً من جدولك"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Despertar massa a prop del teu horari"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aufwachen zu nah am Zeitplan"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-up too close to your schedule"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despertar demasiado cerca de tu horario"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réveil trop proche de votre emploi du temps"
          }
        },
        "ja": {
