    "prc.help.dead.body": {
      "comment": "Body text for a help section in the PRC help sheet related to \"dead\" data points.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المنبهات في هذه النافذة ليس لها تأثير يُذكر على ساعتك. يحدث هذا عادةً في منتصف الصباح."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els estímuls durant aquesta finestra tenen poc efecte en el teu rellotge. Això sol ocórrer a mig matí."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reize in diesem Fenster haben kaum Auswirkungen auf deine Uhr. Dies tritt typischerweise am späten Vormittag auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stimuli during this window have little effect on your clock. This typically occurs in the mid-morning hours."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los estímulos durante esta ventana tienen poco efecto en tu reloj. Esto suele ocurrir a media mañana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les stimuli pendant cette fenêtre ont peu d'effet sur votre horloge. Cela se produit généralement en milieu de matinée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この時間帯の刺激は時計にほとんど影響を与えません。通常、朝中頃に発生します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此时间窗内的刺激对你的时钟影响很小，通常发生在上午中段。"
          }
        }
      }
    },
    "prc.help.dead.title": {
      "comment": "Title for a help section in the PRC help sheet that explains the neutral zone in PRCs.",
      "localizations": {
