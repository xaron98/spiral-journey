    "consistency.help.global.desc" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحوّل جدول نومك بشكل ملحوظ مقارنةً بنمطك الأخير. قد يحدث هذا بسبب اضطراب الرحلات الجوية الطويلة، أو تغييرات في الجدول الزمني، أو النوم في وقت مختلف جدًا عن المعتاد. قد يؤثر تحول كبير في إيقاعك اليوماوي لعدة أيام."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tot el teu horari de son s'ha desplaçat significativament respecte al teu patró recent. Pot passar per jet lag, canvis d'horari, o dormir a una hora molt diferent de l'habitual. Un desplaçament gran pot afectar el teu ritme circadià durant diversos dies."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein gesamter Schlafrhythmus hat sich im Vergleich zu deinem letzten Muster deutlich verschoben. Dies kann durch Jetlag, Änderungen des Zeitplans oder Schlafen zu einer sehr anderen Zeit als üblich verursacht werden. Eine große Verschiebung kann deinen zirkadianen Rhythmus für mehrere Tage beeinflussen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your entire sleep schedule shifted significantly compared to your recent pattern. This can happen due to jet lag, schedule changes, or sleeping at a very different time than usual. A large shift can affect your circadian rhythm for several days."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu horario de sueño se desplazó significativamente respecto a tu patrón reciente. Puede ocurrir por jet lag, cambios de horario, o dormir a una hora muy diferente de lo habitual. Un desplazamiento grande puede afectar tu ritmo circadiano durante varios días."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'intégralité de ton horaire de sommeil a considérablement changé par rapport à ton schéma récent. Cela peut arriver à cause du décalage horaire, de changements d'emploi du temps, ou d'un coucher à une heure très différente de l'habitude. Un grand décalage peut affecter ton rythme circadien pendant plusieurs jours."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠スケジュール全体が最近のパターンと比べて大幅にずれました。これはジェット lag、スケジュールの変更、またはいつもと大きく異なる時間に寝ることで起こります。大きなずれは概日リズムに数日間影響を与えることがあります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与近期规律相比，你的整个睡眠时间表发生了显著偏移。这可能是由于时差、日程变化或在与平时差异很大的时间入睡所导致。较大的偏移可能会影响你的昼夜节律数天。"
          }
        }
      }
    },
    "consistency.help.global.title" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحول عالمي"
          }
        },
        "ca" : {
          "stringUnit" : {
