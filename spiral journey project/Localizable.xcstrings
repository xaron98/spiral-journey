    "onboarding.events.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سجّل أحداثاً مثل التعرض للضوء أو الكافيين أو الرياضة لترى كيف تؤثر على إيقاعك اليومي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra esdeveniments com l'exposició a la llum, la cafeïna o l'exercici per veure com afecten el teu ritme circadià."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfasse Ereignisse wie Lichteinwirkung, Koffein oder Sport, um zu sehen, wie sie deinen Biorhythmus beeinflussen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log events like light exposure, caffeine, or exercise to see how they affect your circadian rhythm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra eventos como la exposición a la luz, la cafeína o el ejercicio para ver cómo afectan a tu ritmo circadiano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistre des événements comme l'exposition à la lumière, la caféine ou l'exercice pour voir leur effet sur ton rythme circadien."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "光の暴露、カフェイン、運動などのイベントを記録して、概日リズムへの影響を確認しましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "记录光照、咖啡因或运动等事件，了解它们如何影响你的昼夜节律。"
          }
        }
      }
    },
