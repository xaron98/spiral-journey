    "pdf.body.biomarkersNote" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ملاحظة: المؤشرات الحيوية تقديرات إحصائية مبنية على أنماط توقيت النوم، وليست قياسات مباشرة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nota: Els biomarcadors són estimacions estadístiques basades en patrons de temps de son, no mesures directes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinweis: Biomarker sind statistische Schätzungen basierend auf Schlafzeitmuster, keine direkten Messungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Note: Biomarkers are statistical estimates based on sleep timing patterns, not direct measurements."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nota: Los biomarcadores son estimaciones estadísticas basadas en patrones de horario de sueño, no mediciones directas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
