    "prc.help.use.body": {
      "comment": "Body text for a help section in the PRC help sheet, explaining how to use the \"Use\" button.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجّل الأحداث (الضوء، الرياضة، الميلاتونين…) في عرض الحلزون وستظهر كنقاط على المنحنى. النقاط في منطقة التقديم تساعد على تقديم إيقاعك؛ والنقاط في منطقة التأخير تؤخره."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra esdeveniments (llum, exercici, melatonina…) a la vista en espiral i apareixeran com a punts a la corba. Els punts a la zona d'avançament ajuden a avançar el teu ritme; els punts a la zona de retard el retarden."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasse Ereignisse (Licht, Sport, Melatonin…) in der Spiralansicht und sie erscheinen als Punkte auf der Kurve. Punkte in der Vorverlegungszone helfen, deinen Rhythmus früher zu verschieben; Punkte in der Verzögerungszone verschieben ihn später."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log events (light, exercise, melatonin…) in the spiral view and they'll appear as dots on the curve. Dots in the advance zone help shift your rhythm earlier; dots in the delay zone push it later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra eventos (luz, ejercicio, melatonina…) en la vista espiral y aparecerán como puntos en la curva. Los puntos en la zona de avance ayudan a adelantar tu ritmo; los puntos en la zona de retraso lo retrasan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez des événements (lumière, exercice, mélatonine…) dans la vue spirale et ils apparaîtront comme des points sur la courbe. Les points dans la zone d'avance aident à avancer votre rythme ; les points dans la zone de retard le retardent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スパイラルビューでイベント（光、運動、メラトニンなど）を記録すると、曲線上にドットとして表示されます。前進ゾーンのドットはリズムを早めるのに役立ち、遅延ゾーンのドットは遅らせます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在螺旋视图中记录事件（光线、运动、褪黑素…），它们将以圆点形式显示在曲线上。提前区的圆点有助于使节律提前，延迟区的圆点则使其延后。"
          }
        }
      }
    },
    "prc.help.use.title": {
      "comment": "Title of a help section in the PRC help sheet that explains how to use the PRC.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
