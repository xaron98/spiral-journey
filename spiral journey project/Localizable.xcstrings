    "dna.help.detects.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأنماط المتكررة، والطفرات عن خط الأساس، والأنماط المرتبطة بتغيرات السياق (السفر، التدريب، التوتر)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patrons recurrents, mutacions respecte a la teva base i motius associats a canvis de context (viatge, entrenament, estrès)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wiederkehrende Muster, Abweichungen von deiner Basislinie und Motive im Zusammenhang mit Kontextwechseln (Reisen, Training, Stress)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recurring patterns, mutations from your baseline, and motifs tied to context changes (travel, training, stress)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patrones recurrentes, mutaciones respecto a tu base y motivos asociados a cambios de contexto (viaje, entreno, estrés)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motifs récurrents, mutations par rapport à ta ligne de base et motifs liés aux changements de contexte (voyage, entraînement, stress)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "繰り返しのパターン、ベースラインからの変異、コンテキスト変化（旅行、トレーニング、ストレス）に関連する動機。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "反复出现的模式、与基线的变异，以及与情境变化（旅行、训练、压力）相关的主题。"
          }
        }
      }
    },
    "dna.help.detects.title" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
