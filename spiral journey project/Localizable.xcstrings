    "jetlag.disclaimer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تستند هذه الخطة إلى مبادئ علم الإيقاع اليومي. يجب مناقشة جرعة الميلاتونين مع طبيبك. لا يغني عن الاستشارة الطبية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquest pla es basa en principis de ciència circadiana. La dosi de melatonina s'ha de consultar amb el metge. No substitueix el consell mèdic."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Plan basiert auf zirkadianen Wissenschaftsprinzipien. Die Melatonin-Dosierung sollte mit Ihrem Arzt besprochen werden. Kein Ersatz für ärztlichen Rat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This plan is based on circadian science principles. Melatonin dosing should be discussed with your doctor. Not a substitute for medical advice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este plan se basa en principios de ciencia circadiana. La dosis de melatonina debe consultarse con su médico. No sustituye el consejo médico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce plan est basé sur les principes de la science circadienne. Le dosage de mélatonine doit être discuté avec votre médecin. Ne remplace pas un avis médical."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
