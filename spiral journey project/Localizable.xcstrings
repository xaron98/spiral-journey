    "onboarding.disclaimer" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey أداة تعليمية للملاحظة الذاتية للنوم. لا يقدم تشخيصات طبية أو توصيات سريرية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey és una eina educativa d'autoobservació del son. No proporciona diagnòstics mèdics ni recomanacions clíniques."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey ist ein Bildungswerkzeug zur Selbstbeobachtung des Schlafs. Es bietet keine medizinischen Diagnosen oder klinischen Empfehlungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey is an educational tool for sleep self-observation. It does not provide medical diagnoses or clinical recommendations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey es una herramienta educativa de autoobservación del sueño. No proporciona diagnósticos médicos ni recomendaciones clínicas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey est un outil éducatif d'auto-observation du sommeil. Il ne fournit pas de diagnostics médicaux ni de recommandations cliniques."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey は睡眠の自己観察のための教育ツールです。医療診断や臨床的な推奨は提供しません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiral Journey 是一款用于睡眠自我观察的教育工具。它不提供医疗诊断或临床建议。"
          }
        }
      }
    },
