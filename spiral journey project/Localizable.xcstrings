    "chronotype.result.moderateMorning.desc": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تميل نحو الصباح. تعمل بشكل جيد في بداية اليوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendeixes cap als matins. Sols funcionar bé a la primera part del dia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie tendieren zum Morgen. Sie funktionieren gut in der ersten Tageshälfte."
          }
        },
        "en": {
          "stringUnit": {
