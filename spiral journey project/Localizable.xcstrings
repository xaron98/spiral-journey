    "onboarding.cursor.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسحب في أي مكان على الحلزونة لتحريك مؤشر الوقت. يعرض الشريط أدناه الوقت والتاريخ بدقة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrossega qualsevol part de l'espiral per moure el cursor de temps. La barra inferior mostra l'hora i la data exactes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe überall auf der Spirale, um den Zeitcursor zu bewegen. Die Leiste unten zeigt die genaue Uhrzeit und das Datum."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag anywhere on the spiral to move the time cursor. The bar below shows the exact time and date."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra cualquier parte de la espiral para mover el cursor de tiempo. La barra inferior muestra la hora y fecha exactas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fais glisser n'importe où sur la spirale pour déplacer le curseur temporel. La barre en bas affiche l'heure et la date exactes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スパイラル上をどこでもドラッグしてタイムカーソルを動かせます。下のバーに正確な時間と日付が表示されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在螺旋上任意拖动以移动时间光标。下方的栏显示确切的时间和日期。"
          }
        }
      }
    },
