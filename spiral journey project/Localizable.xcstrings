    "dna.help.disclaimer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "للاستخدام الإعلامي. استشر متخصصًا إذا كانت لديك مخاوف بشأن نومك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ús informatiu. Consulta un professional si tens preocupacions sobre el teu son."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur zu Informationszwecken. Bei Schlafsorgen wende dich an eine Fachkraft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For informational use. Consult a professional if you have sleep concerns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uso informativo. Consulta a un profesional si tienes preocupaciones sobre tu sueño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À titre informatif. Consulte un professionnel si tu as des préoccupations concernant ton sommeil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "情報提供目的のみ。睡眠に懸念がある場合は専門家に相談してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅供参考。如有睡眠疑虑，请咨询专业人士。"
          }
        }
      }
    },
    "dna.help.experimental.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه استعارة حاسوبية مستوحاة من علم الوراثة. لا تحل محل التقييم السريري لمختص النوم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "És una metàfora computacional inspirada en genètica. No substitueix la valoració clínica d'un professional del son."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist eine computergestützte Metapher, inspiriert von der Genetik. Sie ersetzt keine klinische Bewertung durch eine Schlafexpertin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is a computational metaphor inspired by genetics. It doesn't replace a sleep professional's clinical assessment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es una metáfora computacional inspirada en genética. No sustituye la valoración clínica de un profesional del sueño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est une métaphore computationnelle inspirée de la génétique. Elle ne remplace pas l'évaluation clinique d'un spécialiste du sommeil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これは遺伝学にインスパイアされた計算メタファー。睡眠専門家の臨床評価に代わるものではない。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是受遗传学启发的计算比喻。不能替代睡眠专业人士的临床评估。"
          }
        }
      }
    },
    "dna.help.experimental.title" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تفسير وليس تشخيصًا"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interpretació, no diagnòstic"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interpretation, keine Diagnose"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interpretation, not diagnosis"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interpretación, no diagnóstico"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interprétation, pas un diagnostic"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解釈であって診断ではない"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅为解读，非诊断"
          }
        }
      }
    },
    "dna.help.helix.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سلسلتان مرتبطتان تعرضان ليلتين (أو أسبوعين) جنبًا إلى جنب. اسحب للاستكشاف، اضغط للتكبير."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dues cadenes enllaçades mostren dues nits (o setmanes) en paral·lel. Arrossega-la per explorar-la, pessiga-la per apropar-te."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwei verknüpfte Stränge zeigen zwei Nächte (oder Wochen) nebeneinander. Ziehen zum Erkunden, Zwei-Finger zum Zoomen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Two linked strands show two nights (or weeks) side by side. Drag to explore, pinch to zoom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dos cadenas enlazadas muestran dos noches (o semanas) en paralelo. Arrástrala para explorarla, pellízcala para acercarte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deux brins liés montrent deux nuits (ou semaines) côte à côte. Fais-le glisser pour explorer, pince pour zoomer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "連結された2本の鎖が2つの夜（または週）を並べて表示。ドラッグして探索、ピンチでズーム。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "两条连接的链并排显示两个夜晚（或两周）。拖动探索，捏合缩放。"
          }
        }
      }
    },
