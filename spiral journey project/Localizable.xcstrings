    "stats.glossary.wkndAmp": {
      "comment": "Definition of a term related to the amplitude of a user's sleep pattern on weekends.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتساع نهاية الأسبوع — الفرق في اتساع توقيت النوم بين أيام الأسبوع وعطلة نهاية الأسبوع. الفرق الكبير قد يشير إلى تراكم دين النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Amplitud de cap de setmana — la diferència en l'amplitud del moment del son entre dies feiners i caps de setmana. Una gran diferència pot indicar un deute de son acumulat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wochenendamplitude — der Unterschied in der Schlafzeitamplitude zwischen Werktagen und Wochenenden. Ein großer Unterschied kann auf aufgelaufenen Schlafmangel hinweisen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weekend amplitude — the difference in sleep timing amplitude between weekdays and weekends. A large difference may indicate accumulated sleep debt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Amplitud de fin de semana — la diferencia en la amplitud del momento del sueño entre días de semana y fines de semana. Una gran diferencia puede indicar deuda de sueño acumulada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Amplitude du week-end — la différence d'amplitude du timing de sommeil entre les jours de semaine et les week-ends. Une grande différence peut indiquer une dette de sommeil accumulée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "週末振幅——平日と週末の睡眠タイミング振幅の差。差が大きい場合、睡眠負債の蓄積を示す可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "周末振幅——工作日和周末睡眠时间振幅的差异。差异较大可能表明存在睡眠债务积累。"
          }
        }
      }
    },
