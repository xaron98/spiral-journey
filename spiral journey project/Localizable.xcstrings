          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un margen entre despertar y las obligaciones reduce los picos de cortisol y mejora la alerta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un tampon entre le réveil et les obligations réduit les pics de cortisol et améliore la vigilance."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "起床と義務の間のバッファはコルチゾールスパイクを減らし、覚醒度を向上させます。"
