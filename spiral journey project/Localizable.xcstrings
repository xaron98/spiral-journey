    "coach.insight.delayed.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وقت نومك المقدّر %@ والاستيقاظ %@. يشير ذلك إلى تأخر طور النوم. يمكن تقديم الساعة البيولوجية تدريجياً."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hora estimada de dormir %@ i despertar %@. Això indica una fase de son retardada. El rellotge intern es pot avançar gradualment."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geschätzte Schlafzeit %@ und Aufwachzeit %@. Das deutet auf eine verzögerte Schlafphase hin. Die innere Uhr kann schrittweise vorgestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estimated sleep around %@ and wake around %@. This suggests a delayed sleep phase. Your internal clock can be gradually shifted earlier."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hora estimada de dormir %@ y despertar %@. Esto indica una fase de sueño retrasada. El reloj interno puede adelantarse gradualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heure de coucher estimée %@ et réveil %@. Cela indique une phase de sommeil retardée. L'horloge interne peut être avancée progressivement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "推定就寝時刻 %@、起床時刻 %@。これは睡眠位相後退を示しています。体内時計は段階的に早めることができます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "估计入睡时间%@，醒来时间%@。这表明睡眠时相延迟。内部时钟可以逐步提前。"
          }
        }
      }
    },
