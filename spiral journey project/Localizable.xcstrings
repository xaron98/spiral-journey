    "triangle.legend.note" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل رأس هو مرحلة نقية (مستيقظ · REM · عميق). النوم الخفيف (N2) يظهر في الداخل لأنه يتشارك خصائص مع REM والعميق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada vèrtex és una fase pura (Despert · REM · Profund). El son lleuger (N2) apareix a l'interior perquè comparteix característiques amb REM i Profund."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Ecke ist eine reine Phase (Wach · REM · Tief). Leichtschlaf (N2) erscheint im Inneren, weil er Merkmale von REM und Tiefschlaf teilt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each vertex is a pure phase (Wake · REM · Deep). Light sleep (N2) appears in the interior because it shares features with REM and Deep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada vértice es una fase pura (Despierto · REM · Profundo). El sueño ligero (N2) aparece en el interior porque comparte características con REM y Profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque sommet est une phase pure (Éveil · REM · Profond). Le sommeil léger (N2) apparaît à l'intérieur car il partage des caractéristiques avec REM et Profond."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各頂点は純粋なフェーズ（覚醒・REM・深い）です。浅い睡眠（N2）はREMと深い睡眠の特徴を共有するため、内部に表示されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个顶点是一种纯粹的阶段（清醒·REM·深睡）。浅睡 (N2) 出现在内部，因为它与 REM 和深睡共享特征。"
          }
        }
      }
    },
