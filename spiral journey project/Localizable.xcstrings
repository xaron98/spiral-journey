    "pdf.glossary.acrophase" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الذروة — وقت ذروة الإيقاع اليومي، ساعة النشاط القصوى. عند البالغين الأصحاء بين 14:00-17:00."
          }
        },
        "ca" : {
          "stringUnit" : {
