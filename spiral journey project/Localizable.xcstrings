    "settings.prediction.privacyNote": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تدريب ML بالكامل على الجهاز. بيانات نومك لا تغادر هاتفك أبداً."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tot l'entrenament ML s'executa al dispositiu. Les teves dades de son mai surten del telèfon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das ML-Training läuft vollständig auf dem Gerät. Deine Schlafdaten verlassen nie dein Telefon."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All ML training runs on-device. Your sleep data never leaves your phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo el entrenamiento ML se ejecuta en el dispositivo. Tus datos de sueño nunca salen de tu teléfono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout l'entraînement ML se fait sur l'appareil. Vos données de sommeil ne quittent jamais votre téléphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MLトレーニングはすべてデバイス上で実行されます。睡眠データがスマホから外に出ることはありません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo o treino ML é feito no dispositivo. Seus dados de sono nunca saem do seu celular."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有ML训练均在设备上运行。您的睡眠数据永远不会离开您的手机。"
          }
        }
      }
    },
