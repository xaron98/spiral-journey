    "neurospiral.info.reference" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مبني على: هندسة طوق كليفورد (S¹×S¹ ⊂ S³)، تقطيع المكعب الرباعي Q(x) = sgn(x)، ونموذج العمليتين لبوربيلي (1982)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basat en: geometria del tor de Clifford (S¹×S¹ ⊂ S³), discretització tesseractal Q(x) = sgn(x), i el model de dos processos de Borbély (1982)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basiert auf: Clifford-Torus-Geometrie (S¹×S¹ ⊂ S³), Tesserakt-Diskretisierung Q(x) = sgn(x), und Borbélys Zwei-Prozess-Modell (1982)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Based on: Clifford torus geometry (S¹×S¹ ⊂ S³), tesseract discretization Q(x) = sgn(x), and Borbély's two-process model (1982)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basado en: geometría del toro de Clifford (S¹×S¹ ⊂ S³), discretización tesseractal Q(x) = sgn(x), y el modelo de dos procesos de Borbély (1982)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basé sur : géométrie du tore de Clifford (S¹×S¹ ⊂ S³), discrétisation tesseractale Q(x) = sgn(x), et le modèle à deux processus de Borbély (1982)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基礎理論：クリフォードトーラス幾何学（S¹×S¹ ⊂ S³）、テッセラクト離散化 Q(x) = sgn(x)、ボルベリーの2プロセスモデル（1982）。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基于：克利福德环面几何（S¹×S¹ ⊂ S³）、超立方体离散化 Q(x) = sgn(x)、以及Borbély的双过程模型（1982）。"
          }
        }
      }
    },
    "neurospiral.info.stability.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "درجة الاستقرار المرتفعة تعني أنك تقضي معظم الليل في حالة دقيقة واحدة (نوم متماسك). الاستقرار المنخفض يشير إلى التشتت — مسارك يقفز بين العديد من رؤوس المكعب الرباعي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una puntuació alta d'estabilitat significa que passes la major part de la nit en un sol microestat (son consolidat). L'estabilitat baixa indica fragmentació — la teva trajectòria salta entre molts vèrtexs del tesseracte."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein hoher Stabilitätswert bedeutet, dass du die meiste Nacht in einem einzigen Mikrozustand verbringst (konsolidierter Schlaf). Niedrige Stabilität zeigt Fragmentierung — deine Trajektorie springt zwischen vielen Tesserakt-Ecken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A high stability score means you spend most of the night in a single micro-state (consolidated sleep). Low stability indicates fragmentation — your trajectory jumps between many tesseract vertices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un score alto de estabilidad significa que pasas la mayor parte de la noche en un solo micro-estado (sueño consolidado). Estabilidad baja indica fragmentación — tu trayectoria salta entre muchos vértices del teseracto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un score élevé de stabilité signifie que vous passez la majeure partie de la nuit dans un seul micro-état (sommeil consolidé). Une faible stabilité indique une fragmentation — votre trajectoire saute entre de nombreux sommets du tesseract."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安定性スコアが高いということは、一晩のほとんどを1つのマイクロステートで過ごすこと（統合された睡眠）を意味します。低い安定性は断片化を示します — 軌跡がテッセラクトの多くの頂点間を跳びます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高稳定性分数意味着您大部分时间处于单一微态（整合睡眠）。低稳定性表示碎片化——您的轨迹在超立方体的许多顶点之间跳跃。"
          }
        }
      }
    },
