    "codon.help.bars.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each bar represents one night. Green = good cycle transitions. Yellow = moderate. Red = many disruptions. The height shows the integrity score — taller bars mean better sleep architecture that night."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada barra representa una noche. Verde = buenas transiciones de ciclo. Amarillo = moderado. Rojo = muchas disrupciones. La altura muestra la integridad — barras más altas significan mejor arquitectura de sueño esa noche."
          }
        }
      }
    },
    "codon.help.bars.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What do the bars mean?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qué significan las barras?"
          }
        }
      }
    },
    "codon.help.disclaimer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requires Apple Watch sleep stage data. Analysis based on bioinformatics k-mer technique applied to sleep phases."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requiere datos de fases de sueño del Apple Watch. Análisis basado en técnica bioinformática de k-mers aplicada a fases de sueño."
          }
        }
      }
    },
    "codon.help.disruption.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A disruption is when a sleep phase is interrupted unexpectedly — like waking up in the middle of REM sleep or deep sleep. The most common disruption pattern is shown so you can identify what breaks your sleep cycles most often."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una disrupción es cuando una fase de sueño se interrumpe inesperadamente — como despertarte en medio del REM o del sueño profundo. Se muestra el patrón de disrupción más común para que puedas identificar qué rompe tus ciclos de sueño con más frecuencia."
          }
        }
      }
    },
    "codon.help.disruption.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is a disruption?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qué es una disrupción?"
          }
        }
      }
    },
    "codon.help.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep architecture"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arquitectura del sueño"
          }
        }
      }
    },
    "codon.help.what.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We analyze how your sleep phases transition during the night: light sleep, deep sleep, REM, and awakenings. A healthy night follows a predictable cycle (light → deep → REM). When this cycle breaks — for example, waking up during REM — it affects the quality of your rest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analizamos cómo transicionan tus fases de sueño durante la noche: sueño ligero, sueño profundo, REM y despertares. Una noche saludable sigue un ciclo predecible (ligero → profundo → REM). Cuando este ciclo se rompe — por ejemplo, despertarse durante el REM — afecta la calidad de tu descanso."
          }
        }
      }
    },
    "codon.help.what.title" : {
