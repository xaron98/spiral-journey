    "coach.consent.description": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب مدرب الذكاء الاصطناعي تنزيل نموذج بحجم 2.4 جيجابايت من الإنترنت. بعد التنزيل، تتم جميع العمليات على جهازك."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El Coach IA requereix descarregar un model de 2,4 GB d'internet. Després de la descàrrega, tot el processament es fa al dispositiu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der KI-Coach erfordert den Download eines 2,4 GB großen Modells aus dem Internet. Nach dem Download erfolgt die gesamte Verarbeitung auf deinem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The AI coach requires downloading a 2.4 GB model from the internet. After download, all processing happens on your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El coach IA requiere descargar un modelo de 2,4 GB de internet. Después de la descarga, todo el procesamiento se realiza en tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le coach IA nécessite le téléchargement d'un modèle de 2,4 Go depuis internet. Après le téléchargement, tout le traitement se fait sur votre appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIコーチはインターネットから2.4 GBのモデルをダウンロードする必要があります。ダウンロード後、すべての処理はデバイス上で行われます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
