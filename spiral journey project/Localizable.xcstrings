          "stringUnit" : {
            "state" : "translated",
            "value" : "وقت نومك يبتعد عن النافذة المستهدفة لوردية عملك. هذا يُصعّب التكيف والشعور بالراحة خلال ساعات العمل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu temps de son s'allunya de la finestra objectiu del teu torn. Això dificulta l'adaptació i sentir-se descansat durant les hores de treball."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Schlafzeit weicht vom Zielfenster für deine Schicht ab. Das erschwert die Anpassung und das Ausgeruhtsein während der Arbeitszeiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep timing is drifting away from your shift target window. This makes adapting and feeling rested during work hours harder."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu horario de sueño se aleja de la ventana objetivo de tu turno. Esto dificulta la adaptación y sentirse descansado durante las horas de trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'horaire de votre sommeil s'éloigne de la fenêtre cible de votre quart. Cela rend plus difficile l'adaptation et le fait de se sentir reposé pendant les heures de travail."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠時間がシフトの目標窓からずれています。これにより、勤務時間中の適応と休息感が困難になります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠时间偏离了班次目标窗口，使在工作时间内适应和感到休息更加困难。"
          }
        }
      }
    },
