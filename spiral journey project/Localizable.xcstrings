    "coach.issue.offTargetForShift.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضبط وقت نومك ليتوافق مع النافذة المستهدفة لوردية عملك، واستخدم قناعاً للعين وستائر معتمة لنوم نهاري جيد."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta l'hora de dormir per alinear-te amb la finestra objectiu del teu torn; usa antifaç i cortines opaques per a un bon son diürn."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe deine Schlafzeit an das Zielfenster deiner Schicht an; nutze Schlafmaske und Verdunkelungsvorhänge für guten Tagesschlaf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust your sleep time to align with your shift target window; use an eye mask and blackout curtains for good daytime sleep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta tu hora de sueño para alinearte con la ventana objetivo de tu turno; usa antifaz y cortinas opacas para un buen sueño diurno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez votre heure de sommeil pour vous aligner sur la fenêtre cible de votre quart; utilisez un masque pour les yeux et des rideaux occultants pour un bon sommeil diurne."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シフトの目標窓に合わせて睡眠時間を調整し、良質な昼間の睡眠のためにアイマスクと遮光カーテンを使用しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整睡眠时间以与班次目标窗口对齐；使用眼罩和遮光窗帘以获得良好的白天睡眠。"
          }
        }
      }
    },
    "coach.issue.offTargetForShift.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التوافق مع نافذة الوردية يُقلّل التعب أثناء العمل ويُحسّن التعافي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Alinear-se amb la finestra del torn reduirà la fatiga durant el treball i millorarà la recuperació."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Ausrichtung auf das Schichtfenster reduziert die Erschöpfung bei der Arbeit und verbessert die Erholung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aligning with the shift window will reduce on-shift fatigue and improve recovery."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alinearse con la ventana del turno reducirá la fatiga durante el turno y mejorará la recuperación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'aligner sur la fenêtre de quart réduira la fatigue pendant le quart et améliorera la récupération."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シフト窓に合わせることで、勤務中の疲労が軽減され、回復が改善されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与班次窗口对齐将减少班次期间的疲劳并改善恢复。"
          }
        }
      }
    },
    "coach.issue.offTargetForShift.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت نومك يبتعد عن النافذة المستهدفة لوردية عملك. هذا يُصعّب التكيف والشعور بالراحة خلال ساعات العمل."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu temps de son s'allunya de la finestra objectiu del teu torn. Això dificulta l'adaptació i sentir-se descansat durant les hores de treball."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schlafzeit weicht vom Zielfenster für deine Schicht ab. Das erschwert die Anpassung und das Ausgeruhtsein während der Arbeitszeiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep timing is drifting away from your shift target window. This makes adapting and feeling rested during work hours harder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu horario de sueño se aleja de la ventana objetivo de tu turno. Esto dificulta la adaptación y sentirse descansado durante las horas de trabajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'horaire de votre sommeil s'éloigne de la fenêtre cible de votre quart. Cela rend plus difficile l'adaptation et le fait de se sentir reposé pendant les heures de travail."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間がシフトの目標窓からずれています。これにより、勤務時間中の適応と休息感が困難になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠时间偏离了班次目标窗口，使在工作时间内适应和感到休息更加困难。"
          }
        }
      }
    },
    "coach.issue.offTargetForShift.title": {
