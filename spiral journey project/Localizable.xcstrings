    "neurospiral.info.datasource.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تأتي القراءات من HealthKit (Apple Watch). يلزم ما لا يقل عن 7 ليالٍ لبناء الطارة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les lectures venen de HealthKit (Apple Watch). Calen almenys 7 nits per construir el tor."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Messwerte stammen aus HealthKit (Apple Watch). Mindestens 7 Nächte sind erforderlich, um den Torus zu erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Readings come from HealthKit (Apple Watch). A minimum of 7 nights is needed to build the torus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las lecturas vienen de HealthKit (Apple Watch). Se requieren al menos 7 noches para construir el toroide."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les lectures proviennent de HealthKit (Apple Watch). Au moins 7 nuits sont nécessaires pour construire le tore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "測定値はHealthKit（Apple Watch）から取得。トーラスの構築には最低7晩必要。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据来自HealthKit（Apple Watch）。构建环面至少需要7晚。"
          }
        }
      }
    },
