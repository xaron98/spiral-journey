          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf den Mond, um die Einschlafzeit zu markieren. Ziehe den Cursor zur Aufwachzeit und tippe dann auf die Sonne zum Speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the moon to mark when you fell asleep. Drag the cursor to your wake-up time, then tap the sun to save."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca la luna para marcar cuándo te dormiste. Arrastra el cursor hasta tu hora de despertar y luego toca el sol para guardar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuie sur la lune pour marquer l'endormissement. Fais glisser le curseur jusqu'à l'heure de réveil, puis appuie sur le soleil pour enregistrer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "月をタップして就寝時間をマークします。カーソルを起床時間にドラッグし、太陽をタップして保存します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击月亮标记入睡时间。将光标拖到醒来时间，然后点击太阳保存。"
          }
        }
      }
    },
