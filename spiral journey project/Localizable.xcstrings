          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ · %@ → %@" : {
      "comment" : "A line that shows the date and start/end time of a manually logged sleep episode. The first argument is the capitalized date string (e.g. \"Monday\"). The second argument is the start hour, formatted to show as a two-digit number (e.g. \"07\"). The third argument is the end hour, formatted to show as a two-digit number (e.g. \"23\").",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@ → %3$@"
          }
        }
      }
    },
    "%@ %@" : {
      "comment" : "A label that describes the user's sleep DNA analysis tier and the number of weeks of data used to determine it. The first argument is the string “dna.tier.basic”, the string “dna.tier.intermediate”, the string “dna.tier.full”, the string “dna.tier.analysisLevel” or the string “dna.tier.weeksOfData”. The second argument is the string “dna.tier.basic”, the string “dna.tier.intermediate”, the string “dna.tier.full”, the string “dna.tier.analysisLevel” or the string “dna.tier.weeksOfData”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %@  →  %@ %@" : {
      "comment" : "A label displaying the predicted bedtime and wake-up time based on DNA alignment similarity. The first argument is the string “dna.alignment.header”, the string “dna.alignment.needMoreData”, the string “dna.alignment.similarity”, the string “dna.alignment.prediction”, the string “dna.alignment.sleep” or the string “dna.alignment.wake”. The second argument is the string “%1$02d:%2$02d”. The third argument is the string “dna.alignment.header”, the string “dna.alignment.needMoreData”, the string “dna.alignment.similarity”, the string “dna.alignment.prediction”, the string “dna.alignment.sleep” or the string “dna.alignment.wake”. The fourth argument is the string “%1$02d:%2$02d”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@  →  %3$@ %4$@"
          }
        }
      }
    },
    "%@ %@ (PLV %@)" : {
      "comment" : "A description of the strength of a DNA base pair connection, using a placeholder for the strength level. The argument is the string “%.2f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@ (PLV %3$@)"
          }
        }
      }
    },
    "%@ %lld" : {
      "comment" : "A label displaying the week number and a percentage indicating similarity to the user's profile. The first argument is the string “dna.3d.needsdata”, the string “dna.3d.patterns”, the string “dna.3d.week”, the string “dna.3d.similar” or the string “dna.3d.pattern”. The second argument is a percentage value (0-100).",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld"
          }
        }
      }
    },
    "%@ %lld%%  ·  HB %@" : {
      "comment" : "A pair of text labels showing the current circadian coherence percentage and the homeostasis balance as a decimal. Both values are suffixed with a percentage sign and a period followed by a space. The first argument is the string “dna.state.synchronized”, the string “dna.state.transitioning”, the string “dna.state.misaligned”, the string “dna.state.header” or the string “dna.state.coherence”. The third argument is the string “%.2f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%%  ·  HB %3$@"
          }
        }
      }
    },
    "%@ ↔ %@" : {
      "comment" : "A pair of features (e.g. \"estres\" and \"sueno\") with a description of their impact on sleep, including a numerical value indicating the strength of the relationship.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ ↔ %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "The text displayed in the center of the score gauge. The content is the score as a number.",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld" : {
      "comment" : "A label showing the number of evaluated samples (i.e., samples that have been predicted and their actual values compared to them) and the minimum required number of samples for training the model.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
