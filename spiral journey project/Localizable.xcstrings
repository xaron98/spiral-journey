    "onboarding.tabs.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "زر «الاتجاهات» لتحليل الإيقاع، و«المدرب» للنصائح اليومية، و«الإعدادات» لتخصيص التطبيق."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Visita Tendències per analitzar el ritme, Coach per als consells diaris i Ajustos per personalitzar l'app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Besuche Trends für die Rhythmusanalyse, Coach für tägliche Tipps und Einstellungen zur Anpassung der App."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visit Trends for rhythm analysis, Coach for daily tips, and Settings to customize the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Visita Tendencias para el análisis del ritmo, Coach para consejos diarios y Ajustes para personalizar la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visite Tendances pour l'analyse du rythme, Coach pour les conseils quotidiens et Réglages pour personnaliser l'app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トレンドでリズム分析、コーチで毎日のヒント、設定でアプリのカスタマイズができます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "访问趋势查看节律分析，Coach获取每日建议，设置自定义应用。"
          }
        }
      }
    },
    "onboarding.tabs.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استكشف التطبيق"
          }
        },
