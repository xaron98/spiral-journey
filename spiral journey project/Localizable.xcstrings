          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben eine flexible innere Uhr. Sie passen sich gut an verschiedene Zeitpläne an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have a flexible internal clock. You adapt well to different schedules."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes un reloj interno flexible. Te adaptas bien a diferentes horarios."
          }
        },
        "fr" : {
          "stringUnit" : {
