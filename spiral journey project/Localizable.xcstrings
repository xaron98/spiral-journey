    "neurospiral.info.oscillators.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ يقيس سرعة حركة حالتك في المستوى التوازني (ضغط النوم). ω₂ يقيس الإيقاع اليومي. نسبتهما (ω₁/ω₂) هي 'رقم الالتفاف' — إذا كانت نسبة عقلانية فمسارك مغلق (نوم منتظم)، وإذا كانت غير عقلانية فلا يتكرر أبداً (نوم غير منتظم)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ mesura com de ràpid es mou el teu estat en el pla homeostàtic (pressió de son). ω₂ mesura el ritme circadià. La seva ràtio (ω₁/ω₂) és el 'nombre d'enrotllament' — si és racional la trajectòria es tanca (son regular), si és irracional no es repeteix mai (son irregular)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ misst, wie schnell sich dein Zustand in der homöostatischen Ebene bewegt (Schlafdruck). ω₂ misst den zirkadianen Rhythmus. Ihr Verhältnis (ω₁/ω₂) ist die 'Windungszahl' — rational bedeutet geschlossene Bahn (regelmäßiger Schlaf), irrational bedeutet nie wiederholend (unregelmäßig)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ measures how fast your state moves in the homeostatic plane (sleep pressure). ω₂ measures circadian rhythm. Their ratio (ω₁/ω₂) is the 'winding number' — if rational, your trajectory closes (regular sleep); if irrational, it never repeats (irregular sleep)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ mide cuán rápido se mueve tu estado en el plano homeostático (presión de sueño). ω₂ mide el ritmo circadiano. Su ratio (ω₁/ω₂) es el 'número de enroscamiento' — si es racional tu trayectoria se cierra (sueño regular), si es irracional nunca se repite (sueño irregular)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ mesure la vitesse de votre état dans le plan homéostatique (pression de sommeil). ω₂ mesure le rythme circadien. Leur ratio (ω₁/ω₂) est le 'nombre d'enroulement' — rationnel = trajectoire fermée (sommeil régulier), irrationnel = ne se répète jamais (sommeil irrégulier)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁は恒常性面での状態の移動速度（睡眠圧）を測定します。ω₂は概日リズムを測定します。その比（ω₁/ω₂）が「巻き数」です — 有理数なら軌道は閉じ（規則的な睡眠）、無理数なら繰り返しません（不規則な睡眠）。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁测量您的状态在稳态平面（睡眠压力）中的移动速度。ω₂测量昼夜节律。它们的比值（ω₁/ω₂）是「缠绕数」——有理数意味着轨迹闭合（规律睡眠），无理数则永不重复（不规律睡眠）。"
          }
        }
      }
    },
    "neurospiral.info.oscillators.title" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المذبذبان ω₁ و ω₂"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els oscil·ladors ω₁ i ω₂"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Oszillatoren ω₁ und ω₂"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The oscillators ω₁ and ω₂"
          }
        },
        "es" : {
          "stringUnit" : {
