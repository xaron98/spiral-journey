    "coach.issue.sleepOverlapsContext.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جزء من نومك يقع ضمن فترة %@ الخاصة بك."
