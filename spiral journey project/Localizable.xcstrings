    "coach.issue.splitSleep.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تجنب القيلولة بعد الساعة 15:00 واستهدف فترة نوم رئيسية واحدة متصلة في الليل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evita les becaines després de les 15:00 i busca un únic bloc de son nocturn principal i continuat."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeide Schlafen nach 15:00 Uhr und strebe einen einzigen zusammenhängenden Hauptschlafblock nachts an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid sleeping after 15:00 and aim for one single consolidated night sleep block."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evita dormir después de las 15:00 y apunta a un único bloque de sueño nocturno consolidado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Évitez de dormir après 15:00 et visez un seul bloc de sommeil nocturne consolidé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "15:00以降の睡眠を避け、夜に一つの統合した睡眠ブロックを目指しましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "避免15:00后睡眠，目标是夜间一个整合的连续睡眠时段。"
          }
        }
      }
    },
    "coach.issue.splitSleep.outcome" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تجميع نومك سيُعمّق نومك الليلي ويُقوّي إشارات الساعة البيولوجية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolidar el teu son aprofundirà el son nocturn i enfortirà els senyals del rellotge intern."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Konsolidieren deines Schlafs wird den Nachtschlaf vertiefen und die inneren Uhrsignale stärken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolidating your sleep will deepen night sleep and strengthen internal clock signals."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolidar tu sueño profundizará el sueño nocturno y fortalecerá las señales del reloj interno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolider votre sommeil approfondira le sommeil nocturne et renforcera les signaux de l'horloge interne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠を統合することで、夜間睡眠が深まり、体内時計のシグナルが強化されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "整合睡眠将加深夜间睡眠，并强化生物钟信号。"
          }
        }
      }
    },
    "coach.issue.splitSleep.reason" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نومك موزع على فترتين رئيسيتيين تفصل بينهما فجوة كبيرة أثناء النهار. هذا النمط يعطل الضغط الداخلي للنوم ويُصعّب تحقيق نوم ليلي عميق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu son es divideix en dos períodes principals amb una bretxa significativa durant el dia. Aquest patró altera la pressió de son interna i dificulta el son nocturn profund."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Schlaf ist in zwei Hauptphasen aufgeteilt, mit einer erheblichen Lücke tagsüber. Dieses Muster stört den inneren Schlafdruck und erschwert tiefen Nachtschlaf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep is split into two main blocks with a significant gap during the day. This pattern disrupts internal sleep pressure and makes deep night sleep harder to achieve."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu sueño se divide en dos bloques principales con una brecha significativa durante el día. Este patrón altera la presión interna del sueño y dificulta el sueño nocturno profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre sommeil est divisé en deux blocs principaux avec une pause significative dans la journée. Ce schéma perturbe la pression interne du sommeil et rend difficile un sommeil nocturne profond."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠が日中の大きな空白を挟んで2つの主要なブロックに分かれています。このパターンは内部の睡眠圧力を乱し、深い夜間睡眠を困難にします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠分为两个主要时段，中间有较长的白天间隔。这种模式会破坏内部睡眠压力，使深度夜间睡眠更难实现。"
          }
        }
      }
    },
