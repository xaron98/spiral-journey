    "neurospiral.oscillators.explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (التوازن الداخلي) يقيس ضغط النوم دلتا. ω₂ (الساعة البيولوجية) يقيس الإيقاع الداخلي. نسبتهما هي رقم الالتفاف على الطوق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (homeostàtic) mesura la pressió de son delta. ω₂ (circadià) mesura el ritme endogen. La seva ràtio és el nombre d'enrotllament al tor."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (homöostatisch) misst den Delta-Schlafdruck. ω₂ (zirkadian) misst den endogenen Rhythmus. Ihr Verhältnis ist die Windungszahl auf dem Torus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (homeostatic) measures delta sleep pressure. ω₂ (circadian) measures endogenous rhythm. Their ratio is the winding number on the torus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (homeostático) mide la presión de sueño delta. ω₂ (circadiano) mide el ritmo endógeno. Su ratio es el número de enroscamiento en el toro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁ (homéostatique) mesure la pression de sommeil delta. ω₂ (circadien) mesure le rythme endogène. Leur ratio est le nombre d'enroulement sur le tore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁（恒常性）はデルタ睡眠圧を測定。ω₂（概日）は内因性リズムを測定。その比がトーラス上の巻き数です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ω₁（稳态）测量δ睡眠压力。ω₂（昼夜节律）测量内源性节律。它们的比值是环面上的缠绕数。"
          }
        }
      }
    },
