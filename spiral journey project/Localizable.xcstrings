    "neurospiral.info.what.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D يُسقط بيانات نومك من Apple Watch إلى فضاء رياضي رباعي الأبعاد يُسمى طوق كليفورد. يعيش هذا الطوق داخل مكعب رباعي الأبعاد (تيسيراكت) بـ 16 رأساً تمثل حالات فسيولوجية دقيقة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D projecta les dades de son del teu Apple Watch a un espai matemàtic 4D anomenat tor de Clifford. Aquest tor viu dins d'un tesseracte (hipercub 4D) amb 16 vèrtexs que representen microestats fisiològics."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D projiziert deine Schlafdaten von der Apple Watch in einen 4D-Raum namens Clifford-Torus. Dieser Torus lebt in einem Tesserakt (4D-Hyperwürfel) mit 16 Ecken, die physiologische Mikrozustände repräsentieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D maps your Apple Watch sleep data into a 4-dimensional mathematical space called a Clifford torus. This torus lives inside a tesseract (4D hypercube) with 16 vertices representing physiological micro-states."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D mapea tus datos de sueño del Apple Watch a un espacio matemático de 4 dimensiones llamado toro de Clifford. Este toro vive dentro de un teseracto (hipercubo 4D) con 16 vértices que representan micro-estados fisiológicos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D projette vos données de sommeil Apple Watch dans un espace mathématique 4D appelé tore de Clifford. Ce tore vit dans un tesseract (hypercube 4D) avec 16 sommets représentant des micro-états physiologiques."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4Dは、Apple Watchの睡眠データを「クリフォードトーラス」と呼ばれる4次元数学空間にマッピングします。このトーラスは16個の頂点を持つテッセラクト（4D超立方体）の中に存在し、各頂点は生理的マイクロステートを表します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NeuroSpiral 4D将Apple Watch睡眠数据映射到称为克利福德环面的四维数学空间。该环面存在于具有16个顶点的超正方体（4D超立方体）中，每个顶点代表一个生理微态。"
          }
        }
      }
