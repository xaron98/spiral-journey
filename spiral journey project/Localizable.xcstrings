    "rec.stabilizePeriod.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم اكتشاف انجراف تدريجي. الجمع بين ضوء الصباح الساطع + الميلاتونين بجرعة منخفضة (0.5 ملغ) قبل 5-7 ساعات من النوم يمكن أن يُثبِّت الإيقاع عند 24 ساعة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deriva progressiva detectada. Combinar llum brillant al matí + melatonina de baixa dosi (0,5 mg) 5-7h abans de dormir pot ancorar el ritme a 24h."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Verschiebung erkannt. Kombination aus hellem Morgenlicht + niedrig dosiertem Melatonin (0,5 mg) 5-7h vor dem Schlaf kann den Rhythmus auf 24h verankern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive drift detected. Combining bright morning light + low-dose melatonin (0.5 mg) 5-7 h before sleep can anchor the rhythm to 24 h."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deriva progresiva detectada. Combinar luz intensa por la mañana + melatonina de baja dosis (0,5 mg) 5-7h antes de dormir puede anclar el ritmo a 24h."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dérive progressive détectée. Combiner lumière vive le matin + mélatonine faible dose (0,5 mg) 5-7h avant le sommeil peut ancrer le rythme à 24h."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "進行性のドリフトが検出されました。朝の強い光＋低用量メラトニン（0.5mg）を睡眠5〜7時間前に組み合わせることでリズムを24時間に固定できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "检测到进行性漂移。将早晨强光照射与低剂量褪黑素（0.5mg，睡前5-7小时服用）结合，可将节律锚定在24小时。"
          }
        }
      }
    },
    "rec.stabilizePeriod.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تثبيت الفترة البيولوجية"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabilitza el període circadià"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Circadianen Rhythmus stabilisieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilize circadian period"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabiliza el período circadiano"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabiliser la période circadienne"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概日周期を安定させる"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "稳定昼夜节律周期"
          }
        }
      }
    },
    "rec.stabilizeSchedule.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتظام جيد، لكن هناك مجال للتحسين. قلّل الفارق بين أيام الأسبوع وعطلة نهاية الأسبوع إلى أقل من ساعة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bona regularitat, però hi ha marge de millora. Redueix la diferència entre dies laborables i cap de setmana a menys d'1 hora."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gute Regelmäßigkeit, aber Verbesserungspotenzial. Reduziere den Unterschied zwischen Werktagen und Wochenende auf unter 1 Stunde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Good regularity, but room to improve. Reduce the weekday/weekend difference to under 1 hour."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buena regularidad, pero hay margen de mejora. Reduce la diferencia entre días laborables y fin de semana a menos de 1 hora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bonne régularité, mais des progrès sont possibles. Réduisez la différence semaine/week-end à moins d'1 heure."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "規則性は良好ですが改善の余地があります。平日と週末の差を1時間未満に縮めましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "规律性良好，但仍有改善空间。将工作日与周末的差异缩小到1小时以内。"
          }
        }
      }
    },
    "rec.stabilizeSchedule.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
