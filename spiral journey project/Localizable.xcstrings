    "chronotype.result.definiteMorning.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ساعتك البيولوجية تعمل مبكرًا. تشعر بأعلى مستوى من اليقظة والإنتاجية في ساعات الصباح."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu rellotge intern funciona d'hora. Et sents més alerta i productiu al matí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre innere Uhr läuft früh. Sie fühlen sich morgens am wachsten und produktivsten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your internal clock runs early. You naturally feel most alert and productive in the morning hours."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu reloj interno funciona temprano. Te sientes más alerta y productivo por la mañana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre horloge interne est matinale. Vous vous sentez naturellement plus alerte et productif le matin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの体内時計は早めに動きます。朝の時間帯に最も覚醒し、生産性が高くなります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的生物钟偏早。你在早晨时段自然感觉最清醒、最高效。"
          }
        }
      }
    },
