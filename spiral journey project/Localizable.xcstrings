          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sommeil diurne pendant votre emploi du temps"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スケジュール中の日中睡眠"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日间睡眠占用日程时间"
          }
        }
      }
    },
    "coach.issue.delayedPhase.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعرض للضوء الساطع في الساعة %@ لمدة 20-30 دقيقة. قدِّم موعد نومك 15 دقيقة كل يومين."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Exposa't a llum intensa (sol o làmpada 10.000 lux) a les %@ durant 20-30 min. Avança l'hora d'anar a dormir 15 min cada 2 dies."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Helles Licht (Sonne oder 10.000-Lux-Lampe) um %@ Uhr für 20-30 Min. tanken. Schlafenszeit alle 2 Tage um 15 Min. vorverlegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get bright light (sunlight or 10,000-lux lamp) at %@ for 20–30 min. Shift bedtime 15 min earlier every 2 days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exponte a luz brillante (sol o lámpara 10.000 lux) a las %@ durante 20-30 min. Adelanta tu hora de dormir 15 min cada 2 días."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exposez-vous à une lumière vive (soleil ou lampe 10 000 lux) à %@ pendant 20-30 min. Avancez l'heure du coucher de 15 min tous les 2 jours."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@に明るい光（日光または1万ルクスランプ）を20〜30分浴びてください。2日ごとに就寝時刻を15分早めましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在%@接受强光（阳光或10000勒克斯灯）照射20-30分钟，每2天提前15分钟就寝。"
          }
        }
      }
    },
    "coach.issue.delayedPhase.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتقدم توقيت نومك بمقدار 15-30 دقيقة كل أسبوع مع الالتزام المنتظم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu horari de son avançarà 15-30 minuts per setmana amb consistència."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Schlafrhythmus verschiebt sich bei konsequenter Umsetzung um 15–30 Minuten pro Woche nach vorne."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep timing will advance 15–30 minutes per week with consistent effort."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu horario de sueño avanzará 15-30 minutos por semana con esfuerzo constante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre horaire de sommeil avancera de 15 à 30 minutes par semaine avec un effort constant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "継続的な取り組みにより、毎週15〜30分ずつ睡眠タイミングが前進します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "坚持努力，每周睡眠时间将提前15–30分钟。"
          }
        }
      }
    },
    "coach.issue.delayedPhase.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ذروة نشاطك البيولوجي تقع في المساء المتأخر، مما يعني أن ساعتك البيولوجية تعمل متأخرة بشكل ملحوظ عن المعيار الاجتماعي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu pic d'activitat biològica cau tard a la nit, cosa que significa que el teu rellotge intern funciona significativament més tard del que la majoria de programes socials requereixen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein biologisches Aktivitätsmaximum fällt auf den späten Abend, was bedeutet, dass deine innere Uhr deutlich später als der gesellschaftliche Standard läuft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your biological activity peak falls in the late evening, meaning your internal clock is running significantly later than most social schedules require."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu pico de actividad biológica cae en la noche avanzada, lo que significa que tu reloj interno funciona significativamente más tarde de lo que la mayoría de los horarios sociales requieren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre pic d'activité biologique tombe en fin de soirée, ce qui signifie que votre horloge interne fonctionne bien plus tard que la plupart des horaires sociaux ne le requièrent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生物学的な活動のピークが深夜に集中しており、体内時計が社会的なスケジュールより大幅に遅れていることを意味します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的生物活动峰值出现在深夜，说明您的生物钟比大多数社会时间表所需的要晚得多。"
          }
        }
      }
    },
    "coach.issue.delayedPhase.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طور النوم المتأخر"
          }
        },
        "ca": {
          "stringUnit": {
