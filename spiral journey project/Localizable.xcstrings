    "chronotype.q5" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُقال إن هناك أشخاص \"صباحيين\" و\"مسائيين\". أيهما تعتبر نفسك؟"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es parla de persones \"matutines\" i \"nocturnes\". Quin consideres que ets?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Man hört von \"Morgen-\" und \"Abendtypen\". Welcher Typ sind Sie?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One hears of \"morning\" and \"evening\" types. Which do you consider yourself to be?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se habla de personas \"matutinas\" y \"nocturnas\". ¿Cuál consideras que eres?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On entend parler de types \"du matin\" et \"du soir\". Lequel pensez-vous être ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「朝型」と「夜型」という分類がありますが、自分はどちらだと思いますか？"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人们说有“早起型”和“夜猫型”。你认为自己属于哪种？"
          }
        }
      }
    },
