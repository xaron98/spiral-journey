        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les teves nits contenen múltiples transicions son-vigília. Això redueix la quantitat de son d'ones lentes i son REM que obtens."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Nächte enthalten mehrere Schlaf-Wach-Übergänge. Das reduziert die Menge an Tiefschlaf und REM-Schlaf, die du bekommst."
