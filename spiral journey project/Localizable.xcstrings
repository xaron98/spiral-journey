    "coach.issue.sleepOverlapsContext.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فكر في تقديم موعد نومك لتتجنب التداخل مع بداية %@."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Considera avançar l'hora d'anar a dormir per alliberar l'inici del teu %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erwäge, deine Schlafenszeit vorzuverlegen, um deinen %@-Beginn freizuhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Consider shifting your bedtime earlier to clear your %@ start."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Considera adelantar tu hora de acostarte para despejar el inicio de tu %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envisagez d'avancer votre heure de coucher pour libérer le début de votre %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の開始前に起きられるよう、就寝時間を早めることを検討してください。"
          }
        },
