          }
        }
      }
    },
    "coach.issue.daytimeSleepConsumesContext.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كنت تأخذ قيلولة، حافظ عليها أقل من 20 دقيقة أو انقلها خارج فترة %@."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Si fas migdiada, mantén-la per sota de 20 minuts o mou-la fora de la teva finestra de %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte Nickerchen unter 20 Minuten oder verlege sie außerhalb deines %@-Zeitfensters."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If napping, keep it under 20 minutes or move it outside your %@ window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si duermes siesta, mantenla bajo 20 minutos o muévela fuera de tu ventana de %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous faites la sieste, gardez-la sous 20 minutes ou déplacez-la hors de votre créneau de %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "昼寝する場合は20分以内にするか、%@の時間帯外に移してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果小睡，请控制在20分钟以内或将其移到%@时段之外。"
          }
        }
      }
    },
    "coach.issue.daytimeSleepConsumesContext.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القيلولة القصيرة تعزز اليقظة دون التدخل في الالتزامات أو النوم الليلي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les migdiades curtes milloren l'alerta sense interferir amb obligacions ni el son nocturn."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurze Power-Naps steigern die Wachheit ohne Verpflichtungen oder Nachtschlaf zu beeinträchtigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short power naps boost alertness without interfering with obligations or nighttime sleep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las siestas cortas mejoran la alerta sin interferir con obligaciones ni el sueño nocturno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les courtes siestes améliorent la vigilance sans interférer avec les obligations ou le sommeil nocturne."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短いパワーナップは義務や夜の睡眠を妨げずに覚醒度を高めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "短暂的小睡可以提高警觉性，而不影响义务或夜间睡眠。"
          }
        }
      }
    },
    "coach.issue.daytimeSleepConsumesContext.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نوم نهاري كبير يقع ضمن فترة %@ الخاصة بك."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Una quantitat significativa de son diürn cau dins la teva finestra de %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erheblicher Tagesschlaf fällt in dein %@-Zeitfenster."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Significant daytime sleep falls within your %@ window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una cantidad significativa de sueño diurno cae dentro de tu ventana de %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un sommeil diurne significatif tombe dans votre créneau de %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "かなりの日中睡眠が%@の時間帯に含まれています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "大量日间睡眠落在您的%@时段内。"
          }
        }
      }
    },
    "coach.issue.daytimeSleepConsumesContext.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
