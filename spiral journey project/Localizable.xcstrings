    "coach.issue.delayedPhase.reason" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ذروة نشاطك البيولوجي تقع في المساء المتأخر، مما يعني أن ساعتك البيولوجية تعمل متأخرة بشكل ملحوظ عن المعيار الاجتماعي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu pic d'activitat biològica cau tard a la nit, cosa que significa que el teu rellotge intern funciona significativament més tard del que la majoria de programes socials requereixen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein biologisches Aktivitätsmaximum fällt auf den späten Abend, was bedeutet, dass deine innere Uhr deutlich später als der gesellschaftliche Standard läuft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your biological activity peak falls in the late evening, meaning your internal clock is running significantly later than most social schedules require."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu pico de actividad biológica cae en la noche avanzada, lo que significa que tu reloj interno funciona significativamente más tarde de lo que la mayoría de los horarios sociales requieren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre pic d'activité biologique tombe en fin de soirée, ce qui signifie que votre horloge interne fonctionne bien plus tard que la plupart des horaires sociaux ne le requièrent."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生物学的な活動のピークが深夜に集中しており、体内時計が社会的なスケジュールより大幅に遅れていることを意味します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的生物活动峰值出现在深夜，说明您的生物钟比大多数社会时间表所需的要晚得多。"
          }
        }
      }
    },
