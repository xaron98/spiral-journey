          }
        }
      }
    },
    "coach.issue.sufficientButMisaligned.reason" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مدة نومك كافية لكن توقيته لا يتوافق مع الإيقاع الطبيعي للضوء والنشاط. قد تشعر بالتعب رغم مدة النوم الكافية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La durada del teu son és adequada però el temps no s'alinea amb el ritme natural de llum i activitat. Podries sentir-te cansat malgrat dormir prou."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Schlafdauer ist ausreichend, aber der Zeitpunkt stimmt nicht mit dem natürlichen Hell-Dunkel-Rhythmus überein. Du könntest dich trotz ausreichend Schlaf müde fühlen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep duration is adequate but the timing doesn't align with the natural light-dark rhythm. You may feel tired despite sleeping enough."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu duración de sueño es adecuada pero el horario no se alinea con el ritmo natural de luz y oscuridad. Podrías sentirte cansado a pesar de dormir suficiente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre durée de sommeil est adéquate mais le timing n'est pas aligné avec le rythme naturel lumière-obscurité. Vous pourriez vous sentir fatigué malgré un sommeil suffisant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠時間は十分ですが、タイミングが自然の明暗リズムと合っていません。十分眠っているにもかかわらず疲れを感じるかもしれません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠时长足够，但时间安排与自然光暗节律不匹配，可能即使睡够了也感到疲倦。"
          }
        }
      }
    },
