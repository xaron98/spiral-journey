    "stats.glossary.acrophase" : {
      "comment" : "Definition of \"Acrophase\" in the stats glossary sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وقت اليوم الذي يبلغ فيه إيقاعك اليومي ذروته. الأكروفاز المبكر يعني نمطًا صباحيًا؛ والمتأخر يعني نمطًا مسائيًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'hora del dia en què el teu ritme circadià assoleix el seu pic. Una acrofase més primerenca indica un cronotip matutí; una de més tardana, un cronotip vespertí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Tageszeit, zu der dein circadianer Rhythmus seinen Höhepunkt erreicht. Eine frühere Akrophase bedeutet einen Morgentyp; eine spätere einen Abendtyp."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The time of day when your circadian rhythm peaks. An earlier acrophase means a morning chronotype; a later one means an evening chronotype."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La hora del día en que tu ritmo circadiano alcanza su pico. Una acrofase más temprana indica un cronotipo matutino; una más tardía, un cronotipo vespertino."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'heure de la journée où votre rythme circadien atteint son pic. Une acrophase précoce indique un chronotype du matin ; une tardive, du soir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概日リズムがピークに達する時刻。早い峰相は朝型、遅い峰相は夜型を示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的昼夜节律达到峰值的时刻。较早的峰相表示晨型人，较晚的表示夜型人。"
          }
        }
      }
    },
    "stats.glossary.acroSigma" : {
      "comment" : "Definition of \"AcroSigma\" in the stats glossary sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الانحراف المعياري لأكروفازك عبر الأيام. القيمة الأقل تعني أن إيقاعك يبلغ ذروته في وقت ثابت كل يوم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La desviació estàndard de la teva acrofase entre dies. Un valor més baix significa que el teu ritme assoleix el pic a una hora consistent cada dia."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Standardabweichung deiner Akrophase über Tage. Ein niedrigerer Wert bedeutet, dass dein Rhythmus täglich zu einer konsistenten Zeit seinen Höhepunkt erreicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The standard deviation of your acrophase across days. A lower value means your rhythm peaks at a consistent time each day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La desviación estándar de tu acrofase entre días. Un valor más bajo significa que tu ritmo alcanza el pico a una hora consistente cada día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'écart-type de votre acrophase sur plusieurs jours. Une valeur faible signifie que votre rythme atteint son pic à une heure constante chaque jour."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日ごとの峰相の標準偏差。値が低いほど、毎日一定の時刻にリズムがピークに達することを意味します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的峰相在各天之间的标准差。较低的值表示节律每天在一致的时间达到峰值。"
          }
        }
      }
    },
    "stats.glossary.amplitude" : {
      "comment" : "Definition of \"Amplitude\" in the stats glossary.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قوة إيقاعك اليومي — مدى تباين توقيت نومك بين الذروة والقاع. الامبليتود الأعلى يشير إلى إيقاع أقوى وأكثر ثباتًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La força del teu ritme circadià: quant varia el moment del teu son entre el pic i el vall. Una amplitud més alta suggereix un ritme més fort i robust."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Stärke deines circadianen Rhythmus — wie stark dein Schlafzeitpunkt zwischen Hoch und Tief variiert. Eine höhere Amplitude deutet auf einen stärkeren, robusteren Rhythmus hin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The strength of your circadian rhythm — how much your sleep timing varies between its peak and trough. A higher amplitude suggests a stronger, more robust rhythm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fuerza de tu ritmo circadiano: cuánto varía el momento de tu sueño entre su pico y su valle. Una mayor amplitud sugiere un ritmo más fuerte y robusto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La force de votre rythme circadien — combien votre timing de sommeil varie entre son pic et son creux. Une amplitude plus élevée suggère un rythme plus fort et robuste."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概日リズムの強さ——睡眠タイミングがピークと谷の間でどれだけ変動するか。振幅が高いほど、リズムがより強固であることを示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的昼夜节律强度——睡眠时间在峰值和谷值之间的变化幅度。较高的振幅表明节律更强健。"
          }
        }
      }
    },
