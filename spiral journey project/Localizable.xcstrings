    "coach.issue.insufficientData.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف جلسات نوم لعدة ليالٍ يدوياً أو وصّل Apple Health للاستيراد التلقائي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Afegeix sessions de son per a diverses nits manualment o connecta Apple Health per a la importació automàtica."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge Schlafeinträge für mehrere Nächte manuell hinzu oder verbinde Apple Health für den automatischen Import."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add sleep sessions for several nights manually or connect Apple Health for automatic import."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega sesiones de sueño para varias noches manualmente o conecta Apple Health para la importación automática."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des sessions de sommeil pour plusieurs nuits manuellement ou connectez Apple Health pour l'importation automatique."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "複数の夜の睡眠セッションを手動で追加するか、自動インポートのためにApple Healthに接続してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动添加几晚的睡眠记录，或连接Apple Health进行自动导入。"
          }
        }
      }
    },
    "coach.issue.insufficientData.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد 3 ليالٍ أو أكثر، ستظهر رؤى شخصية ودقيقة عن إيقاعك اليومي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Amb 3 o més nits, apareixeran insights precisos i personalitzats sobre el teu ritme circadià."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ab 3 oder mehr Nächten erscheinen genaue, personalisierte Einblicke in deinen Tagesrhythmus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With 3 or more nights, accurate personalized insights about your circadian rhythm will appear."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con 3 o más noches, aparecerán perspectivas precisas y personalizadas sobre tu ritmo circadiano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avec 3 nuits ou plus, des insights précis et personnalisés sur votre rythme circadien apparaîtront."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "3晩以上のデータがあれば、あなたの概日リズムについての正確な個人化されたインサイトが表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有3晚或更多数据后，关于您昼夜节律的准确个性化见解将会出现。"
          }
        }
      }
    },
    "coach.issue.insufficientData.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نحتاج إلى المزيد من بيانات النوم لتقديم تحليل دقيق. سجّل نومك لعدة ليالٍ لبدء الحصول على رؤى شخصية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Necessitem més dades de son per proporcionar una anàlisi precisa. Registra el teu son durant unes quantes nits per començar a obtenir insights personalitzats."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir brauchen mehr Schlafdaten für eine genaue Analyse. Erfasse deinen Schlaf mehrere Nächte lang, um personalisierte Erkenntnisse zu erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We need more sleep data to provide accurate analysis. Track your sleep for a few nights to start receiving personalized insights."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Necesitamos más datos de sueño para proporcionar un análisis preciso. Registra tu sueño durante algunas noches para comenzar a recibir perspectivas personalizadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons besoin de plus de données de sommeil pour fournir une analyse précise. Enregistrez votre sommeil pendant quelques nuits pour commencer à recevoir des insights personnalisés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "正確な分析のためにより多くの睡眠データが必要です。個人化されたインサイトを受け取るために数晩睡眠を記録してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们需要更多睡眠数据才能提供准确的分析。记录几晚的睡眠以开始获得个性化见解。"
          }
        }
      }
    },
