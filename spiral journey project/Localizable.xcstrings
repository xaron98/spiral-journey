    "dna.info.reference" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مستند إلى: Dynamic Time Warping (Sakoe & Chiba, 1978)، Phase Locking Value (Lachaux et al., 1999)، persistent homology (Edelsbrunner, 2000)، ونموذج العمليتين (Borbely, 1982)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basat en: Dynamic Time Warping (Sakoe & Chiba, 1978), Phase Locking Value (Lachaux et al., 1999), persistent homology (Edelsbrunner, 2000), i el model de dos processos (Borbely, 1982)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basierend auf: Dynamic Time Warping (Sakoe & Chiba, 1978), Phase Locking Value (Lachaux et al., 1999), persistenter Homologie (Edelsbrunner, 2000) und dem Zwei-Prozess-Modell (Borbely, 1982)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Based on: Dynamic Time Warping (Sakoe & Chiba, 1978), Phase Locking Value (Lachaux et al., 1999), persistent homology (Edelsbrunner, 2000), and the two-process model (Borbely, 1982)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basado en: Dynamic Time Warping (Sakoe & Chiba, 1978), Phase Locking Value (Lachaux et al., 1999), homología persistente (Edelsbrunner, 2000), y el modelo de dos procesos (Borbely, 1982)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basé sur: Dynamic Time Warping (Sakoe & Chiba, 1978), Phase Locking Value (Lachaux et al., 1999), homologie persistante (Edelsbrunner, 2000), et le modèle à deux processus (Borbely, 1982)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "参照文献：Dynamic Time Warping (Sakoe & Chiba, 1978)、Phase Locking Value (Lachaux et al., 1999)、persistent homology (Edelsbrunner, 2000)、および2過程モデル (Borbely, 1982)。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基于：Dynamic Time Warping（Sakoe & Chiba, 1978）、Phase Locking Value（Lachaux et al., 1999）、persistent homology（Edelsbrunner, 2000）以及双过程模型（Borbely, 1982）。"
          }
        }
      }
    },
    "dna.info.tiers.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عمق التحليل يعتمد على كمية البيانات المتاحة:\n\n• المستوى 1 (أساسي): أقل من 4 أسابيع. يعرض ترميز النيوكليوتيد والحالة الأساسية.\n• المستوى 2 (متوسط): 4-8 أسابيع. يضيف تنبؤات المحاذاة واكتشاف النماذج.\n• المستوى 3 (كامل): 8+ أسابيع. يفتح خط الأنابيب الكامل: الطوبولوجيا المتقدمة، طيف المعلومات المتبادلة، نمذجة أحداث Hawkes، والمقارنات عبر الأسابيع.\n\nمزيد من البيانات يعني رؤى أغنى — لكن حتى المستوى 1 يُظهر أنماطاً مفيدة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La profunditat de l'anàlisi depèn de quantes dades hi ha disponibles:\n\n• Nivell 1 (Bàsic): Menys de 4 setmanes. Mostra la codificació de nucleòtids i l'estat bàsic.\n• Nivell 2 (Intermedi): 4-8 setmanes. Afegeix prediccions d'alineació i detecció de motius.\n• Nivell 3 (Complet): 8+ setmanes. Desbloqueja el pipeline complet: topologia avançada, espectre d'informació mútua, modelatge d'esdeveniments Hawkes, i comparacions entre setmanes.\n\nMés dades significa coneixements més rics — però fins i tot el Nivell 1 mostra patrons útils."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Analysetiefe hängt davon ab, wie viele Daten verfügbar sind:\n\n• Stufe 1 (Basis): Weniger als 4 Wochen. Zeigt Nukleotidkodierung und Grundzustand.\n• Stufe 2 (Mittel): 4-8 Wochen. Fügt Ausrichtungsvorhersagen und Motiverkennung hinzu.\n• Stufe 3 (Vollständig): 8+ Wochen. Schaltet die vollständige Pipeline frei: erweiterte Topologie, gegenseitiges Informationsspektrum, Hawkes-Ereignismodellierung und wochenübergreifende Vergleiche.\n\nMehr Daten bedeutet reichhaltigere Erkenntnisse — aber selbst Stufe 1 zeigt nützliche Muster."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The depth of analysis depends on how much data is available:\n\n• Tier 1 (Basic): Less than 4 weeks. Shows nucleotide encoding and basic state.\n• Tier 2 (Intermediate): 4-8 weeks. Adds alignment predictions and motif detection.\n• Tier 3 (Full): 8+ weeks. Unlocks the complete pipeline: advanced topology, mutual information spectrum, Hawkes event modeling, and cross-week comparisons.\n\nMore data means richer insights — but even Tier 1 shows useful patterns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La profundidad del análisis depende de cuántos datos hay disponibles:\n\n• Nivel 1 (Básico): Menos de 4 semanas. Muestra la codificación de nucleótidos y el estado básico.\n• Nivel 2 (Intermedio): 4-8 semanas. Agrega predicciones de alineación y detección de motivos.\n• Nivel 3 (Completo): 8+ semanas. Desbloquea el flujo completo: topología avanzada, espectro de información mutua, modelado de eventos Hawkes, y comparaciones entre semanas.\n\nMás datos significa perspectivas más ricas — pero incluso el Nivel 1 muestra patrones útiles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La profondeur de l'analyse dépend de la quantité de données disponibles:\n\n• Niveau 1 (Basique): Moins de 4 semaines. Affiche l'encodage des nucléotides et l'état de base.\n• Niveau 2 (Intermédiaire): 4-8 semaines. Ajoute des prédictions d'alignement et la détection de motifs.\n• Niveau 3 (Complet): 8+ semaines. Débloque le pipeline complet: topologie avancée, spectre d'information mutuelle, modélisation d'événements Hawkes, et comparaisons inter-semaines.\n\nPlus de données signifie des insights plus riches — mais même le Niveau 1 montre des schémas utiles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分析の深さは利用可能なデータ量によって異なります：\n\n• ティア1（基本）：4週間未満。ヌクレオチドエンコードと基本状態を表示します。\n• ティア2（中級）：4〜8週間。アライメント予測とモチーフ検出を追加します。\n• ティア3（フル）：8週間以上。完全なパイプラインをアンロック：高度なトポロジー、相互情報スペクトル、Hawkesイベントモデリング、クロスウィーク比較。\n\nデータが多いほどリッチなインサイトが得られます — でもティア1でも有用なパターンが見られます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分析深度取决于可用数据量：\n\n• 第1层（基础）：不足4周。显示核苷酸编码和基本状态。\n• 第2层（中级）：4-8周。添加比对预测和主题检测。\n• 第3层（完整）：8周以上。解锁完整管道：高级拓扑学、互信息谱、Hawkes事件建模以及跨周比较。\n\n数据越多，洞察越丰富——但即使是第1层也能显示有用的模式。"
          }
        }
      }
    },
