    "rec.advancePhase.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم اكتشاف نمط تأخر الطور. ضوء الصباح الساطع (10,000 لوكس) لمدة 30 دقيقة عند الاستيقاظ هو العلاج الأكثر فاعلية. تجنّب الضوء الأزرق بعد الساعة 21:00."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patró de fase retardada detectat. La llum intensa al matí (10.000 lux) durant 30 min en despertar és el tractament més eficaç. Evita la llum blava després de les 21:00."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verzögerte Phasenmuster erkannt. Helles Morgenlicht (10.000 Lux) 30 Min nach dem Aufwachen ist die wirksamste Behandlung. Kein Blaulicht nach 21:00 Uhr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep timing is significantly delayed. Bright morning light (sunlight or 10,000 lux lamp) for 20-30 min on waking is the most effective treatment. Shift bedtime 15 min earlier every 2 days. Avoid blue light after 21:00."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu horario de sueño está significativamente retrasado. La luz matutina intensa (sol o lámpara de 10.000 lux) durante 20-30 min al despertar es el tratamiento más eficaz. Adelanta la hora de dormir 15 min cada 2 días. Evita la luz azul después de las 21:00."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schéma de phase retardée détecté. La lumière vive le matin (10 000 lux) pendant 30 min au réveil est le traitement le plus efficace. Évitez la lumière bleue après 21h."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "遅延位相パターンが検出されました。起床時に10,000ルクスの強い朝の光を30分浴びるのが最も効果的です。21:00以降は青色光を避けてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "检测到相位延迟模式。醒来后用10,000勒克斯的强光照射30分钟是最有效的治疗方法。21:00后避免蓝光。"
          }
        }
      }
    },
