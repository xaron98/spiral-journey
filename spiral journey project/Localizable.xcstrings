    "chronotype.q2": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لو كنت حرًا في تخطيط مسائك، في أي وقت ستذهب للنوم؟"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Si poguessis planificar la teva nit lliurement, a quina hora te n'iries a dormir?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Ihren Abend frei planen könnten, wann würden Sie ins Bett gehen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you were entirely free to plan your evening, what time would you go to bed?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si pudieras planificar tu noche libremente, ¿a qué hora te irías a dormir?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous pouviez planifier votre soirée librement, à quelle heure iriez-vous vous coucher ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自由に夜を計画できるとしたら、何時に寝ますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你可以自由安排晚间时间，你会几点上床睡觉？"
          }
        }
      }
    },
