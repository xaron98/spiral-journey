    "analysis.charts.autocorrelation.desc" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يوضح أي ساعات اليوم هي الأكثر استقرارًا عبر فترات زمنية مختلفة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra quines hores del dia són més estables en diferents intervals de temps."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt, welche Tageszeiten über verschiedene Zeiträume am stabilsten sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shows which hours of the day are most stable across different time intervals."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra qué horas del día son más estables en diferentes intervalos de tiempo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Montre quelles heures de la journée sont les plus stables à différents intervalles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1日のうちどの時間帯が最も安定しているかを時間間隔ごとに表示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "显示一天中哪些时段在不同时间间隔内最稳定。"
          }
        }
      }
    },
