    "coach.issue.rephaseInProgress.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقدّم بوقت نومك الليلة وفق جدول إعادة الضبط. لا تحذف أياماً — الاستمرارية هي المفتاح."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avança l'hora de dormir d'aquesta nit seguint el calendari de refasament. No et saltes dies — la consistència és la clau."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verlege die heutige Schlafenszeit nach dem Neuausrichtungsplan vor. Überspringe keine Tage — Konsequenz ist der Schlüssel."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advance tonight's bedtime according to the rephase schedule. Don't skip days — consistency is the key."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adelanta la hora de dormir de esta noche según el plan de refasado. No te saltes días — la consistencia es la clave."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avancez l'heure de coucher de ce soir selon le calendrier de rephasage. Ne sautez pas de jours — la constance est la clé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リフェーズスケジュールに従って今夜の就寝時間を早めましょう。日をスキップしないでください — 一貫性が鍵です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按照重相位时间表提前今晚的就寝时间。不要跳过任何一天——持续性是关键。"
          }
        }
      }
    },
    "coach.issue.rephaseInProgress.outcome" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل خطوة تقترب بك من هدفك — ستلاحظ تحسناً في جودة النوم كلما اقتربت من النافذة المستهدفة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada pas t'acosta a l'objectiu — notaràs una millora en la qualitat del son a mesura que t'acostis a la finestra objectiu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Schritt bringt dich näher zum Ziel — du wirst eine Verbesserung der Schlafqualität bemerken, je näher du dem Zielfenster kommst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each step brings you closer to the target — you'll notice improving sleep quality as you approach the target window."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada paso te acerca al objetivo — notarás una mejora en la calidad del sueño a medida que te acerques a la ventana objetivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque pas vous rapproche de l'objectif — vous remarquerez une amélioration de la qualité du sommeil au fur et à mesure que vous approchez de la fenêtre cible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一歩ずつ目標に近づいています — 目標窓に近づくにつれて睡眠の質が改善されていくことに気づくでしょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一步都让您更接近目标——随着接近目标窗口，您会注意到睡眠质量的改善。"
          }
        }
      }
    },
    "coach.issue.rephaseInProgress.reason" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تزال ساعتك البيولوجية بعيدة عن الهدف. استمر في التقدم التدريجي — التحولات الصغيرة المنتظمة أفضل من القفز الكبير."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu rellotge intern encara és lluny de l'objectiu. Continua amb els avanços gradualment — els petits desplaçaments constants funcionen millor que els salts grans."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine innere Uhr ist noch weit vom Ziel entfernt. Mache weiter mit schrittweisem Voranschreiten — kleine, gleichmäßige Verschiebungen wirken besser als große Sprünge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your internal clock is still some distance from the target. Keep advancing gradually — small consistent shifts work better than large jumps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu reloj interno aún está lejos del objetivo. Continúa avanzando gradualmente — los pequeños cambios consistentes funcionan mejor que los saltos grandes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre horloge interne est encore loin de l'objectif. Continuez à avancer progressivement — les petits décalages constants fonctionnent mieux que les grands sauts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "体内時計はまだ目標から離れています。段階的に進め続けましょう — 小さく一定のシフトは大きなジャンプより効果的です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的生物钟距目标还有一段距离。继续逐步推进——小而持续的调整比大幅跳跃更有效。"
          }
        }
      }
    },
