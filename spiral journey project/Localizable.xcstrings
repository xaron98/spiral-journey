    "rec.consistentSchedule.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انتظامك منخفض. حدد وقت استيقاظ ثابتاً (حتى في عطلة نهاية الأسبوع) بتباين أقل من 30 دقيقة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva regularitat és baixa. Fixa una hora d'aixecar-te (fins i tot el cap de setmana) amb menys de 30 minuts de variació."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Regelmäßigkeit ist gering. Lege eine feste Aufstehzeit fest (auch am Wochenende) mit weniger als 30 Minuten Abweichung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your regularity is low. Set a fixed wake-up time (even on weekends) with less than 30 minutes variation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu regularidad es baja. Fija una hora de despertar (incluso el fin de semana) con menos de 30 minutos de variación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre régularité est faible. Fixez une heure de réveil fixe (même le week-end) avec moins de 30 min de variation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規則性が低いです。週末も含め固定の起床時間を設定し、30分以内の変動に抑えましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的规律性较低。设定固定起床时间（包括周末），变动不超过30分钟。"
          }
        }
      }
    },
