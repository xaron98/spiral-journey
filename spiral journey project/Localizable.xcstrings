    "dna.info.nucleotide.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل يوم مُشفَّر كنيوكليوتيد بـ16 ميزة: متى ذهبت للنوم، متى استيقظت، كم نمت، نسب النوم العميق و REM، التشتت، الكافيين، التمرين، الإجهاد، والمزيد.\n\nهذه الأرقام الـ16 هي 'حرفك الجيني' اليومي. سبعة أيام تشكل تسلسلاً — كلمة نومك الأسبوعية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada dia es codifica com un nucleòtid amb 16 característiques: quan vas anar a dormir, quan et vas despertar, quant temps vas dormir, els teus percentatges de son profund i REM, fragmentació, cafeïna, exercici, estrès, i més.\n\nAquests 16 nombres són la teva 'lletra genètica' diària. Set dies formen una seqüència — la teva paraula de son setmanal."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Tag wird als Nukleotid mit 16 Merkmalen kodiert: wann du schlafen gegangen bist, wann du aufgewacht bist, wie lange du geschlafen hast, deine Tiefschlaf- und REM-Prozentwerte, Fragmentierung, Koffein, Sport, Stress und mehr.\n\nDiese 16 Zahlen sind dein täglicher 'genetischer Buchstabe'. Sieben Tage ergeben eine Sequenz — dein wöchentliches Schlafwort."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each day is encoded as a nucleotide with 16 features: when you went to bed, when you woke up, how long you slept, your deep sleep and REM percentages, fragmentation, caffeine, exercise, stress, and more.\n\nThese 16 numbers are your daily 'genetic letter.' Seven days make a sequence — your weekly sleep word."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada día se codifica como un nucleótido con 16 características: cuándo te fuiste a dormir, cuándo te despertaste, cuánto dormiste, tus porcentajes de sueño profundo y REM, fragmentación, cafeína, ejercicio, estrés, y más.\n\nEstos 16 números son tu 'letra genética' diaria. Siete días forman una secuencia — tu palabra de sueño semanal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque jour est encodé comme un nucléotide avec 16 caractéristiques: quand tu es allé te coucher, quand tu t'es réveillé, combien de temps tu as dormi, tes pourcentages de sommeil profond et REM, la fragmentation, la caféine, l'exercice, le stress, et plus.\n\nCes 16 nombres sont ta 'lettre génétique' quotidienne. Sept jours forment une séquence — ton mot de sommeil hebdomadaire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各日は16の特徴を持つヌクレオチドとしてエンコードされます：就寝時間、起床時間、睡眠時間、深い睡眠とREMの割合、断片化、カフェイン、運動、ストレスなど。\n\nこれら16の数字があなたの日々の「遺伝的文字」です。7日間でシーケンスが作られます — あなたの週次睡眠ワードです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天被编码为具有16个特征的核苷酸：你何时入睡、何时醒来、睡了多久、深度睡眠和REM百分比、碎片化程度、咖啡因、运动、压力等。\n\n这16个数字是你每天的'遗传字母'。七天构成一个序列——你的每周睡眠词汇。"
          }
        }
      }
    },
