    "temporal.help.delay.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some factors may not affect your sleep immediately. We use the Hawkes process (Hawkes, 1971, Biometrika) — a self-exciting model validated in seismology (ETAS earthquake aftershock model), finance (market crash cascades), epidemiology (COVID-19 contagion chains), and neuroscience (neural spike train modeling, Pillow et al. 2008). Its application to sleep is EXPERIMENTAL and original to this app — there are no published studies validating this specific use. The delayed effects shown are correlations from your data, not proven causation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos factores pueden no afectar tu sueño inmediatamente. Usamos el proceso de Hawkes (Hawkes, 1971, Biometrika) — un modelo auto-excitado validado en sismología (modelo ETAS de réplicas de terremotos), finanzas (cascadas de crashes bursátiles), epidemiología (cadenas de contagio COVID-19) y neurociencia (modelado de trenes de impulsos neuronales, Pillow et al. 2008). Su aplicación al sueño es EXPERIMENTAL y original de esta app — no existen estudios publicados que validen este uso específico. Los efectos retardados mostrados son correlaciones de tus datos, no causalidad demostrada."
          }
        }
      }
    },
    "temporal.help.delay.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is the delay effect?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qué es el efecto retardado?"
          }
        }
      }
    },
    "temporal.help.disclaimer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Poisson process and chi-squared test are established science. The Hawkes application to sleep is an experimental hypothesis. Correlations from your data — not medical advice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El proceso de Poisson y la prueba chi-cuadrado son ciencia establecida. La aplicación de Hawkes al sueño es una hipótesis experimental. Correlaciones de tus datos — no es consejo médico."
          }
        }
      }
    },
    "temporal.help.how.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We compare your nights WITH a specific factor (caffeine, exercise, stress) against nights WITHOUT it. The percentage shows how much more (or less) you wake up. This is measured using regression analysis across all your historical data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparamos tus noches CON un factor específico (cafeína, ejercicio, estrés) contra noches SIN él. El porcentaje muestra cuánto más (o menos) te despiertas. Se mide mediante análisis de regresión sobre todo tu historial de datos."
          }
        }
      }
    },
    "temporal.help.how.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How are the percentages calculated?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cómo se calculan los porcentajes?"
          }
        }
      }
    },
    "temporal.help.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How does it work?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cómo funciona?"
          }
        }
      }
    },
    "temporal.help.what.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We analyze how many times you wake up each night and calculate your personal baseline. Using the Poisson process (Poisson, 1837; Lundberg, 1903) — a mathematical model validated for over a century in fields like physics, telecommunications and insurance — we detect which nights had statistically anomalous awakenings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analizamos cuántas veces te despiertas cada noche y calculamos tu base personal. Usando el proceso de Poisson (Poisson, 1837; Lundberg, 1903) — un modelo matemático validado durante más de un siglo en campos como física, telecomunicaciones y seguros — detectamos qué noches tuvieron despertares estadísticamente anómalos."
          }
        }
      }
    },
    "temporal.help.what.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is temporal impact?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qué es el impacto temporal?"
          }
        }
      }
    },
