        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "延迟区"
          }
        }
      }
    },
    "prc.help.advance.body": {
      "comment": "Body text for a help section in the PRC help sheet that explains how to use the \"advance\" button.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُقدِّم المنبهات في هذه النافذة ساعتك — مما يساعدك على الاستيقاظ والنوم مبكرًا. مفيد لتصحيح مرحلة النوم المتأخرة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els estímuls en aquesta finestra avancen el teu rellotge, ajudant-te a despertar-te i adormir-te abans. Útil per corregir una fase de son retardada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reize in diesem Fenster verschieben deine Uhr früher — sie helfen dir, früher aufzuwachen und einzuschlafen. Nützlich zur Korrektur einer verzögerten Schlafphase."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stimuli in this window shift your clock earlier — helping you wake up and fall asleep sooner. Useful for correcting a delayed sleep phase."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los estímulos en esta ventana adelantan tu reloj, ayudándote a despertar y dormirte antes. Útil para corregir una fase de sueño retrasada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les stimuli dans cette fenêtre avancent votre horloge — vous aidant à vous réveiller et à vous endormir plus tôt. Utile pour corriger une phase de sommeil retardée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この時間帯の刺激は時計を早める方向にシフトさせ、早起き・早寝に役立ちます。遅れた睡眠相の修正に有効です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此窗口内的刺激会使你的时钟提前，帮助你更早醒来和入睡。对纠正睡眠相位延迟有帮助。"
          }
        }
      }
    },
    "prc.help.advance.title": {
      "comment": "Title for a help section in the PRC help sheet that explains how to interpret positive PRC values.",
      "isCommentAutoGenerated": true,
      "localizations": {
