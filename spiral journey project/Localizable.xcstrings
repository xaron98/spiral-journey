    "coach.issue.offTargetForCustomSchedule.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "راجع الجدول المخصص في الإعدادات وحاول الاقتراب من أوقات النوم والاستيقاظ المستهدفة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revisa l'horari personalitzat a la configuració i intenta apropar-te als temps de son i despertar objectius."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überprüfe den Benutzerzeitplan in den Einstellungen und versuche, die Ziel-Schlaf- und Aufwachzeiten einzuhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
