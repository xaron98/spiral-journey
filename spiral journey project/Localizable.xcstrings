    "onboarding.welcome.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُصوِّر هذه الحلزونة نمط نومك عبر الزمن. كل حلقة تمثل يوماً واحداً. كلما سجّلت ليالي أكثر، كلما اتسعت الحلزونة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquesta espiral visualitza el teu patró de son al llarg del temps. Cada anell és un dia. A mesura que registres més nits, l'espiral creix."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Spirale zeigt dein Schlafmuster im Zeitverlauf. Jeder Ring steht für einen Tag. Je mehr Nächte du erfasst, desto größer wird die Spirale."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This spiral visualizes your sleep pattern over time. Each ring is one day. As you log more nights, the spiral grows outward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta espiral visualiza tu patrón de sueño a lo largo del tiempo. Cada anillo representa un día. A medida que registras más noches, la espiral crece."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette spirale visualise ton rythme de sommeil dans le temps. Chaque anneau représente un jour. Plus tu enregistres de nuits, plus la spirale s'agrandit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このスパイラルは、時間の経過とともに睡眠パターンを可視化します。各リングは1日を表します。記録する夜が増えるほどスパイラルが広がります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这个螺旋图展示了你随时间变化的睡眠模式。每一圈代表一天。记录的夜晚越多，螺旋越向外扩展。"
          }
        }
      }
    },
    "onboarding.welcome.title": {
      "localizations": {
        "ar": {
