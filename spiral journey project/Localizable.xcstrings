    "dna.patterns.help.intro" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل نمط يصف ما يجعل مجموعة من أسابيعك تبرز مقارنة بمتوسطك الشخصي. الأسماء تلقائية — يتم اختيار العامل الأكثر انحرافًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada patró descriu què fa que un grup de les teves setmanes destaqui respecte a la teva mitjana habitual. Els noms són automàtics — s'escull el factor que més es desvia."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Muster beschreibt, was eine Gruppe Ihrer Wochen von Ihrem persönlichen Durchschnitt unterscheidet. Namen werden automatisch vergeben — der am stärksten abweichende Faktor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each pattern describes what makes a group of your weeks stand out from your personal average. Names are automatic — they pick the single factor that deviates the most."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada patrón describe qué hace que un grupo de tus semanas destaque frente a tu media habitual. Los nombres se asignan automáticamente — el algoritmo elige el único factor que más se desvía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque motif décrit ce qui distingue un groupe de vos semaines de votre moyenne habituelle. Les noms sont automatiques — le facteur le plus écarté est choisi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各パターンは、あなたの週のグループが個人的な平均からどのように際立っているかを表します。名前は自動で、最も逸脱した要因が選ばれます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个模式描述是什么让您的一组周脱颖而出于您的个人平均水平。名称是自动的——选择偏差最大的单一因素。"
          }
        }
      }
    },
