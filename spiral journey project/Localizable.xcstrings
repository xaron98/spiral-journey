    "rec.addressNegativeTrends.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم رصد اتجاهات سلبية. راجع التغييرات الأخيرة في عاداتك لتفسير هذا الاتجاه."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "S'han observat tendències negatives. Revisa els canvis d'hàbits recents que puguin explicar aquesta tendència."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Negative Trends beobachtet. Überprüfe jüngste Gewohnheitsänderungen, die diesen Trend erklären könnten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Negative trends observed. Review recent habit changes that may explain this trend."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se han observado tendencias negativas. Revisa los cambios de hábitos recientes que puedan explicar esta tendencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendances négatives observées. Examinez les changements d'habitudes récents qui pourraient expliquer cette tendance."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイナスの傾向が観察されました。この傾向を説明する可能性のある最近の習慣の変化を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "观察到负面趋势。请检查最近的习惯变化，这可能解释这一趋势。"
          }
        }
      }
    },
