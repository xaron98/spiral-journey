    "dna.sheet.diag.hint.tooSimilar" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع الأسابيع متشابهة جدًا (المسافات أقل بكثير من العتبة). ربما تكون عاداتك منتظمة جدًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Totes les teves setmanes són molt semblants (distàncies molt per sota del llindar). No hi ha patrons distints — probablement els teus hàbits són molt regulars."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Wochen sind sich sehr ähnlich (Abstände deutlich unter der Schwelle). Keine unterschiedlichen Muster — wahrscheinlich sehr regelmäßige Gewohnheiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All weeks are very similar (distances well below threshold). No distinct patterns to separate — likely very regular habits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas tus semanas son muy parecidas (distancias muy por debajo del umbral). No hay patrones distintos que separar — probablemente tus hábitos son muy regulares."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes vos semaines sont très similaires (distances bien en dessous du seuil). Pas de motifs distincts — habitudes probablement très régulières."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての週が非常に似ています（距離がしきい値よりはるかに低い）。習慣が非常に規則的だと思われます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有周都非常相似（距离远低于阈值）。习惯可能非常规律。"
          }
        }
      }
    },
    "dna.sheet.diag.hint.tooVaried" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأسابيع مختلفة جدًا (جميع المسافات فوق العتبة). لا يوجد نمط متكرر."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les teves setmanes són massa diferents entre si (totes les distàncies superen el llindar). No hi ha patró recurrent — cada setmana és única."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Wochen unterscheiden sich zu stark voneinander (alle Abstände über der Schwelle). Kein wiederkehrendes Muster."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weeks are too different from one another (all distances above threshold). No recurring pattern — each week stands alone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus semanas son demasiado distintas entre sí (todas las distancias superan el umbral). No hay un patrón recurrente — cada semana es única."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les semaines sont trop différentes les unes des autres (toutes les distances dépassent le seuil). Pas de motif récurrent."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "週の差が大きすぎます（すべての距離がしきい値を超える）。繰り返しパターンなし。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "周之间差异太大（所有距离都超过阈值）。无重复模式。"
