    "stats.glossary.r2" : {
      "comment" : "Tooltip text for the \"r2\" term in the stats glossary sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² (معامل التحديد) — جودة ملاءمة نموذج الكوسينور لبيانات نومك. القيم الأقرب إلى 1.0 تشير إلى أن نومك يتبع إيقاعًا قويًا مدته 24 ساعة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² — la bondat d'ajust del model cosinor a les teves dades de son. Els valors més propers a 1,0 indiquen que el teu son segueix un fort ritme de 24 hores."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² — die Anpassungsgüte des Cosinor-Modells an deine Schlafdaten. Werte nahe 1,0 zeigen, dass dein Schlaf einem starken 24-Stunden-Rhythmus folgt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² (R-squared) — the goodness-of-fit of the cosinor model to your sleep data. Values closer to 1.0 indicate that your sleep follows a strong 24-hour rhythm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² (R cuadrado) — la bondad de ajuste del modelo cosinor a tus datos de sueño. Los valores más cercanos a 1,0 indican que tu sueño sigue un fuerte ritmo de 24 horas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R² — la qualité d'ajustement du modèle cosinor à vos données de sommeil. Des valeurs proches de 1,0 indiquent que votre sommeil suit un rythme fort de 24 heures."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R²——コサイナーモデルの睡眠データへの適合度。1.0に近い値ほど、睡眠が強い24時間リズムに従っていることを示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R²——余弦模型对你睡眠数据的拟合优度。值越接近1.0，表明睡眠遵循强烈的24小时节律。"
          }
        }
      }
    },
    "stats.glossary.rhythm" : {
      "comment" : "Definition of a term related to the \"rhythm\" aspect of a user's sleep data.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقدّر نقاط الإيقاع مدى اتباع نمط نومك واستيقاظك لدورة منتظمة مدتها 24 ساعة، بناءً على جودة ملاءمة الكوسينور."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La puntuació de ritme estima com de bé el teu patró de son-vigília segueix un cicle regular de 24 hores, basat en la qualitat de l'ajust del cosinor."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Rhythmuswert schätzt, wie gut dein Schlaf-Wach-Muster einem regelmäßigen 24-Stunden-Zyklus folgt, basierend auf der Cosinor-Anpassungsqualität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rhythm score estimates how well your sleep-wake pattern follows a regular 24-hour cycle, based on the cosinor fit quality."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La puntuación de ritmo estima qué tan bien tu patrón de sueño-vigilia sigue un ciclo regular de 24 horas, basándose en la calidad del ajuste del cosinor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le score de rythme estime dans quelle mesure votre modèle veille-sommeil suit un cycle régulier de 24 heures, basé sur la qualité de l'ajustement cosinor."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リズムスコアは、コサイナー適合の質に基づいて、睡眠-覚醒パターンが規則的な24時間周期にどれだけ従っているかを推定します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "节律评分估计你的睡眠-觉醒模式遵循规律24小时周期的程度，基于余弦拟合质量。"
          }
        }
      }
    },
    "stats.glossary.sleep" : {
      "comment" : "Description of a term related to sleep in the stats glossary sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "متوسط مدة النوم عبر جميع الليالي المسجلة. النطاق الموصى به للبالغين هو 7-9 ساعات في الليلة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durada mitjana del son en totes les nits registrades. El rang recomanat per a adults és de 7 a 9 hores per nit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durchschnittliche Schlafdauer über alle aufgezeichneten Nächte. Der empfohlene Bereich für Erwachsene beträgt 7–9 Stunden pro Nacht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Average sleep duration across all recorded nights. The recommended range for adults is 7–9 hours per night."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duración media del sueño en todas las noches registradas. El rango recomendado para adultos es de 7 a 9 horas por noche."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durée moyenne du sommeil sur toutes les nuits enregistrées. La plage recommandée pour les adultes est de 7 à 9 heures par nuit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記録されたすべての夜の平均睡眠時間。成人の推奨範囲は1晩7〜9時間です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有记录夜晚的平均睡眠时长。成人推荐范围为每晚7–9小时。"
          }
        }
      }
    },
    "stats.glossary.socialJL" : {
      "comment" : "Definition of a term related to social media usage and journal entries.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضطراب النوم الاجتماعي — الفرق بين توقيت نومك في أيام العمل مقابل أيام الراحة. القيم الأكبر تشير إلى تفاوت أكبر بين ساعتك البيولوجية والاجتماعية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jet lag social — la diferència entre el moment del teu son en dies laborables i dies lliures. Valors més alts indiquen un major desajust entre el teu rellotge biològic i social."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sozialer Jetlag — der Unterschied zwischen deinen Schlafzeiten an Arbeitstagen und freien Tagen. Größere Werte zeigen eine stärkere Diskrepanz zwischen biologischer und sozialer Uhr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Social Jetlag — the difference between your sleep timing on work days vs. free days. Larger values indicate a greater mismatch between your biological and social clock."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jet lag social — la diferencia entre el momento de tu sueño en días laborables y días libres. Valores más altos indican un mayor desajuste entre tu reloj biológico y social."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jet lag social — la différence entre votre timing de sommeil les jours de travail et les jours libres. Des valeurs plus élevées indiquent un plus grand décalage entre votre horloge biologique et sociale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ソーシャルジェットラグ——仕事日と自由日の睡眠タイミングの差。値が大きいほど、生物時計と社会時計のずれが大きいことを示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "社交时差——工作日和自由日睡眠时间的差异。值越大，表明生物钟与社会时钟之间的不匹配程度越大。"
          }
        }
      }
    },
    "stats.glossary.sri" : {
      "comment" : "Definition of an item in the stats glossary sheet related to the Social-Rhythm Index (SRI).",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مؤشر انتظام النوم — يقيس مدى ثبات نومك واستيقاظك في الأوقات نفسها. القيمة الأعلى أفضل. مستند إلى Phillips et al. (2017)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Índex de Regularitat del Son — mesura la consistència amb la qual dorms i et despertes a la mateixa hora. Més alt és millor. Basat en Phillips et al. (2017)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schlafregularitätsindex — misst, wie konsistent du zur gleichen Zeit schläfst und aufwachst. Höher ist besser. Basiert auf Phillips et al. (2017)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep Regularity Index — measures how consistently you sleep and wake at the same times. Higher is better. Based on Phillips et al. (2017)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Índice de Regularidad del Sueño — mide la consistencia con la que duermes y te despiertas a la misma hora. Mayor es mejor. Basado en Phillips et al. (2017)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indice de régularité du sommeil — mesure la constance avec laquelle vous dormez et vous réveillez aux mêmes heures. Plus élevé est mieux. Basé sur Phillips et al. (2017)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠規則性指数——同じ時間に睡眠・覚醒する一貫性を測定します。高いほど良い。Phillips et al.（2017）に基づきます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠规律性指数——衡量你在相同时间睡眠和醒来的一致性。越高越好。基于Phillips等（2017）。"
          }
        }
      }
    },
