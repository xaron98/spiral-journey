    "hrv.needMoreData" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقيس Apple Watch تقلب معدل ضربات القلب أثناء النوم. تحتاج إلى 3 ليالٍ على الأقل مع بيانات HRV — ارتدِ ساعتك عند النوم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'Apple Watch mesura el HRV mentre dorms. Calen almenys 3 nits amb dades HRV — porta el rellotge al llit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Apple Watch misst HRV im Schlaf. Du brauchst mindestens 3 Nächte mit HRV-Daten — trag die Uhr nachts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch records HRV while you sleep. You need at least 3 nights with HRV data — wear your watch to bed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El Apple Watch registra HRV mientras duermes. Necesitas al menos 3 noches con datos HRV — duerme con el reloj."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'Apple Watch mesure la VRC pendant le sommeil. Il te faut au moins 3 nuits de données HRV — porte ta montre au lit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watchは睡眠中にHRVを記録します。HRVデータのある夜が少なくとも3晩必要です — 就寝時も装着してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watch 会在睡眠时记录心率变异。需要至少 3 晚带有 HRV 数据 — 睡觉时佩戴手表。"
          }
        }
      }
    },
