      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على القمر لتحديد وقت نومك. اسحب المؤشر إلى وقت الاستيقاظ ثم اضغط على الشمس للحفظ."
