    },
    "rec.increaseSleep.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "متوسطك %.1f ساعة من النوم. استهدف 7-8 ساعات بتحديد وقت نوم ثابت وإيقاف الشاشات قبل ساعة من النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorms una mitjana de %.1f h. Intenta arribar a 7-8h fixant una hora d'anar a dormir i desconnectant pantalles 1h abans."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du schläfst durchschnittlich %.1f h. Ziel sind 7-8h — feste Schlafenszeit und 1h vorher keine Bildschirme."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You average %.1fh of sleep. Aim for 7-8h by setting a fixed bedtime and disconnecting screens 1h before bed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duermes un promedio de %.1f h. Intenta llegar a 7-8h fijando una hora de acostarse y desconectando pantallas 1h antes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous dormez en moyenne %.1f h. Visez 7-8h avec une heure de coucher fixe et pas d'écrans 1h avant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "平均睡眠時間は%.1f時間です。就寝時間を固定し、就寝1時間前にスクリーンをオフにして7〜8時間を目指しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您平均睡眠%.1f小时。请设定固定就寝时间，睡前1小时关闭屏幕，目标7-8小时。"
          }
        }
      }
    },
