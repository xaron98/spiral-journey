    "chronotype.q1": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لو كنت حرًا تمامًا في تخطيط يومك، في أي وقت ستستيقظ؟"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Si poguessis planificar el teu dia lliurement, a quina hora t'aixecaries?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Ihren Tag frei planen könnten, wann würden Sie aufstehen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you were entirely free to plan your day, what time would you get up?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si pudieras planificar tu día libremente, ¿a qué hora te levantarías?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous pouviez planifier votre journée librement, à quelle heure vous lèveriez-vous ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自由に一日を計画できるとしたら、何時に起きますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你可以自由安排一天的时间，你会几点起床？"
          }
        }
      }
    },
