    "coach.insight.good.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ساعتك البيولوجية مستقرة. استمر في عاداتك الحالية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu rellotge circadià és estable. Segueix amb els teus hàbits actuals."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine zirkadiane Uhr ist stabil. Mach weiter so mit deinen aktuellen Gewohnheiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your circadian clock is stable. Keep up your current habits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu reloj circadiano es estable. Sigue con tus hábitos actuales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton horloge circadienne est stable. Continue avec tes habitudes actuelles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの概日時計は安定しています。今の習慣を続けましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的昼夜节律稳定，请继续保持当前习惯。"
          }
        }
      }
    },
    "coach.insight.good.title" : {
