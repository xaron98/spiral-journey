          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠の一部が%@の時間帯と重なっています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分睡眠时间落在您的%@时段内。"
          }
        }
      }
    },
    "coach.issue.sleepOverlapsContext.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النوم يتداخل مع جدولك"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu son es solapa amb el teu horari"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schlaf überlappt deinen Zeitplan"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep overlaps your schedule"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sueño se solapa con tu horario"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sommeil chevauche votre emploi du temps"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠がスケジュールと重なっています"
          }
