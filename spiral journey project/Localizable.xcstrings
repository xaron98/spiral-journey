    "coach.issue.socialJetlag.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاول أن لا يتجاوز اختلاف وقت الاستيقاظ بين عطلة نهاية الأسبوع وأيام العمل 30 دقيقة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta que la diferència d'hora de despertar entre cap de setmana i dies laborables no superi els 30 minuts."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche, den Unterschied zwischen Wochenend- und Werktags-Aufwachzeit auf maximal 30 Minuten zu begrenzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try to keep the difference between weekend and weekday wake times within 30 minutes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta mantener la diferencia entre los horarios de despertar de fin de semana y días laborables dentro de los 30 minutos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de maintenir la différence entre les heures de réveil du week-end et des jours ouvrables en dessous de 30 minutes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "週末と平日の起床時間の差を30分以内に抑えるようにしましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试将周末和工作日起床时间的差距控制在30分钟以内。"
          }
        }
      }
    },
    "coach.issue.socialJetlag.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقليل الفرق سيُحسّن التيقظ في أيام العمل وسيُقلّل الشعور بالتعب المزمن."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduir la diferència millorarà l'estat d'alerta en els dies laborables i reduirà la fatiga crònica."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine geringere Differenz verbessert die Wachheit an Werktagen und verringert chronische Müdigkeit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reducing the gap will improve weekday alertness and reduce chronic fatigue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reducir la brecha mejorará el estado de alerta en días laborables y reducirá la fatiga crónica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réduire l'écart améliorera la vigilance en semaine et réduira la fatigue chronique."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "差を縮めることで、平日の集中力が上がり、慢性疲労が軽減されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "缩小差距将改善工作日的警觉性并减少慢性疲劳。"
          }
        }
      }
    },
    "coach.issue.socialJetlag.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يختلف نومك في عطلة نهاية الأسبوع عن أيام العمل بأكثر من ساعة. هذا مثل تغيير منطقة زمنية كل أسبوع."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu son cap de setmana difereix dels dies laborables en més d'una hora. Això és com canviar de zona horària cada setmana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Wochenendschlaf weicht um mehr als eine Stunde von Werktagen ab. Das ist wie wöchentlicher Zeitzonenwechsel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your weekend sleep differs from weekdays by more than an hour. This is like changing time zones every week."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sueño de fin de semana difiere de los días laborables en más de una hora. Esto es como cambiar de zona horaria cada semana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre sommeil du week-end diffère des jours de semaine de plus d'une heure. C'est comme changer de fuseau horaire chaque semaine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "週末の睡眠が平日と1時間以上異なっています。これは毎週タイムゾーンを変えるようなものです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的周末睡眠与工作日相差超过一小时，就像每周更换时区一样。"
          }
        }
      }
    },
    "coach.issue.socialJetlag.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
