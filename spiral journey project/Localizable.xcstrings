          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolidar tu sueño profundizará el sueño nocturno y fortalecerá las señales del reloj interno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consolider votre sommeil approfondira le sommeil nocturne et renforcera les signaux de l'horloge interne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠を統合することで、夜間睡眠が深まり、体内時計のシグナルが強化されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
