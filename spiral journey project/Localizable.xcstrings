    "chronotype.result.intermediate.desc": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لديك ساعة بيولوجية مرنة. تتكيف جيدًا مع الجداول المختلفة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tens un rellotge intern flexible. T'adaptes bé a diferents horaris."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben eine flexible innere Uhr. Sie passen sich gut an verschiedene Zeitpläne an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have a flexible internal clock. You adapt well to different schedules."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes un reloj interno flexible. Te adaptas bien a diferentes horarios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez une horloge interne flexible. Vous vous adaptez bien à différents horaires."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの体内時計は柔軟です。さまざまなスケジュールにうまく適応できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的生物钟比较灵活。你能很好地适应不同的作息安排。"
          }
        }
      }
    },
    "chronotype.result.moderateEvening": {
