    "about.disclaimer" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا التطبيق أداة تعليمية للملاحظة الذاتية. لا يقدم تشخيصات طبية أو توصيات سريرية. استشر دائمًا أخصائي رعاية صحية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquesta app és una eina educativa d'autoobservació. No proporciona diagnòstics mèdics ni recomanacions clíniques. Consulta sempre un professional de la salut."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App ist ein Bildungswerkzeug zur Selbstbeobachtung. Sie bietet keine medizinischen Diagnosen oder klinischen Empfehlungen. Konsultiere immer einen Arzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is an educational tool for self-observation. It does not provide medical diagnoses or clinical recommendations. Always consult a healthcare professional."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta app es una herramienta educativa de autoobservación. No proporciona diagnósticos médicos ni recomendaciones clínicas. Consulta siempre a un profesional de la salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette application est un outil éducatif d'auto-observation. Elle ne fournit pas de diagnostics médicaux ni de recommandations cliniques. Consultez toujours un professionnel de santé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは自己観察のための教育ツールです。医療診断や臨床的な推奨は提供しません。健康上の懸念がある場合は、必ず医療専門家にご相談ください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本应用是一款用于自我观察的教育工具。它不提供医疗诊断或临床建议。如有健康问题，请咨询医疗专业人士。"
