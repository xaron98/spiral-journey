    "Send message": {
      "comment": "A button label that says \"Send message\".",
      "isCommentAutoGenerated": true
    },
    "settings.about.description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "متتبع الإيقاع البيولوجي مبني على تحليل جيب التمام، ومنحنيات الاستجابة للطور، ونموذج العمليتين لتنظيم النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguidor del ritme circadià basat en l'Anàlisi Cosinor, les Corbes de Resposta de Fase i el Model de Dos Processos de regulació del son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zirkadianer Rhythmustracker basierend auf Cosinor-Analyse, Phasenantwortkurven und dem Zwei-Prozess-Modell der Schlafregulation."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Circadian rhythm tracker based on Cosinor Analysis, Phase Response Curves, and the Two-Process Model of sleep regulation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rastreador de ritmo circadiano basado en Análisis Cosinor, Curvas de Respuesta de Fase y el Modelo de Dos Procesos de regulación del sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivi du rythme circadien basé sur l'analyse Cosinor, les courbes de réponse de phase et le modèle à deux processus de la régulation du sommeil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cosinor分析、位相反応曲線、睡眠調節の2プロセスモデルに基づく概日リズムトラッカー。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "基于Cosinor分析、相位响应曲线和睡眠调节双过程模型的昼夜节律追踪器。"
          }
        }
      }
    },
    "settings.about.philosophy": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صُمِّم Spiral Journey لمساعدتك على فهم إيقاعك بشكل أفضل، لا لتصبح مهووساً به. إذا أدّت التطبيق وظيفتها، ستحتاج إليها أقل وأقل."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey està pensada per ajudar-te a entendre millor el teu ritme, no per obsessionar-te'n. Si l'app compleix la seva funció, hauries de necessitar-la cada vegada menys."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey soll dir helfen, deinen Rhythmus besser zu verstehen – nicht, dich damit zu besessen. Wenn die App ihren Zweck erfüllt, solltest du sie immer weniger brauchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey is designed to help you understand your rhythm better, not to obsess over it. If the app does its job, you should need it less and less."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey está pensada para ayudarte a entender mejor tu ritmo, no para obsesionarte con él. Si la app cumple su función, deberías necesitarla cada vez menos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey est conçue pour t'aider à mieux comprendre ton rythme, pas pour en devenir obsédé. Si l'app remplit son rôle, tu en auras de moins en moins besoin."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journeyはあなたのリズムをよりよく理解するためのものであり、それに執着するためのものではありません。アプリが機能を果たせば、使う頻度はどんどん減るはずです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiral Journey 旨在帮助你更好地了解自己的节律，而不是让你为此着迷。如果这款应用发挥了作用，你应该越来越少地需要它。"
          }
        }
      }
    },
