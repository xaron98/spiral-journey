    "settings.aiCoach.privacy" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل المعالجة تتم على الجهاز. بيانات نومك لا تغادر هاتفك أبدًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tot el processament és local. Les teves dades de son mai surten del telèfon."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die gesamte Verarbeitung erfolgt auf dem Gerät. Deine Schlafdaten verlassen nie dein Telefon."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All processing is on-device. Your sleep data never leaves your phone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo el procesamiento es local. Tus datos de sueño nunca salen de tu teléfono."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout le traitement se fait sur l'appareil. Tes données de sommeil ne quittent jamais ton téléphone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての処理はデバイス上で行われます。睡眠データがスマホの外に出ることはありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有处理均在设备上完成。你的睡眠数据绝不会离开手机。"
          }
        }
      }
    },
