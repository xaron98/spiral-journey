    "chronotype.result.moderateEvening.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تميل نحو المساء. تصل إلى أفضل أدائك في وقت لاحق من اليوم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tendeixes cap a les nits. Sols assolir el teu millor ritme més tard."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie tendieren zum Abend. Sie kommen erst später am Tag richtig in Schwung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You lean toward evenings. You tend to hit your stride later in the day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiendes hacia las noches. Sueles alcanzar tu mejor ritmo más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous penchez vers les soirées. Vous atteignez votre plein potentiel plus tard dans la journée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "夜型寄りです。一日の後半に調子が上がる傾向があります。"
