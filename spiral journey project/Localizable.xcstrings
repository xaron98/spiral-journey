    "rec.improveDuration.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بـ %.1f ساعة أنت قريب من المثالي. حاول الذهاب إلى النوم مبكراً 30 دقيقة للوصول إلى 7 ساعات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amb %.1f h estàs a prop de l'òptim. Prova d'anar a dormir 30 min abans per arribar a les 7h."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit %.1f h bist du nah am Optimum. Versuche 30 Min früher ins Bett zu gehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At %.1fh you're close to optimal. Try going to bed 30 min earlier to reach 7h."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con %.1f h estás cerca de lo óptimo. Intenta acostarte 30 min antes para llegar a las 7h."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À %.1f h vous êtes proche de l'optimal. Essayez de vous coucher 30 min plus tôt."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%.1f時間は最適に近いです。30分早く就寝して7時間を目指しましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%.1f小时已接近最佳。尝试提前30分钟就寝达到7小时。"
          }
        }
      }
    },
