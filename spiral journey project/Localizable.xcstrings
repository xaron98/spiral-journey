          }
        }
      }
    },
    "pdf.disorder.desc.aswpd": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ذروة إيقاعية مبكرة مع نمط مستقر. الساعة البيولوجية متقدمة مقارنة بالجدول التقليدي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase circadiana primerenca amb patró estable. El rellotge biològic està avançat respecte l'horari convencional."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Frühe zirkadiane Akrophase mit stabilem Muster. Die biologische Uhr ist vorverlagert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Early circadian acrophase with stable pattern. The biological clock is advanced relative to the conventional schedule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase circadiana temprana con patrón estable. El reloj biológico está adelantado respecto al horario convencional."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrophase circadienne précoce avec profil stable. L'horloge biologique est en avance par rapport à l'horaire conventionnel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安定したパターンで概日アクロフェーズが前進。生体時計が通常のスケジュールより進んでいます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "昼夜节律峰值时相偏早，模式稳定。生物钟相对于常规时间表提前。"
          }
        }
      }
    },
    "pdf.disorder.desc.dswpd": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ذروة إيقاعية متأخرة مع نمط مستقر. الساعة البيولوجية متأخرة مقارنة بالجدول التقليدي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase circadiana tardana amb patró estable. El rellotge biològic està retardat respecte l'horari convencional."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Späte zirkadiane Akrophase mit stabilem Muster. Die biologische Uhr ist verzögert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Late circadian acrophase with stable pattern. The biological clock is delayed relative to the conventional schedule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase circadiana tardía con patrón estable. El reloj biológico está retrasado respecto al horario convencional."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrophase circadienne tardive avec profil stable. L'horloge biologique est en retard par rapport à l'horaire conventionnel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安定したパターンで概日アクロフェーズが遅延。生体時計が通常のスケジュールより遅れています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "昼夜节律峰值时相偏晚，模式稳定。生物钟相对于常规时间表延迟。"
          }
        }
      }
    },
    "pdf.disorder.desc.iswrd": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تباين كبير في مواعيد النوم وإيقاع يومي ضعيف. النمط يفتقر إلى بنية واضحة من 24 ساعة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Alta variabilitat en l'horari de son i ritme circadiari feble. El patró manca d'estructura clara de 24 hores."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hohe Variabilität der Schlafzeiten und schwacher zirkadianer Rhythmus. Keine klare 24-Stunden-Struktur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High variability in sleep timing and weak circadian rhythm. The pattern lacks a clear 24-hour structure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alta variabilidad en el horario de sueño y ritmo circadiano débil. El patrón carece de estructura clara de 24 horas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Forte variabilité des horaires de sommeil et rythme circadien faible. Le profil manque d'une structure de 24 heures."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間の高い変動性と弱い概日リズム。明確な24時間構造が欠如しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠时间高度不规律，昼夜节律微弱。缺乏明确的24小时结构。"
          }
        }
      }
    },
    "pdf.disorder.desc.n24swd": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انحراف تدريجي في دورة النوم-الاستيقاظ. الإيقاع اليومي ينحرف عن 24 ساعة مسبباً تحولاً يومياً."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Deriva progressiva del cicle son-vigília. El període circadiari es desvia de les 24 hores, causant un desplaçament diari."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fortschreitende Drift des Schlaf-Wach-Zyklus. Die zirkadiane Periode weicht von 24 Stunden ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progressive drift of the sleep-wake cycle. The circadian period deviates from 24 hours, causing a daily shift."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deriva progresiva del ciclo sueño-vigilia. El período circadiano se desvía de las 24 horas, causando un desplazamiento diario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dérive progressive du cycle sommeil-éveil. La période circadienne s'écarte de 24 heures, provoquant un décalage quotidien."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠覚醒サイクルの進行性ドリフト。概日周期が24時間から逸脱し、毎日のシフトが生じています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠-觉醒周期进行性漂移。昼夜节律周期偏离24小时，导致每日时移。"
          }
        }
      }
    },
    "pdf.disorder.desc.normal": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إيقاع يومي مستقر مع مواعيد نوم-استيقاظ منتظمة. متسق مع ساعة بيولوجية سليمة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritme circadiari estable amb horari de son-vigília regular. Consistent amb un rellotge biològic saludable."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stabiler zirkadianer Rhythmus mit regelmäßigen Schlaf-Wach-Zeiten. Vereinbar mit einer gesunden biologischen Uhr."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable circadian rhythm with regular sleep-wake timing. Consistent with a healthy biological clock."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritmo circadiano estable con horario de sueño-vigilia regular. Consistente con un reloj biológico saludable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rythme circadien stable avec des horaires de sommeil-éveil réguliers. Cohérent avec une horloge biologique saine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規則的な睡眠覚醒時間を伴う安定した概日リズム。健康な生体時計に一致するパターンです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稳定的昼夜节律，睡眠-觉醒时间规律。与健康的生物钟一致。"
          }
        }
      }
    },
