    },
    "coach.issue.sleepOverlapsContext.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مواءمة النوم مع التزاماتك يحسن جودة الراحة والأداء النهاري."
          }
        },
        "ca": {
          "stringUnit": {
