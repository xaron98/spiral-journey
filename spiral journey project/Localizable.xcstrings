    "dna.help.what.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمثيل لنمط نومك كتسلسل جيني: كل ليلة قاعدة، وكل أسبوع لفة من اللولب."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una representació del teu patró de son com una seqüència genètica: cada nit és una base, cada setmana una volta d'hèlix."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Darstellung deines Schlafmusters als genetische Sequenz: Jede Nacht ist eine Base, jede Woche eine Helix-Windung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A representation of your sleep pattern as a genetic sequence: each night is a base, each week a helix turn."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una representación de tu patrón de sueño como una secuencia genética: cada noche es una base, cada semana una vuelta de hélice."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une représentation de ton schéma de sommeil comme une séquence génétique : chaque nuit est une base, chaque semaine un tour d'hélice."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠パターンを遺伝配列として表現。各夜は塩基、各週はらせんの一回転。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将睡眠模式表示为遗传序列：每晚是一个碱基，每周是一圈螺旋。"
          }
        }
      }
    },
    "dna.help.what.title" : {
