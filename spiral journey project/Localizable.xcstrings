    "settings.prediction.privacyNote" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تدريب ML بالكامل على الجهاز. بيانات نومك لا تغادر هاتفك أبداً."
          }
        },
        "ca" : {
          "stringUnit" : {
