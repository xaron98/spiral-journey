    "coach.issue.offTargetForShift.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضبط وقت نومك ليتوافق مع النافذة المستهدفة لوردية عملك، واستخدم قناعاً للعين وستائر معتمة لنوم نهاري جيد."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta l'hora de dormir per alinear-te amb la finestra objectiu del teu torn; usa antifaç i cortines opaques per a un bon son diürn."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe deine Schlafzeit an das Zielfenster deiner Schicht an; nutze Schlafmaske und Verdunkelungsvorhänge für guten Tagesschlaf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust your sleep time to align with your shift target window; use an eye mask and blackout curtains for good daytime sleep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta tu hora de sueño para alinearte con la ventana objetivo de tu turno; usa antifaz y cortinas opacas para un buen sueño diurno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez votre heure de sommeil pour vous aligner sur la fenêtre cible de votre quart; utilisez un masque pour les yeux et des rideaux occultants pour un bon sommeil diurne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シフトの目標窓に合わせて睡眠時間を調整し、良質な昼間の睡眠のためにアイマスクと遮光カーテンを使用しましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整睡眠时间以与班次目标窗口对齐；使用眼罩和遮光窗帘以获得良好的白天睡眠。"
          }
        }
      }
    },
