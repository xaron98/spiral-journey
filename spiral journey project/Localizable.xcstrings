    "rec.reviewStimulants.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للكافيين عمر نصف 5-7 ساعات. تجنّب القهوة بعد الساعة 14:00 يمكن أن يحسّن وقت النوم وعمقه."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La cafeïna té una semivida de 5-7 h. Evitar el cafè després de les 14:00 pot millorar la latència i la profunditat del son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Koffein hat eine Halbwertszeit von 5-7 h. Kaffee nach 14:00 Uhr zu meiden kann die Einschlaflatenz und Schlaftiefe verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Caffeine has a half-life of 5-7 h. Avoiding coffee after 14:00 can improve sleep latency and depth."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cafeína tiene una vida media de 5-7 h. Evitar el café después de las 14:00 puede mejorar la latencia y la profundidad del sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La caféine a une demi-vie de 5-7 h. Éviter le café après 14h peut améliorer la latence et la profondeur du sommeil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カフェインの半減期は5〜7時間です。14:00以降のコーヒーを避けることで睡眠潜時と深度が改善できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "咖啡因的半衰期为5-7小时。14:00后避免喝咖啡可以改善睡眠潜伏期和睡眠深度。"
          }
        }
      }
    },
    "rec.reviewStimulants.title": {
