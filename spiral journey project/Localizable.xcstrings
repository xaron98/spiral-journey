    "Zero" : {
      "comment" : "Label for the zero mark on the circadian phase drift chart.",
      "isCommentAutoGenerated" : true
    },
    "prc.help.sheet.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "Cómo leer este gráfico" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Com llegir aquest gràfic" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Diagramm verstehen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How to read this chart" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cómo leer este gráfico" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Comment lire ce graphique" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "グラフの読み方" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如何读取此图表" } }
      }
    },
    "prc.help.what.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "ما هو منحنى الاستجابة للطور؟" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Què és la Corba de Resposta de Fase?" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Was ist die Phasenantwortkurve?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What is the Phase Response Curve?" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Qué es la Curva de Respuesta de Fase?" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Qu'est-ce que la courbe de réponse de phase ?" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "位相反応曲線とは？" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "什么是相位反应曲线？" } }
      }
    },
    "prc.help.what.body" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يُظهر كيف يؤثر منبّه معين (ضوء، كافيين، تمرين…) على ساعتك الداخلية بحسب وقت تطبيقه. نفس القهوة في الساعة 8 صباحاً وفي الساعة 10 مساءً لها تأثيرات مختلفة تماماً على دورة نومك." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Mostra com un estímul (llum, cafeïna, exercici…) afecta el teu rellotge intern segons l'hora del dia en què l'apliquis. El mateix cafè a les 8h del matí i a les 22h té efectes completament diferents sobre el teu cicle de son." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeigt, wie ein Reiz (Licht, Koffein, Sport…) je nach Tageszeit deine innere Uhr beeinflusst. Derselbe Kaffee um 8 Uhr morgens und um 22 Uhr hat völlig unterschiedliche Auswirkungen auf deinen Schlaf-Wach-Zyklus." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Shows how a stimulus (light, caffeine, exercise…) affects your internal clock depending on the time of day you apply it. The same coffee at 8am and 10pm has completely different effects on your sleep cycle." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Muestra cómo un estímulo (luz, cafeína, ejercicio…) afecta a tu reloj interno según la hora del día en que lo apliques. El mismo café a las 8h de la mañana y a las 22h tiene efectos completamente distintos sobre tu ciclo de sueño." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Montre comment un stimulus (lumière, caféine, exercice…) affecte votre horloge interne selon l'heure à laquelle vous l'appliquez. Le même café à 8h du matin et à 22h a des effets complètement différents sur votre cycle de sommeil." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "光、カフェイン、運動などの刺激が、適用する時間帯によって体内時計にどう影響するかを示します。朝8時と夜10時の同じコーヒーは、睡眠サイクルに全く異なる影響を与えます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "显示刺激（光线、咖啡因、运动…）根据一天中施加的时间如何影响你的体内时钟。早上8点和晚上10点喝同样的咖啡对睡眠周期有完全不同的影响。" } }
      }
    },
    "prc.help.advance.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "المنحنى للأعلى ← يُقدِّم الساعة" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Corba cap amunt → avança el rellotge" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kurve nach oben → Uhr vorverschieben" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Curve up → advances the clock" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Curva hacia arriba → adelanta el reloj" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Courbe vers le haut → avance l'horloge" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "曲線上向き → 時計を前進させる" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "曲线向上 → 提前时钟" } }
      }
    },
    "prc.help.advance.body" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "عندما يرتفع المنحنى فوق الصفر، يساعدك هذا المنبّه في ذلك الوقت على النوم مبكراً. مثال: الضوء الساطع في الصباح الباكر يُقدِّم ساعتك ويجعلك تشعر بالنعاس أبكر في الليل." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Quan la corba puja per sobre de zero, aquell estímul en aquell horari t'ajuda a dormir més d'hora. Exemple: llum brillant a primera hora del matí avança el teu rellotge i fa que tinguis son abans de nit." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn die Kurve über null steigt, hilft dir dieser Reiz zu diesem Zeitpunkt, früher einzuschlafen. Beispiel: Helles Licht am frühen Morgen verschiebt deine innere Uhr vor und lässt dich abends früher müde werden." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "When the curve rises above zero, that stimulus at that time helps you sleep earlier. Example: bright light early in the morning advances your clock and makes you feel sleepy earlier at night." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando la curva sube por encima de cero, ese estímulo en ese horario te ayuda a dormir más temprano. Ejemplo: luz brillante a primera hora de la mañana adelanta tu reloj y hace que tengas sueño antes por la noche." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quand la courbe monte au-dessus de zéro, ce stimulus à cette heure vous aide à dormir plus tôt. Exemple : une lumière vive tôt le matin avance votre horloge et vous donne envie de dormir plus tôt le soir." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "曲線がゼロより上に上がると、その時間帯のその刺激が早く眠るのを助けます。例：早朝の明るい光は時計を前進させ、夜に早く眠気を感じさせます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当曲线升至零以上时，该时间段的该刺激有助于你更早入睡。例如：清晨的明亮光线会提前你的时钟，让你在晚上更早感到困倦。" } }
      }
    },
    "prc.help.delay.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "المنحنى للأسفل ← يُؤخِّر الساعة" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Corba cap avall → endarrereix el rellotge" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kurve nach unten → Uhr verzögern" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Curve down → delays the clock" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Curva hacia abajo → retrasa el reloj" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Courbe vers le bas → retarde l'horloge" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "曲線下向き → 時計を遅らせる" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "曲线向下 → 延迟时钟" } }
      }
    },
    "prc.help.delay.body" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "عندما ينخفض المنحنى تحت الصفر، يدفع هذا المنبّه ساعتك إلى وقت متأخر: يصعب عليك النوم وتستيقظ متأخراً في اليوم التالي. ضوء الشاشة ليلاً هو الحالة الأكثر شيوعاً والأكثر ضرراً." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Quan la corba baixa per sota de zero, aquell estímul empeny el teu rellotge cap a més tard: et costa més adormir-te i et despertes més tard l'endemà. La llum de pantalla de nit és el cas més comú i més perjudicial." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn die Kurve unter null fällt, verschiebt dieser Reiz deine innere Uhr nach hinten: Du schläfst schwerer ein und wachst am nächsten Tag später auf. Bildschirmlicht am Abend ist der häufigste und schädlichste Fall." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "When the curve drops below zero, that stimulus pushes your clock later: you find it harder to fall asleep and wake up later the next day. Screen light at night is the most common and most damaging case." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando la curva baja por debajo de cero, ese estímulo empuja tu reloj hacia más tarde: te cuesta más dormirte y te despiertas más tarde al día siguiente. La luz de pantalla por la noche es el caso más común y el más perjudicial." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quand la courbe descend en dessous de zéro, ce stimulus pousse votre horloge vers plus tard : vous avez du mal à vous endormir et vous réveillez plus tard le lendemain. La lumière des écrans la nuit est le cas le plus courant et le plus néfaste." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "曲線がゼロより下に下がると、その刺激が時計を遅らせます：眠りにくくなり、翌日遅く目覚めます。夜のスクリーン光は最も一般的で最も有害なケースです。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当曲线降至零以下时，该刺激会推迟你的时钟：你更难入睡，第二天醒得更晚。夜晚的屏幕光是最常见也是最有害的情况。" } }
      }
    },
    "prc.help.dead.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "قريب من الصفر ← المنطقة المحايدة" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Prop de zero → zona neutra" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Nahe null → neutrale Zone" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Near zero → neutral zone" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cerca de cero → zona neutra" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Près de zéro → zone neutre" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ゼロ付近 → 中立ゾーン" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "接近零 → 中性区域" } }
      }
    },
    "prc.help.dead.body" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "في المنطقة المسطحة، لا يكاد المنبّه يؤثر على ساعتك بغض النظر عن الكمية المستخدمة. بالنسبة للضوء، يكون هذا عادةً في منتصف فترة ما بعد الظهر." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "A la zona plana, l'estímul té poc o cap efecte sobre el teu rellotge, independentment de la quantitat que en facis servir. Per a la llum, sol ser a mitja tarda." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "In der flachen Zone hat der Reiz kaum oder keinen Einfluss auf deine innere Uhr, egal wie viel du verwendest. Bei Licht ist das meist am frühen Nachmittag." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "In the flat zone, the stimulus has little or no effect on your clock, regardless of how much you use. For light, this is typically mid-afternoon." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "En la zona plana, el estímulo tiene poco o ningún efecto sobre tu reloj, independientemente de la cantidad que uses. Para la luz, suele ser a mediados de la tarde." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dans la zone plate, le stimulus a peu ou pas d'effet sur votre horloge, quelle que soit la quantité utilisée. Pour la lumière, c'est généralement en milieu d'après-midi." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "平坦なゾーンでは、どれだけ使っても刺激は体内時計にほとんど影響しません。光の場合、これは通常午後中頃です。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在平坦区域，无论使用多少，该刺激对你的时钟几乎没有影响。对于光线，这通常是下午中段。" } }
      }
    },
    "prc.help.use.title" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "كيف تستخدمه عملياً" } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Com usar-lo a la pràctica" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Praktische Anwendung" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How to use it in practice" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cómo usarlo en la práctica" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Comment l'utiliser en pratique" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "実際の使い方" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如何在实践中使用" } }
      }
    },
    "prc.help.use.body" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "إذا أردت النوم مبكراً: ابحث عن ضوء ساطع في الصباح (المنطقة الخضراء) وتجنب الشاشات ليلاً (المنطقة الحمراء). إذا أردت النوم متأخراً: افعل العكس. سجّل أحداثك في اللولب لترى في أي منطقة من المنحنى تقع." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Si vols dormir abans: busca llum brillant al matí (zona verda) i evita pantalles de nit (zona vermella). Si vols dormir més tard: fes el contrari. Registra els teus events a l'espiral per veure exactament en quina zona de la corba cauen." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn du früher schlafen möchtest: Suche morgens helles Licht (grüne Zone) und vermeide abends Bildschirme (rote Zone). Wenn du später schlafen möchtest: mache das Gegenteil. Erfasse deine Ereignisse in der Spirale, um genau zu sehen, in welche Zone der Kurve sie fallen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you want to sleep earlier: seek bright light in the morning (green zone) and avoid screens at night (red zone). If you want to sleep later: do the opposite. Log your events on the spiral to see exactly which zone of the curve they fall in." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Si quieres dormir antes: busca luz brillante por la mañana (zona verde) y evita pantallas por la noche (zona roja). Si quieres dormir más tarde: haz lo contrario. Registra tus eventos en la espiral para ver exactamente en qué zona de la curva caen." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Si vous voulez dormir plus tôt : cherchez une lumière vive le matin (zone verte) et évitez les écrans la nuit (zone rouge). Si vous voulez dormir plus tard : faites le contraire. Enregistrez vos événements sur la spirale pour voir exactement dans quelle zone de la courbe ils tombent." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "早く眠りたい場合：朝に明るい光を浴びて（緑ゾーン）、夜はスクリーンを避けてください（赤ゾーン）。遅く眠りたい場合は逆にしてください。スパイラルにイベントを記録して、曲線のどのゾーンに当たるか確認しましょう。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果想早点睡：早上寻找明亮光线（绿色区域），晚上避免屏幕（红色区域）。如果想晚点睡：做相反的事。在螺旋上记录你的事件，看看它们落在曲线的哪个区域。" } }
      }
    },
    "prc.reference.label" : {
