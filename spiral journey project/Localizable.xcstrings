    "dna.sheet.diag.hint.borderline" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البيانات على الحدود — تم التجميع لكن لم يتجاوز أي عنقود عضوًا واحدًا. المزيد من البيانات سيكشف عن الأنماط."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les dades estan al límit — hi va haver clustering però cap clúster va passar d'un membre. Amb més dades haurien d'aparèixer patrons."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daten am Rand — Clustering erfolgte, aber kein Cluster wuchs über ein einzelnes Mitglied hinaus. Mehr Daten sollten Muster aufzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data is borderline — clustering happened but no cluster grew past a single member. More data should reveal patterns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los datos están en el límite — hubo clustering pero ningún cluster llegó a 2 miembros. Con más datos deberían aparecer patrones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Données limites — clustering effectué mais aucun cluster n'a dépassé un seul membre. Plus de données devraient révéler des motifs."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データは境界線上 — クラスタリングは行われたが、どのクラスタも単一メンバーを超えませんでした。さらにデータがあればパターンが現れるはずです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据处于边缘 — 进行了聚类，但没有聚类超过单个成员。更多数据应该会显示模式。"
          }
        }
      }
    },
    "dna.sheet.diag.hint.fewSequences" : {
      "localizations" : {
        "ar" : {
