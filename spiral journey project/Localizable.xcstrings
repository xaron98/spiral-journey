          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相位正在移动"
          }
        }
      }
    },
    "coach.insight.short.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنام أقل من 7 ساعات الموصى بها. الحرمان المتراكم من النوم يؤثر على الإدراك والصحة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorms per sota de les 7h recomanades. La privació de son acumulada afecta la cognició i la salut."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du schläfst weniger als die empfohlenen 7h. Kumulativer Schlafmangel beeinträchtigt Kognition und Gesundheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're sleeping below the recommended 7h. Cumulative sleep deprivation affects cognition and health."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duermes por debajo de las 7h recomendadas. La privación acumulada afecta la cognición y la salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu dors moins que les 7h recommandées. La privation cumulée affecte la cognition et la santé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推奨の7時間を下回っています。睡眠不足の蓄積は認知機能と健康に影響します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠时间低于建议的7小时，累积睡眠不足会影响认知和健康。"
          }
        }
      }
    },
    "coach.insight.short.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدة نوم غير كافية"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Durada de son insuficient"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schlafdauer zu kurz"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insufficient sleep duration"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duración de sueño insuficiente"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée de sommeil insuffisante"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間が不十分です"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠时长不足"
          }
        }
      }
    },
    "coach.issue.advancedPhase.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعرض للضوء الساطع في المساء (18:00-20:00) وأخّر وقت النوم تدريجياً بـ 15 دقيقة كل أسبوع."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Exposa't a llum intensa al vespre (18:00-20:00) i retarda gradualment l'hora d'anar a dormir 15 minuts per setmana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Setze dich abends (18:00–20:00) hellem Licht aus und verschiebe die Schlafenszeit schrittweise um 15 Minuten pro Woche nach hinten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get bright light exposure in the evening (18:00–20:00) and gradually delay bedtime by 15 minutes per week."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exponte a luz brillante por la tarde (18:00-20:00) y retrasa gradualmente la hora de dormir 15 minutos por semana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exposez-vous à une lumière vive le soir (18:00–20:00) et retardez progressivement le coucher de 15 minutes par semaine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "夕方（18:00～20:00）に明るい光を浴び、毎週15分ずつ就寝時間を遅らせていきましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "傍晚（18:00–20:00）接受强光照射，并每周逐渐将就寝时间推迟15分钟。"
          }
        }
      }
    },
    "coach.issue.advancedPhase.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتأخر ساعتك البيولوجية وستصبح أوقات الاستيقاظ المبكرة أقل تكراراً."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu rellotge intern es retardarà i els despertars molt prematurs seran menys freqüents."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine innere Uhr wird sich verzögern und sehr frühe Aufwachzeiten werden seltener."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your internal clock will shift later and very early wake-ups will become less frequent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu reloj interno se retrasará y los despertares muy tempranos serán menos frecuentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre horloge interne se décalera et les réveils très matinaux deviendront moins fréquents."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "体内時計が後ろにずれ、非常に早い目覚めが減少します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的生物钟将后移，过早醒来的情况会减少。"
          }
        }
      }
    },
    "coach.issue.advancedPhase.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت نومك أبكر بكثير مما هو مثالي، وقد تستيقظ مبكراً جداً بشكل لا إرادي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu temps de son és significativament més aviat del que és òptim, i et podries despertar molt d'hora de manera involuntària."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schlafzeit liegt deutlich früher als optimal, und du wachst möglicherweise ungewollt sehr früh auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep timing is significantly earlier than optimal, and you may be waking very early involuntarily."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu horario de sueño es significativamente más temprano de lo óptimo, y podrías despertar muy temprano de forma involuntaria."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre horaire de sommeil est bien plus tôt qu'optimal, et vous pourriez vous réveiller très tôt involontairement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間が最適より大幅に早く、意図せず非常に早く目覚めている可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠时间比最佳时间早得多，可能会不自觉地很早醒来。"
          }
        }
      }
    },
    "coach.issue.advancedPhase.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طور النوم المبكر"
          }
        },
        "ca": {
