    "periodogram.insight.hr.menstrual" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "معدل نبض قلبك أثناء الراحة له دورة مدتها حوالي 28 يومًا — وهذا يتوافق مع التغيرات الهرمونية عبر الدورة الشهرية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La teva freqüència cardíaca en repòs té un cicle de ~28 dies — consistent amb els canvis hormonals del cicle menstrual."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Ruheherzfrequenz hat einen ~28-Tage-Zyklus — passend zu hormonellen Veränderungen im Menstruationszyklus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your resting heart rate has a ~28-day cycle — this is consistent with hormonal changes across the menstrual cycle."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu frecuencia cardíaca en reposo tiene un ciclo de ~28 días — consistente con los cambios hormonales del ciclo menstrual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre fréquence cardiaque au repos a un cycle de ~28 jours — cohérent avec les changements hormonaux du cycle menstruel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安静時心拍数に約28日の周期があります——月経周期のホルモン変化と一致しています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的静息心率有约28天的周期——这与月经周期的激素变化一致。"
          }
        }
      }
    },
    "periodogram.insight.hr.weekly" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "معدل نبض قلبك أثناء الراحة يتبع نمطًا أسبوعيًا — جسمك يراكم التوتر خلال الأسبوع ويتعافى في عطلة نهاية الأسبوع."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La teva freqüència cardíaca en repòs segueix un patró setmanal — el teu cos acumula estrès entre setmana i es recupera els caps de setmana."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Ruheherzfrequenz folgt einem Wochenmuster — dein Körper sammelt unter der Woche Stress an und erholt sich am Wochenende."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your resting heart rate follows a weekly pattern — your body accumulates stress during the week and recovers on weekends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu frecuencia cardíaca en reposo sigue un patrón semanal — tu cuerpo acumula estrés entre semana y se recupera los fines de semana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre fréquence cardiaque au repos suit un schéma hebdomadaire — votre corps accumule du stress en semaine et récupère le week-end."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安静時心拍数は週間パターンに従っています——平日にストレスが蓄積し、週末に回復します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
