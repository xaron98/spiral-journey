    "chronotype.q3": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ما مدى يقظتك خلال أول نصف ساعة بعد الاستيقاظ؟"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Com d'alerta et sents durant la primera mitja hora després de despertar-te?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie wach fühlen Sie sich in der ersten halben Stunde nach dem Aufwachen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How alert do you feel during the first half hour after waking up?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo de alerta te sientes durante la primera media hora después de despertar?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À quel point vous sentez-vous alerte pendant la première demi-heure après le réveil ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "起床後の最初の30分間、どの程度目が覚めていますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "醒来后的前半小时，你感觉有多清醒？"
          }
        }
      }
    },
