            "value": "Delayed Sleep Phase"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fase del sueño retrasada"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Phase de sommeil retardée"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠位相の遅れ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠时相延迟"
          }
        }
      }
    },
    "coach.issue.fragmentedSleep.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تجنب الكافيين بعد الساعة 14:00، وقلّل من الكحول، واجعل غرفة النوم باردة ومظلمة وهادئة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita la cafeïna després de les 14:00, redueix l'alcohol i mantén la habitació fresca, fosca i silenciosa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vermeide Koffein nach 14:00 Uhr, reduziere Alkohol und halte das Schlafzimmer kühl, dunkel und ruhig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Avoid caffeine after 14:00, reduce alcohol, and keep your bedroom cool, dark, and quiet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita la cafeína después de las 14:00, reduce el alcohol y mantén el dormitorio fresco, oscuro y silencioso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Évitez la caféine après 14:00, réduisez l'alcool et gardez la chambre fraîche, sombre et calme."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "14:00以降のカフェインを避け、アルコールを減らし、寝室を涼しく暗く静かに保ちましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "14:00后避免咖啡因，减少饮酒，保持卧室凉爽、黑暗和安静。"
          }
        }
      }
    },
    "coach.issue.fragmentedSleep.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحسين البيئة سيُقلّل الاستيقاظ الليلي ويزيد نسبة النوم العميق."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Millorar l'ambient reduirà els despertars nocturns i augmentarà la proporció de son profund."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine bessere Schlafumgebung wird nächtliche Aufwachzeiten reduzieren und den Tiefschlafanteil erhöhen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Improving the environment will reduce night waking and increase the proportion of deep sleep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejorar el ambiente reducirá los despertares nocturnos y aumentará la proporción de sueño profundo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorer l'environnement réduira les réveils nocturnes et augmentera la proportion de sommeil profond."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "環境を改善することで夜間覚醒が減り、深い睡眠の割合が増加します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "改善睡眠环境将减少夜间觉醒，增加深度睡眠比例。"
          }
        }
      }
    },
    "coach.issue.fragmentedSleep.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحتوي لياليك على انتقالات متعددة بين النوم واليقظة. هذا يُقلّل من كمية نوم الموجة البطيئة ونوم حركة العين السريعة التي تحصل عليها."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les teves nits contenen múltiples transicions son-vigília. Això redueix la quantitat de son d'ones lentes i son REM que obtens."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Nächte enthalten mehrere Schlaf-Wach-Übergänge. Das reduziert die Menge an Tiefschlaf und REM-Schlaf, die du bekommst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your nights contain multiple sleep-wake transitions. This reduces the amount of slow-wave and REM sleep you get."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus noches contienen múltiples transiciones sueño-vigilia. Esto reduce la cantidad de sueño de ondas lentas y sueño REM que obtienes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos nuits contiennent de multiples transitions sommeil-éveil. Cela réduit la quantité de sommeil à ondes lentes et de sommeil paradoxal que vous obtenez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "夜間に睡眠と覚醒の切り替えが複数回起きています。これにより、徐波睡眠とレム睡眠の量が減少します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的夜晚包含多次睡眠-清醒切换，减少了慢波睡眠和快速眼动睡眠的量。"
          }
        }
      }
    },
    "coach.issue.fragmentedSleep.title": {
      "extractionState": "stale",
      "localizations": {
