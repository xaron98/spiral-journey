    "prc.help.delay.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُؤخِّر المنبهات هنا ساعتك — مما يجعلك ترغب في البقاء مستيقظًا والاستيقاظ متأخرًا. التعرض للضوء مساءً سبب شائع لتأخر النوم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els estímuls aquí retarden el teu rellotge, fent que vulguis quedar-te despert i despertar-te més tard. L'exposició a la llum al vespre és una causa habitual del retard del son."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reize hier verzögern deine Uhr — du möchtest später schlafen gehen und später aufwachen. Abendliche Lichtexposition ist eine häufige Ursache für verzögerten Schlaf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stimuli here push your clock later — making you want to stay up and wake up later. Evening light exposure is a common cause of delayed sleep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los estímulos aquí retrasan tu reloj, haciendo que quieras quedarte despierto y despertar más tarde. La exposición a la luz por la noche es una causa común del retraso del sueño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les stimuli ici retardent votre horloge — vous donnant envie de veiller et de vous réveiller plus tard. L'exposition à la lumière le soir est une cause fréquente de retard du sommeil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この時間帯の刺激は時計を遅らせ、夜更かしや遅起きをしたくなります。夜の光暴露は睡眠遅延の一般的な原因です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这里的刺激会使你的时钟延迟，让你想晚睡晚起。晚间光照是导致睡眠延迟的常见原因。"
          }
        }
      }
    },
