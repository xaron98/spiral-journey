          "stringUnit" : {
            "state" : "translated",
            "value" : "Circadianen Rhythmus stabilisieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilize circadian period"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabiliza el período circadiano"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabiliser la période circadienne"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概日周期を安定させる"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "稳定昼夜节律周期"
          }
        }
      }
    },
    "rec.stabilizeSchedule.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتظام جيد، لكن هناك مجال للتحسين. قلّل الفارق بين أيام الأسبوع وعطلة نهاية الأسبوع إلى أقل من ساعة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bona regularitat, però hi ha marge de millora. Redueix la diferència entre dies laborables i cap de setmana a menys d'1 hora."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gute Regelmäßigkeit, aber Verbesserungspotenzial. Reduziere den Unterschied zwischen Werktagen und Wochenende auf unter 1 Stunde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Good regularity, but room to improve. Reduce the weekday/weekend difference to under 1 hour."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buena regularidad, pero hay margen de mejora. Reduce la diferencia entre días laborables y fin de semana a menos de 1 hora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bonne régularité, mais des progrès sont possibles. Réduisez la différence semaine/week-end à moins d'1 heure."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "規則性は良好ですが改善の余地があります。平日と週末の差を1時間未満に縮めましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "规律性良好，但仍有改善空间。将工作日与周末的差异缩小到1小时以内。"
          }
        }
      }
    },
    "rec.stabilizeSchedule.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تثبيت جداول النوم"
          }
        },
