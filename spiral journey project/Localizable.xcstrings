    "rec.reinforceZeitgebers.text" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إيقاع متوسط. عزّز المحفزات البيولوجية: ضوء الصباح، ووجبات منتظمة، وتمارين خلال النهار (ليس في المساء)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritme moderat. Potencia els zeitgebers: llum matinal, àpats regulars, exercici diürn (no al vespre)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moderater Rhythmus. Stärke Zeitgeber: Morgenlicht, regelmäßige Mahlzeiten, Sport am Tag (nicht abends)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moderate rhythm. Enhance zeitgebers: morning light, regular meals, daytime exercise (not in the evening)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritmo moderado. Potencia los zeitgebers: luz matutina, comidas regulares, ejercicio diurno (no por la tarde-noche)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rythme modéré. Renforcez les zeitgebers : lumière matinale, repas réguliers, exercice en journée (pas le soir)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リズムは中程度です。時間同期因子を強化：朝の光、規則的な食事、日中の運動（夕方は避ける）。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "节律中等。增强授时因子：早晨光照、规律饮食、白天运动（不在傍晚）。"
          }
        }
      }
    },
    "rec.reinforceZeitgebers.title" : {
