    "rec.minimizeWeekendLag.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فارق %@. حاول إبقاء جداول عطلة نهاية الأسبوع أقرب إلى أيام الأسبوع."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de desfasament. Intenta mantenir els horaris de cap de setmana més propers als de la setmana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Lag. Versuche, die Wochenendzeiten näher an den Werktagen zu halten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ of lag. Try keeping weekend schedules closer to weekdays."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de desfase. Intenta mantener los horarios del fin de semana más cercanos a los de la semana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de décalage. Essayez de maintenir les horaires du week-end proches des jours de semaine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@のずれがあります。週末のスケジュールを平日に近づけるよう心がけましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "存在%@的滞后。尝试让周末作息时间更接近工作日。"
          }
        }
      }
    },
    "rec.minimizeWeekendLag.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقليل تأخر عطلة نهاية الأسبوع"
          }
        },
        "ca": {
          "stringUnit": {
