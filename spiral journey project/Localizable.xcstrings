        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Abstimmung des Schlafs mit deinen Verpflichtungen verbessert Schlafqualität und Tagesleistung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
