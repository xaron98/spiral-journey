    "chronotype.result.definiteEvening.desc": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ساعتك البيولوجية تعمل متأخرًا. تشعر بأعلى مستوى من اليقظة والإبداع في ساعات المساء."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu rellotge intern funciona tard. Et sents més alerta i creatiu a la nit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre innere Uhr läuft spät. Sie fühlen sich abends am wachsten und kreativsten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your internal clock runs late. You naturally feel most alert and creative in the evening hours."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu reloj interno funciona tarde. Te sientes más alerta y creativo por la noche."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre horloge interne est tardive. Vous vous sentez naturellement plus alerte et créatif le soir."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの体内時計は遅めに動きます。夜の時間帯に最も覚醒し、創造性が高まります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的生物钟偏晚。你在夜间时段自然感觉最清醒、最有创造力。"
          }
        }
      }
    },
    "chronotype.result.definiteMorning": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
