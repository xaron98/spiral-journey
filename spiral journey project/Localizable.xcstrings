          }
        }
      }
    },
    "prc.help.what.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُظهر منحنى الاستجابة للطور مقدار تحويل المنبه (كالضوء أو الميلاتونين) لساعتك البيولوجية اليومية حسب وقت التعرض له."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Una corba de resposta de fase mostra quant desplaça un estímul (com la llum o la melatonina) el teu rellotge circadià segons l'hora del dia en què t'hi exposes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Phasenreaktionskurve zeigt, wie stark ein Reiz (z.B. Licht oder Melatonin) deine innere Uhr verschiebt, abhängig von der Tageszeit der Exposition."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Phase Response Curve shows how much a stimulus (like light or melatonin) shifts your circadian clock depending on the time of day you're exposed to it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una curva de respuesta de fase muestra cuánto desplaza un estímulo (como la luz o la melatonina) tu reloj circadiano según la hora del día en que te expones a él."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une courbe de réponse de phase montre à quel point un stimulus (comme la lumière ou la mélatonine) décale votre horloge circadienne selon l'heure d'exposition."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位相反応曲線は、刺激（光やメラトニンなど）が暴露された時刻に応じて概日時計をどれだけシフトさせるかを示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相位反应曲线显示刺激（如光线或褪黑素）根据暴露时间对昼夜节律时钟的影响程度。"
          }
        }
      }
    },
