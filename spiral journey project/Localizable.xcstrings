          }
        }
      }
    },
    "rec.stabilizePeriod.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم اكتشاف انجراف تدريجي. الجمع بين ضوء الصباح الساطع + الميلاتونين بجرعة منخفضة (0.5 ملغ) قبل 5-7 ساعات من النوم يمكن أن يُثبِّت الإيقاع عند 24 ساعة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Deriva progressiva detectada. Combinar llum brillant al matí + melatonina de baixa dosi (0,5 mg) 5-7h abans de dormir pot ancorar el ritme a 24h."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Progressive Verschiebung erkannt. Kombination aus hellem Morgenlicht + niedrig dosiertem Melatonin (0,5 mg) 5-7h vor dem Schlaf kann den Rhythmus auf 24h verankern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progressive drift detected. Combining bright morning light + low-dose melatonin (0.5 mg) 5-7 h before sleep can anchor the rhythm to 24 h."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deriva progresiva detectada. Combinar luz intensa por la mañana + melatonina de baja dosis (0,5 mg) 5-7h antes de dormir puede anclar el ritmo a 24h."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dérive progressive détectée. Combiner lumière vive le matin + mélatonine faible dose (0,5 mg) 5-7h avant le sommeil peut ancrer le rythme à 24h."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行性のドリフトが検出されました。朝の強い光＋低用量メラトニン（0.5mg）を睡眠5〜7時間前に組み合わせることでリズムを24時間に固定できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检测到进行性漂移。将早晨强光照射与低剂量褪黑素（0.5mg，睡前5-7小时服用）结合，可将节律锚定在24小时。"
          }
        }
      }
    },
    "rec.stabilizePeriod.title": {
      "extractionState": "stale",
