    "dna.help.how.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "القضبان الذهبية تمثل الليلة الحالية؛ الفضية للمقارنة. الألوان تشير إلى المراحل (اليقظة، حركة العين السريعة، النوم غير الحالم)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les barres daurades representen la nit actual; les platejades, la comparació. Els colors indiquen les fases (vigília, REM, NREM)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Goldene Balken zeigen die aktuelle Nacht, silberne den Vergleich. Die Farben zeigen die Phasen (Wach, REM, NREM)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gold bars represent the current night; silver bars the comparison. Colors show the phases (wake, REM, NREM)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las barras doradas representan tu noche actual; las plateadas, la comparación. Los colores indican las fases (vigilia, REM, NREM)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les barres dorées représentent la nuit actuelle ; les argentées, la comparaison. Les couleurs indiquent les phases (éveil, REM, NREM)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金色のバーは現在の夜、銀色は比較対象。色は各段階（覚醒、REM、NREM）を表します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金色条代表当前夜晚，银色代表对比。颜色表示各阶段（清醒、REM、NREM）。"
          }
        }
      }
    },
