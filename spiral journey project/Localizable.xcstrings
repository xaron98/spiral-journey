          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稳定睡眠时间表"
          }
        }
      }
    },
    "rec.strengthenRhythm.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إيقاعك البيولوجي ضعيف. التعرض للضوء الساطع صباحاً (20-30 دقيقة) والظلام ليلاً هما أقوى المحفزات البيولوجية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu ritme circadià és feble. La llum brillant al matí (20-30 min) i la foscor a la nit són els zeitgebers més potents."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein circadianer Rhythmus ist schwach. Helles Licht morgens (20-30 Min.) und Dunkelheit nachts sind die stärksten Zeitgeber."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your circadian rhythm is weak. Bright light exposure in the morning (20-30 min) and darkness at night are the strongest zeitgebers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ritmo circadiano es débil. La exposición a luz brillante por la mañana (20-30 min) y la oscuridad por la noche son los zeitgebers más potentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre rythme circadien est faible. La lumière vive le matin (20-30 min) et l'obscurité la nuit sont les zeitgebers les plus puissants."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概日リズムが弱いです。朝の強い光（20〜30分）と夜の暗さが最も強力な時間同期因子です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的昼夜节律较弱。早晨强光照射（20-30分钟）和夜间黑暗是最强的授时因子。"
          }
        }
      }
    },
    "rec.strengthenRhythm.title": {
      "extractionState": "stale",
      "localizations": {
