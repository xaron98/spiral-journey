    "periodogram.insight.duration.weekly" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتغير مدة نومك بدورة أسبوعية — ربما بسبب الاختلافات بين أيام العمل وعطلة نهاية الأسبوع."
          }
