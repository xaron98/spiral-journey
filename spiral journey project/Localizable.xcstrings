    "coach.issue.insufficientDuration.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقدّم بوقت نومك 15 دقيقة كل ليلة حتى تصل إلى هدف مدة النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Avança l'hora d'anar a dormir 15 minuts cada nit fins a assolir la durada objectiu del son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verlege deine Schlafenszeit jede Nacht um 15 Minuten vor, bis du die Ziel-Schlafdauer erreichst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move your bedtime 15 minutes earlier each night until you reach your target sleep duration."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adelanta tu hora de dormir 15 minutos cada noche hasta alcanzar la duración objetivo del sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avancez votre heure de coucher de 15 minutes chaque nuit jusqu'à atteindre la durée de sommeil cible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標睡眠時間に達するまで、毎晩15分ずつ就寝時間を早めましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每晚将就寝时间提前15分钟，直到达到目标睡眠时长。"
          }
        }
      }
    },
    "coach.issue.insufficientDuration.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "زيادة مدة النوم تُحسّن الذاكرة والمزاج والجهاز المناعي خلال أسبوعين."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Augmentar la durada del son millorarà la memòria, l'humor i el sistema immunitari en dues setmanes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mehr Schlaf verbessert Gedächtnis, Stimmung und Immunsystem innerhalb von zwei Wochen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Increasing sleep duration will improve memory, mood, and immune function within two weeks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aumentar la duración del sueño mejorará la memoria, el estado de ánimo y la función inmunitaria en dos semanas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Augmenter la durée du sommeil améliorera la mémoire, l'humeur et la fonction immunitaire en deux semaines."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間を増やすことで、2週間以内に記憶力、気分、免疫機能が改善されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "增加睡眠时间将在两周内改善记忆力、情绪和免疫功能。"
          }
        }
      }
    },
    "coach.issue.insufficientDuration.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "متوسط نومك أقل من الموصى به. تراكم الديون النومية يؤثر على المزاج والتركيز والصحة العامة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva durada de son mitjana és inferior a la recomanada. L'acumulació de deute de son afecta l'humor, la concentració i la salut general."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine durchschnittliche Schlafdauer liegt unter dem empfohlenen Wert. Aufgebauter Schlafmangel beeinträchtigt Stimmung, Konzentration und allgemeine Gesundheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your average sleep duration is below the recommended amount. Accumulated sleep debt affects mood, focus, and overall health."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu duración media de sueño está por debajo de lo recomendado. La deuda de sueño acumulada afecta el estado de ánimo, la concentración y la salud en general."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre durée de sommeil moyenne est inférieure aux recommandations. La dette de sommeil accumulée affecte l'humeur, la concentration et la santé générale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "平均睡眠時間が推奨量を下回っています。蓄積した睡眠負債は気分、集中力、全体的な健康に影響します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的平均睡眠时间低于建议量。累积的睡眠债务会影响情绪、注意力和整体健康。"
          }
        }
      }
    },
    "coach.issue.insufficientDuration.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدة نوم قصيرة"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Durada del son insuficient"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unzureichende Schlafdauer"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insufficient Sleep Duration"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duración del sueño insuficiente"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée de sommeil insuffisante"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間の不足"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠时间不足"
          }
        }
      }
    },
    "coach.issue.irregularSchedule.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر وقتاً ثابتاً للنوم والاستيقاظ والتزم به حتى في عطل نهاية الأسبوع خلال أسبوعين متتاليين."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Escull una hora fixa per anar a dormir i despertar-te i mantén-la durant dues setmanes, fins i tot els caps de setmana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine feste Schlaf- und Aufwachzeit und halte sie zwei Wochen lang ein – auch am Wochenende."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a fixed sleep and wake time and stick to it for two weeks, even on weekends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una hora fija de sueño y vigilia y cúmplela durante dos semanas, incluso los fines de semana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une heure fixe de coucher et de lever et respectez-la pendant deux semaines, même le week-end."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "就寝・起床時間を決め、週末も含めて2週間守り続けましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择固定的睡眠和起床时间，包括周末，坚持两周。"
          }
        }
      }
    },
    "coach.issue.irregularSchedule.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد أسبوعين من الانتظام، ستلاحظ أنك تستيقظ بشكل تلقائي قبل المنبه وتشعر بمزيد من اليقظة صباحاً."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Després de dues setmanes de regularitat, notaràs que et despertes espontàniament abans del despertador i et sents més despert al matí."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach zwei Wochen Regelmäßigkeit wirst du merken, dass du vor dem Wecker spontan aufwachst und dich morgens wacher fühlst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After two weeks of regularity, you'll notice waking up spontaneously before your alarm and feeling more alert in the morning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después de dos semanas de regularidad, notarás que te despiertas espontáneamente antes de la alarma y te sientes más alerta por la mañana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après deux semaines de régularité, vous remarquerez que vous vous réveillez spontanément avant votre réveil et vous sentez plus alerte le matin."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2週間の規則正しい生活の後、アラームの前に自然に目覚め、朝の覚醒度が上がることに気づくでしょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "规律两周后，您会发现自己在闹钟响之前自然醒来，早晨更加清醒。"
          }
        }
      }
    },
    "coach.issue.irregularSchedule.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت نومك يتغير بأكثر من ساعة من ليلة لأخرى. يصعب على الساعة البيولوجية التنبؤ بمواعيد النوم والاستيقاظ مما يُضعف نوعية النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'hora d'anar a dormir varia més d'una hora d'una nit a l'altra. Això dificulta que el rellotge intern anticipi les hores de son i vigília, cosa que redueix la qualitat del son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schlafenszeit variiert von Nacht zu Nacht um mehr als eine Stunde. Das erschwert es der inneren Uhr, Schlaf- und Wachzeiten vorherzusagen, was die Schlafqualität mindert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your bedtime varies by more than an hour night to night. This makes it hard for your internal clock to anticipate sleep and wake times, reducing sleep quality."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu hora de dormir varía más de una hora de noche en noche. Esto dificulta que el reloj interno anticipe los horarios de sueño y vigilia, reduciendo la calidad del sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre heure de coucher varie de plus d'une heure d'une nuit à l'autre. Cela rend difficile pour l'horloge interne d'anticiper les heures de sommeil et de réveil, réduisant la qualité du sommeil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "就寝時間が夜ごとに1時間以上変動しています。これにより体内時計が睡眠・起床時間を予測しにくくなり、睡眠の質が低下します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您每晚的就寝时间相差超过一小时，使生物钟难以预测睡眠和醒来时间，降低睡眠质量。"
          }
        }
      }
    },
    "coach.issue.irregularSchedule.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جدول نوم غير منتظم"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Horari de son irregular"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unregelmäßiger Schlafrhythmus"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Irregular Sleep Schedule"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Horario de sueño irregular"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Horaire de sommeil irrégulier"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不規則な睡眠スケジュール"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠时间不规律"
          }
        }
      }
    },
    "coach.issue.maintenance.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حافظ على نفس جدول النوم. التعرض للضوء الطبيعي في الصباح يُعزز الثبات."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el mateix horari de son. L'exposició a la llum natural al matí reforça l'estabilitat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalte denselben Schlafrhythmus bei. Natürliches Morgenlicht stärkt die Stabilität."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the same sleep schedule. Natural morning light exposure reinforces stability."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el mismo horario de sueño. La exposición a la luz natural por la mañana refuerza la estabilidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez le même horaire de sommeil. L'exposition à la lumière naturelle le matin renforce la stabilité."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じ睡眠スケジュールを維持しましょう。朝の自然光を浴びることで安定性が強化されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持相同的睡眠时间表。早晨接受自然光照射可以增强稳定性。"
          }
        }
      }
    },
    "coach.issue.maintenance.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الحفاظ على الانتظام يحمي مكاسبك ويمنع الانتكاس نحو الأنماط غير الصحية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenir la regularitat protegeix els teus guanys i prevé la recaiguda en patrons no saludables."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Regelmäßigkeit zu erhalten schützt deine Fortschritte und verhindert einen Rückfall in ungesunde Muster."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintaining regularity protects your gains and prevents regression toward unhealthy patterns."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantener la regularidad protege tus logros y previene la regresión hacia patrones no saludables."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenir la régularité protège vos acquis et prévient une régression vers des schémas non sains."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規則正しさを維持することで、成果を守り、不健康なパターンへの逆戻りを防ぎます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持规律性可以巩固成果，防止退回到不健康的睡眠模式。"
          }
        }
      }
    },
    "coach.issue.maintenance.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نمط نومك منتظم ومتوافق مع أهدافك. الإيقاع اليومي مستقر وقوي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu patró de son és consistent i s'alinea amb els teus objectius. El ritme circadià és estable i fort."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Schlafmuster ist konsistent und entspricht deinen Zielen. Der Tagesrhythmus ist stabil und stark."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep pattern is consistent and aligns with your goals. Your circadian rhythm is stable and strong."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu patrón de sueño es consistente y se alinea con tus objetivos. Tu ritmo circadiano es estable y fuerte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre schéma de sommeil est cohérent et s'aligne sur vos objectifs. Votre rythme circadien est stable et fort."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠パターンは一貫しており、目標に合致しています。概日リズムは安定して強固です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠模式稳定，与目标一致。昼夜节律稳定且强健。"
          }
        }
      }
    },
    "coach.issue.maintenance.title": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إيقاع جيد — حافظ عليه"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Bon ritme — mantén-lo"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Guter Rhythmus — weiter so"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Good Rhythm — Keep It Up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buen ritmo — mantenlo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bon rythme — continuez"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "良好なリズム — 維持しましょう"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "节律良好 — 继续保持"
          }
        }
      }
    },
    "coach.issue.offTargetForCustomSchedule.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "راجع الجدول المخصص في الإعدادات وحاول الاقتراب من أوقات النوم والاستيقاظ المستهدفة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa l'horari personalitzat a la configuració i intenta apropar-te als temps de son i despertar objectius."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überprüfe den Benutzerzeitplan in den Einstellungen und versuche, die Ziel-Schlaf- und Aufwachzeiten einzuhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review your custom schedule in Settings and try to align your sleep and wake times with your targets."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa tu horario personalizado en Ajustes e intenta alinear tus horas de sueño y vigilia con tus objetivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultez votre planning personnalisé dans les Réglages et essayez d'aligner vos heures de sommeil et de réveil sur vos cibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定でカスタムスケジュールを確認し、就寝・起床時間を目標に合わせるよう努めましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置中查看您的自定义时间表，并尝试将睡眠和起床时间与目标对齐。"
          }
        }
      }
    },
    "coach.issue.offTargetForCustomSchedule.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التوافق مع الجدول المستهدف سيُحسّن جودة نومك ومستوى طاقتك خلال النهار."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Alinear-se amb l'horari objectiu millorarà la qualitat del son i el nivell d'energia durant el dia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Ausrichtung auf den Zielplan verbessert die Schlafqualität und das Energieniveau tagsüber."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aligning with the target schedule will improve sleep quality and daytime energy levels."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alinearse con el horario objetivo mejorará la calidad del sueño y los niveles de energía diurna."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'aligner sur le planning cible améliorera la qualité du sommeil et les niveaux d'énergie diurnes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標スケジュールに合わせることで、睡眠の質と日中のエネルギーレベルが向上します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与目标时间表对齐将提高睡眠质量和日间能量水平。"
          }
        }
      }
    },
    "coach.issue.offTargetForCustomSchedule.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نومك يختلف عن الجدول المخصص الذي ضبطته. الثبات على الجدول المستهدف يُحسّن جودة النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El teu son difereix de l'horari personalitzat que has configurat. Mantenir-se en l'horari objectiu millora la qualitat del son."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Schlaf weicht vom festgelegten Benutzerzeitplan ab. Das Einhalten des Zielplans verbessert die Schlafqualität."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep differs from the custom schedule you set. Staying on the target schedule improves sleep quality."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sueño difiere del horario personalizado que estableciste. Mantenerse en el horario objetivo mejora la calidad del sueño."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre sommeil diffère du planning personnalisé que vous avez défini. Respecter le planning cible améliore la qualité du sommeil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定したカスタムスケジュールと睡眠が異なっています。目標スケジュールを維持することで睡眠の質が向上します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠与设置的自定义时间表不符。坚持目标时间表可以提高睡眠质量。"
          }
        }
      }
    },
    "coach.issue.offTargetForCustomSchedule.title": {
