        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wochen mit Wochenend-Rhythmus — spätere Bettzeiten und spätere Aufwachzeiten an mehr Tagen als üblich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weeks dominated by a weekend-style rhythm — later bedtimes and later wake-ups across more days than usual."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semanas dominadas por un ritmo de fin de semana — acostadas y despertares más tardíos en más días de lo normal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semaines dominées par un rythme de week-end — couchers et réveils plus tardifs sur davantage de jours que d'habitude."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "週末型リズムが支配的な週(通常より多くの日で就寝と起床が遅い)。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "周末模式占主导的几周 — 比平时更多天晚睡晚起。"
          }
        }
      }
    },
