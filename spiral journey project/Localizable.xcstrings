    "pdf.glossary.acrophase": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الذروة — وقت ذروة الإيقاع اليومي، ساعة النشاط القصوى. عند البالغين الأصحاء بين 14:00-17:00."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase — Hora pic del ritme circadiari, moment de màxima activitat o alerta. En adults sans, normalment entre les 14:00-17:00."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Akrophase — Spitzenzeitpunkt des zirkadianen Rhythmus, Stunde maximaler Aktivität. Bei Erwachsenen typischerweise zwischen 14:00-17:00."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrophase — Peak time of the circadian rhythm, representing the hour of maximum activity or alertness. In healthy adults, typically between 14:00-17:00."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrofase — Hora pico del ritmo circadiano, momento de máxima actividad o alerta. En adultos sanos, normalmente entre las 14:00-17:00."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrophase — Heure de pointe du rythme circadien, moment d'activité ou vigilance maximale. Chez les adultes sains, typiquement entre 14h-17h."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクロフェーズ — 概日リズムのピーク時間。最大活動性の時刻。健康な成人では通常14:00〜17:00。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "峰值时相 — 昼夜节律的高峰时间，代表最大活动或警觉的时刻。健康成人通常在14:00-17:00之间。"
          }
        }
      }
    },
    "pdf.glossary.car": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (استجابة الكورتيزول عند الاستيقاظ) — الارتفاع الطبيعي في الكورتيزول بعد 30-45 دقيقة من الاستيقاظ. يعكس تنشيط نظام التوتر والتوافق اليومي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (Resposta de cortisol al despertar) — Augment natural de cortisol 30-45 minuts després de despertar. Reflecteix l'activació del sistema d'estrès i l'alineació circadiana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (Cortisol-Aufwachreaktion) — Der natürliche Cortisolanstieg 30-45 Minuten nach dem Aufwachen. Spiegelt Stresssystem-Aktivierung und zirkadiane Ausrichtung wider."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (Cortisol Awakening Response) — The natural surge of cortisol 30-45 minutes after waking. Reflects stress system activation and circadian alignment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (Respuesta de cortisol al despertar) — Aumento natural de cortisol 30-45 minutos después de despertar. Refleja la activación del sistema de estrés y la alineación circadiana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR (Réponse du cortisol au réveil) — La hausse naturelle de cortisol 30-45 minutes après le réveil. Reflète l'activation du système de stress et l'alignement circadien."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR（コルチゾール覚醒反応）— 起床後30〜45分に起こるコルチゾールの自然な急上昇。ストレス応答と概日リズムの整合性を反映。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CAR（皮质醇觉醒反应）— 醒来后30-45分钟的皮质醇自然激增。反映压力系统激活和昼夜节律对齐。"
          }
        }
      }
    },
    "pdf.glossary.composite": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الدرجة المركبة — مؤشر شامل لجودة النوم (0-100) يجمع: الانتظام (SRI)، استقرار الإيقاع، مدة النوم، التفاوت الاجتماعي، وضوح الإيقاع (R²)، واتساق السعة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntuació Composta — Índex general de qualitat del son (0-100) que combina: regularitat (SRI), estabilitat del ritme, durada, jetlag social, claredat circadiana (R²) i consistència d'amplitud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesamtbewertung — Schlafqualitätsindex (0-100) aus: Regelmäßigkeit (SRI), Rhythmusstabilität, Schlafdauer, sozialem Jetlag, zirkadianer Klarheit (R²) und Amplitudenkonsistenz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Composite Score — Overall sleep quality index (0-100) combining: regularity (SRI), rhythm stability, sleep duration, social jetlag, circadian clarity (R²), and amplitude consistency."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntuación Compuesta — Índice general de calidad del sueño (0-100) que combina: regularidad (SRI), estabilidad del ritmo, duración, jetlag social, claridad circadiana (R²) y consistencia de amplitud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Score Composite — Indice global de qualité du sommeil (0-100) combinant: régularité (SRI), stabilité du rythme, durée, jetlag social, clarté circadienne (R²) et constance d'amplitude."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "総合スコア — 睡眠の質の総合指数（0-100）。規則性（SRI）、リズム安定性、睡眠時間、社会的時差、概日明瞭度（R²）、振幅一貫性を統合。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "综合评分 — 睡眠质量综合指数（0-100），综合：规律性（SRI）、节律稳定性、睡眠时长、社会性时差、昼夜清晰度（R²）和振幅一致性。"
          }
        }
      }
    },
    "pdf.glossary.consistency": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "درجة الاتساق — استقرار النمط خلال 7 ليالٍ (0-100). تقيّم: انتظام بداية النوم، الاستيقاظ، تشابه التجزئة، استقرار المدة، وجودة التعافي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntuació de Consistència — Estabilitat del patró en les últimes 7 nits (0-100). Avalua: regularitat d'inici del son, del despertar, fragmentació, estabilitat de durada i recuperació."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konsistenzbewertung — Musterstabilität der letzten 7 Nächte (0-100). Bewertet: Einschlaf-Regelmäßigkeit, Aufwachzeit, Fragmentierung, Dauerstabilität und Erholungsqualität."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Consistency Score — Pattern stability over the last 7 nights (0-100). Evaluates: sleep onset regularity, wake time regularity, fragmentation similarity, duration stability, and recovery quality."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntuación de Consistencia — Estabilidad del patrón en las últimas 7 noches (0-100). Evalúa: regularidad de inicio del sueño, del despertar, fragmentación, estabilidad de duración y recuperación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Score de Cohérence — Stabilité du schéma sur 7 nuits (0-100). Évalue: régularité d'endormissement, de réveil, fragmentation, stabilité de durée et qualité de récupération."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一貫性スコア — 過去7夜のパターン安定性（0-100）。入眠規則性、起床規則性、断片化類似性、持続時間安定性、回復の質を評価。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一致性评分 — 过去7夜的模式稳定性（0-100）。评估：入睡规律性、醒来规律性、片段化相似性、时长稳定性和恢复质量。"
          }
        }
      }
    },
    "pdf.glossary.dlmo": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (بدء إفراز الميلاتونين في الضوء الخافت) — الوقت الذي يبدأ فيه الجسم إنتاج الميلاتونين في ضوء خافت، بداية الليل البيولوجي. عادة قبل 2-3 ساعات من النوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (Inici de melatonina en llum tènue) — Moment en què el cos comença a produir melatonina en llum tènue, marcant l'inici biològic de la nit. Sol ocórrer 2-3 hores abans d'anar a dormir."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (Melatonin-Onset bei Dämmerlicht) — Der Zeitpunkt, an dem der Körper bei schwachem Licht Melatonin produziert und den biologischen Nachtbeginn markiert. Typischerweise 2-3 Stunden vor der Schlafenszeit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (Dim Light Melatonin Onset) — The time when the body begins producing melatonin under dim light, marking the biological start of night. Typically 2-3 hours before habitual bedtime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (Inicio de melatonina en luz tenue) — Momento en que el cuerpo empieza a producir melatonina en luz tenue, marcando el inicio biológico de la noche. Suele ocurrir 2-3 horas antes de acostarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO (Début de sécrétion de mélatonine en lumière tamisée) — Le moment où le corps commence à produire de la mélatonine en lumière faible, marquant le début biologique de la nuit. Typiquement 2-3h avant le coucher."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO（薄暗い光でのメラトニン分泌開始）— 薄暗い環境で体がメラトニン産生を開始する時刻。生物学的な夜の始まりを示します。通常、就寝の2〜3時間前。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DLMO（暗光下褪黑素分泌起始）— 在昏暗光线下身体开始分泌褪黑素的时间，标志着生物学夜晚的开始。通常在就寝前2-3小时。"
          }
        }
      }
    },
    "pdf.glossary.pld": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (انخفاض ما بعد الغداء) — انخفاض طبيعي في اليقظة حوالي 14:00-15:00، مرتبط بتوافقيات دورة الحرارة. لا يسببه الطعام لكن يتضخم بالوجبات الثقيلة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (Baixada post-dinar) — Descens natural de l'alerta al voltant de les 14:00-15:00, lligat a l'harmònic del cicle de temperatura. No causat pel menjar, però amplificat per àpats copiosos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (Nachmittagstief) — Natürlicher Aufmerksamkeitsabfall gegen 14:00-15:00, verbunden mit der Temperaturzyklus-Harmonik. Nicht durch Essen verursacht, aber durch schwere Mahlzeiten verstärkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (Post-Lunch Dip) — A natural decrease in alertness around 14:00-15:00, linked to the temperature cycle harmonic. Not caused by eating, but amplified by heavy meals."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (Bajón post-almuerzo) — Descenso natural de alerta alrededor de las 14:00-15:00, ligado al armónico del ciclo de temperatura. No causado por la comida, pero amplificado por comidas copiosas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD (Creux post-prandial) — Baisse naturelle de vigilance vers 14h-15h, liée à l'harmonique du cycle de température. Non causée par l'alimentation, mais amplifiée par les repas copieux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD（食後の眠気）— 14:00〜15:00頃の覚醒度の自然な低下。体温サイクルの調和振動に関連。食事が原因ではないが、重い食事で増幅。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PLD（餐后低谷）— 约14:00-15:00的自然警觉度下降，与体温周期谐波相关。非进食引起，但可被过量饮食加剧。"
          }
        }
      }
    },
    "pdf.glossary.r2": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (ملاءمة جيب التمام) — يقيس ملاءمة بيانات النوم لموجة 24 ساعة (0-1). القيم الأعلى تشير إلى إيقاع يومي أقوى."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (Ajust Cosinor) — Mesura com s'ajusten les dades de son a una ona cosinus de 24 hores (0-1). Valors més alts = ritme circadiari més fort."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (Kosinor-Anpassung) — Misst die Übereinstimmung der Schlafdaten mit einer 24-Stunden-Kosinuswelle (0-1). Höhere Werte = stärkerer zirkadianer Rhythmus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (Cosinor Fit) — Measures how well sleep data fits a 24-hour cosine wave (0-1). Higher values indicate a stronger, more defined circadian rhythm."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (Ajuste Cosinor) — Mide qué tan bien se ajustan los datos de sueño a una onda coseno de 24 horas (0-1). Valores más altos = ritmo circadiano más fuerte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "R² (Ajustement Cosinor) — Mesure la correspondance des données de sommeil avec une onde cosinus de 24h (0-1). Valeurs élevées = rythme circadien plus fort."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "R²（コサイナー適合度）— 睡眠データが24時間コサイン波にどれだけ適合するかを測定（0-1）。高い値ほど概日リズムが強く明確。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "R²（余弦拟合度）— 衡量睡眠数据与24小时余弦波的拟合程度（0-1）。数值越高表示昼夜节律越强越明确。"
          }
        }
      }
    },
    "pdf.glossary.rhythmStability": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استقرار الإيقاع — انتظام النمط اليومي من 0 (فوضوي) إلى 1 (دوري تماماً). يعتمد على اتساق السعة والتوقيت."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Estabilitat del Ritme — Mesura la regularitat del teu patró circadiari de 0 (caòtic) a 1 (periòdic perfecte). Basat en la consistència d'amplitud i temporització."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rhythmusstabilität — Regelmäßigkeit des zirkadianen Musters von 0 (chaotisch) bis 1 (perfekt periodisch). Basiert auf Amplituden- und Timing-Konsistenz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rhythm Stability — Measures the regularity of your circadian pattern from 0 (chaotic) to 1 (perfectly periodic). Based on amplitude and timing consistency across days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estabilidad del Ritmo — Mide la regularidad de tu patrón circadiano de 0 (caótico) a 1 (perfectamente periódico). Basado en la consistencia de amplitud y temporización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stabilité du Rythme — Régularité du profil circadien de 0 (chaotique) à 1 (parfaitement périodique). Basée sur constance d'amplitude et timing."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リズム安定性 — 0（不規則）〜1（完全周期的）で概日パターンの規則性を測定。振幅とタイミングの一貫性に基づく。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "节律稳定性 — 以0（混乱）到1（完美周期性）衡量昼夜节律的规律性。基于各天间振幅和时相的一致性。"
          }
        }
      }
    },
    "pdf.glossary.socialJetlag": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التفاوت الاجتماعي — التباين بين ساعتك البيولوجية وجدولك الاجتماعي، يُقاس بفرق نقطة منتصف النوم بين أيام العمل والعطلة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Jetlag Social — Discrepància entre el teu rellotge biològic i horari social, mesurada com la diferència del punt mitjà del son entre dies laborables i caps de setmana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sozialer Jetlag — Diskrepanz zwischen biologischer Uhr und sozialem Zeitplan, gemessen als Schlafmittelpunkt-Unterschied zwischen Wochentagen und Wochenende."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Social Jetlag — The discrepancy between your biological clock and social schedule, measured as the sleep midpoint difference between weekdays and weekends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Jetlag Social — Discrepancia entre tu reloj biológico y horario social, medida como la diferencia del punto medio del sueño entre días laborables y fines de semana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jetlag Social — L'écart entre horloge biologique et emploi du temps social, mesuré par la différence du point médian de sommeil semaine/week-end."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "社会的時差 — 生体時計と社会的スケジュールのずれ。平日と週末の睡眠中間点の差で測定。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "社会性时差 — 生物钟与社会时间表的差异，以工作日和周末睡眠中点差值衡量。"
          }
        }
      }
    },
    "pdf.glossary.sri": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (مؤشر انتظام النوم) — يقيس اتساق نمط النوم-الاستيقاظ يومياً (0-100). القيم الأعلى تشير إلى انتظام أكبر مرتبط بصحة أفضل."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (Índex de Regularitat del Son) — Mesura la consistència diària del teu patró son-vigília (0-100). Valors més alts indiquen horari més regular, associat amb millor salut."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (Schlafregularitätsindex) — Misst die tägliche Konsistenz des Schlaf-Wach-Musters (0-100). Höhere Werte bedeuten regelmäßigeren Zeitplan, verbunden mit besserer Gesundheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (Sleep Regularity Index) — Measures day-to-day consistency of your sleep-wake pattern (0-100). Higher values indicate a more regular schedule, associated with better health outcomes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (Índice de Regularidad del Sueño) — Mide la consistencia diaria de tu patrón sueño-vigilia (0-100). Valores más altos indican horario más regular, asociado con mejor salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI (Indice de Régularité du Sommeil) — Mesure la constance quotidienne du cycle sommeil-éveil (0-100). Valeurs élevées = horaire plus régulier, associé à meilleure santé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI（睡眠規則性指数）— 睡眠覚醒パターンの日ごとの一貫性を測定（0-100）。高い値ほど規則的で、健康改善と関連。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SRI（睡眠规律性指数）— 衡量睡眠-觉醒模式的日间一致性（0-100）。数值越高越规律，与更好的健康结果相关。"
          }
        }
      }
    },
    "pdf.glossary.tmin": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (أدنى درجة حرارة مركزية) — أدنى نقطة لحرارة الجسم خلال الدورة اليومية، عادة قبل 2-3 ساعات من الاستيقاظ. علامة رئيسية للمرحلة اليومية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (Nadir de temperatura central) — El punt més baix de la temperatura corporal central durant el cicle circadiari, normalment 2-3 hores abans del despertar natural. Marcador clau de fase circadiana."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (Kerntemperatur-Nadir) — Der tiefste Punkt der Körperkerntemperatur im zirkadianen Zyklus, typischerweise 2-3 Stunden vor dem Aufwachen. Wichtiger Marker der zirkadianen Phase."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (Core Temperature Nadir) — The lowest point of core body temperature during the circadian cycle, typically 2-3 hours before natural wake time. A key marker of circadian phase."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (Nadir de temperatura central) — El punto más bajo de la temperatura corporal central durante el ciclo circadiano, normalmente 2-3 horas antes del despertar natural. Marcador clave de fase circadiana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin (Nadir de température centrale) — Le point le plus bas de la température corporelle pendant le cycle circadien, typiquement 2-3h avant le réveil naturel. Marqueur clé de la phase circadienne."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin（深部体温最低点）— 概日サイクル中の深部体温が最も低くなる時点。通常、自然な起床の2〜3時間前。概日位相の重要なマーカー。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tmin（核心体温最低点）— 昼夜节律周期中核心体温最低的时间点，通常在自然醒来前2-3小时。昼夜节律相位的关键标记。"
          }
        }
      }
    },
