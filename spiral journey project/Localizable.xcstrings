    },
    "consistency.help.normal.desc" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كان نمط نومك مستقرًا هذه الليلة. وقت النوم والاستيقاظ متسق مع متوسطك الأسبوعي، ولم يُرصد أي انقطاع ملحوظ."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu patró de son va ser estable aquesta nit. L'hora d'anar a dormir i de despertar-se és consistent amb la teva mitjana setmanal, i no es van detectar interrupcions significatives."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Schlafmuster war in dieser Nacht stabil. Schlafens- und Aufwachzeit sind konsistent mit deinem Wochendurchschnitt, und es wurden keine signifikanten Unterbrechungen erkannt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep pattern was stable this night. Bedtime and wake time are consistent with your weekly average, and no significant interruptions were detected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu patrón de sueño fue estable esta noche. La hora de dormir y despertar son consistentes con tu media semanal, y no se detectaron interrupciones significativas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton schéma de sommeil était stable cette nuit. L'heure du coucher et du réveil sont cohérentes avec ta moyenne hebdomadaire, et aucune interruption significative n'a été détectée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この夜の睡眠パターンは安定していました。就寝時刻と起床時刻は週間平均と一致しており、大きな中断は検出されませんでした。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今晚的睡眠规律稳定。就寝时间和起床时间与你的每周平均值一致，未检测到明显中断。"
          }
        }
      }
    },
