    "periodogram.insight.amplitude.biweekly" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتذبذب قوة إيقاعك كل أسبوعين تقريبًا — تتناوب بين أسابيع إيقاع قوي وضعيف."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La força del teu ritme oscil·la cada ~2 setmanes — alternes entre setmanes de ritme fort i feble."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Rhythmusstärke schwankt alle ~2 Wochen — du wechselst zwischen Wochen mit starkem und schwachem Rhythmus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your rhythm strength oscillates every ~2 weeks — you alternate between weeks of strong and weak circadian drive."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fuerza de tu ritmo oscila cada ~2 semanas — alternas entre semanas de ritmo fuerte y débil."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La force de votre rythme oscille toutes les ~2 semaines — vous alternez entre des semaines de rythme fort et faible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リズムの強さが約2週間ごとに変動しています——強い週と弱い週が交互に来ます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的节律强度每约2周波动——强弱节律周交替出现。"
          }
        }
      }
    },
    "periodogram.insight.amplitude.weekly" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إيقاعك اليومي أقوى خلال أيام العمل وأضعف في عطلة نهاية الأسبوع — الروتين يقوي ساعتك الداخلية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El teu ritme circadià és més fort entre setmana i més feble els caps de setmana — la rutina enforteix el teu rellotge intern."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein zirkadianer Rhythmus ist werktags stärker und am Wochenende schwächer — Routine stärkt deine innere Uhr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your circadian rhythm is stronger on weekdays and weaker on weekends — routine strengthens your internal clock."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu ritmo circadiano es más fuerte entre semana y más débil los fines de semana — la rutina fortalece tu reloj interno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre rythme circadien est plus fort en semaine et plus faible le week-end — la routine renforce votre horloge interne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概日リズムは平日に強く、週末に弱くなります——規則的な生活が体内時計を強化します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的昼夜节律在工作日更强、周末更弱——规律的作息增强了您的生物钟。"
          }
        }
      }
    },
    "periodogram.insight.duration.circadian" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مدة نومك لها إيقاع يومي مستقر — تنام مدة ثابتة كل ليلة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La teva durada de son té un ritme diari estable — dorms una quantitat consistent cada nit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Schlafdauer hat einen stabilen Tagesrhythmus — du schläfst jede Nacht gleichmäßig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep duration has a stable daily rhythm — you sleep a consistent amount each night."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu duración de sueño tiene un ritmo diario estable — duermes una cantidad consistente cada noche."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre durée de sommeil a un rythme quotidien stable — vous dormez une durée constante chaque nuit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠時間は安定した日リズムがあります——毎晩一定の量を睡眠しています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠时长有稳定的日节律——每晚睡眠量一致。"
          }
        }
      }
    },
    "periodogram.insight.duration.menstrual.noData" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم اكتشاف دورة مدتها حوالي 28 يومًا في مدة نومك."
          }
        },
        "ca" : {
          "stringUnit" : {
