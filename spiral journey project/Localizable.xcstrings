    "neurospiral.info.dimensions.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل عيّنة تتحول إلى نقطة 4D باستخدام: تقلب معدل ضربات القلب (HRV)، السكون الحركي، معدل ضربات القلب، ووقت اليوم. هذه القيم الأربع تحدد موقعك على الطوق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada mostra es transforma en un punt 4D usant: variabilitat cardíaca (HRV), quietud motora, freqüència cardíaca i hora del dia. Aquests 4 valors defineixen la teva posició al tor."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Probe wird mittels Herzfrequenzvariabilität (HRV), motorischer Ruhe, Herzfrequenz und Tageszeit in einen 4D-Punkt umgewandelt. Diese 4 Werte definieren deine Position auf dem Torus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each sample is transformed into a 4D point using: heart rate variability (HRV), motor stillness, heart rate, and time of day. These 4 values define your position on the torus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada muestra se transforma en un punto 4D usando: variabilidad cardíaca (HRV), quietud motora, frecuencia cardíaca y hora del día. Estos 4 valores definen tu posición en el toro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque échantillon est transformé en point 4D en utilisant : variabilité cardiaque (HRV), calme moteur, fréquence cardiaque et heure de la journée. Ces 4 valeurs définissent votre position sur le tore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各サンプルは心拍変動（HRV）、運動静止、心拍数、時刻を使用して4Dポイントに変換されます。これら4つの値がトーラス上の位置を定義します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个样本使用心率变异性（HRV）、运动静止、心率和时间转换为4D点。这4个值定义了您在环面上的位置。"
          }
        }
      }
    },
