    "triangle.legend.explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل نقطة = 15 دقيقة. موقعك داخل المثلث يعكس مدى قربك من كل نموذج."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada punt = 15 min. La teva posició dins del triangle reflecteix com de prop estàs de cada arquetip."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Punkt = 15 Min. Ihre Position im Dreieck zeigt, wie nah Sie an jedem Archetyp sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each dot = 15 min. Your position inside the triangle reflects how close you are to each archetype."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada punto = 15 min. Tu posición dentro del triángulo refleja qué tan cerca estás de cada arquetipo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque point = 15 min. Votre position dans le triangle reflète votre proximité à chaque archétype."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各点 = 15分。三角形内の位置は、各アーキタイプにどれだけ近いかを反映します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个点 = 15 分钟。您在三角形内的位置反映您与每个原型的接近程度。"
          }
        }
      }
    },
    "triangle.legend.light" : {
