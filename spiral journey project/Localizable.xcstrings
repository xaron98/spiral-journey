          }
        }
      }
    },
    "rec.reduceSocialJetlag.text": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ فارق بين أيام الأسبوع وعطلة نهاية الأسبوع — يعادل تغيير المنطقة الزمنية كل أسبوع. يؤثر على الأيض والإدراك."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de diferència entre setmana i cap de setmana — equivalent a creuar fusos horaris cada setmana. Afecta el metabolisme i la cognició."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Unterschied zwischen Werktagen und Wochenende — wie wöchentliches Zeitzonenwechseln. Beeinträchtigt Stoffwechsel und Kognition."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ of difference between weekdays and weekend — equivalent to crossing time zones every week. Affects metabolism and cognition."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de diferencia entre semana y fin de semana — equivalente a cruzar husos horarios cada semana. Afecta al metabolismo y la cognición."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ de différence entre la semaine et le week-end — équivalent à changer de fuseau horaire chaque semaine. Affecte le métabolisme et la cognition."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "平日と週末の差が%@ — 毎週タイムゾーンを越えるのと同等です。代謝と認知機能に影響します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "平日与周末相差%@——相当于每周跨越时区。影响新陈代谢和认知功能。"
          }
        }
      }
    },
    "rec.reduceSocialJetlag.title": {
