    "coach.insight.short.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنام أقل من 7 ساعات الموصى بها. الحرمان المتراكم من النوم يؤثر على الإدراك والصحة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dorms per sota de les 7h recomanades. La privació de son acumulada afecta la cognició i la salut."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du schläfst weniger als die empfohlenen 7h. Kumulativer Schlafmangel beeinträchtigt Kognition und Gesundheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're sleeping below the recommended 7h. Cumulative sleep deprivation affects cognition and health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duermes por debajo de las 7h recomendadas. La privación acumulada afecta la cognición y la salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu dors moins que les 7h recommandées. La privation cumulée affecte la cognition et la santé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "推奨の7時間を下回っています。睡眠不足の蓄積は認知機能と健康に影響します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠时间低于建议的7小时，累积睡眠不足会影响认知和健康。"
          }
        }
      }
    },
    "coach.insight.short.title" : {
