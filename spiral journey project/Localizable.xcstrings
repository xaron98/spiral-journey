          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分段睡眠"
          }
        }
      }
    },
    "coach.issue.sufficientButMisaligned.action": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاول تقديم وقت نومك تدريجياً بـ 15 دقيقة كل أسبوع نحو نافذة 22:00-06:00."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta avançar gradualment l'hora d'anar a dormir 15 minuts per setmana cap a la finestra 22:00-06:00."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche, deine Schlafenszeit schrittweise um 15 Minuten pro Woche in Richtung 22:00–06:00 vorzuverlegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try gradually moving your bedtime 15 minutes earlier each week toward the 22:00–06:00 window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Intenta mover gradualmente tu hora de dormir 15 minutos antes cada semana hacia la ventana 22:00-06:00."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de déplacer progressivement votre heure de coucher de 15 minutes par semaine vers la fenêtre 22:00–06:00."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎週15分ずつ就寝時間を22:00〜06:00の窓に向けて前倒しにしていきましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试每周将就寝时间提前15分钟，逐步调整到22:00-06:00的时间窗口。"
          }
        }
      }
    },
    "coach.issue.sufficientButMisaligned.outcome": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحسين التوافق مع الإيقاع اليومي سيزيد جودة النوم ومستوى الطاقة خلال النهار."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Millorar l'alineació amb el ritme circadià augmentarà la qualitat del son i el nivell d'energia durant el dia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bessere Ausrichtung am Tagesrhythmus wird die Schlafqualität und das Energieniveau tagsüber verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Better alignment with circadian rhythm will increase sleep quality and daytime energy levels."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una mejor alineación con el ritmo circadiano aumentará la calidad del sueño y los niveles de energía diurna."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une meilleure synchronisation avec le rythme circadien améliorera la qualité du sommeil et les niveaux d'énergie diurnes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概日リズムとの同期が改善されることで、睡眠の質と日中のエネルギーレベルが向上します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更好地与昼夜节律同步将提高睡眠质量和日间能量水平。"
          }
        }
      }
    },
    "coach.issue.sufficientButMisaligned.reason": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدة نومك كافية لكن توقيته لا يتوافق مع الإيقاع الطبيعي للضوء والنشاط. قد تشعر بالتعب رغم مدة النوم الكافية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La durada del teu son és adequada però el temps no s'alinea amb el ritme natural de llum i activitat. Podries sentir-te cansat malgrat dormir prou."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schlafdauer ist ausreichend, aber der Zeitpunkt stimmt nicht mit dem natürlichen Hell-Dunkel-Rhythmus überein. Du könntest dich trotz ausreichend Schlaf müde fühlen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sleep duration is adequate but the timing doesn't align with the natural light-dark rhythm. You may feel tired despite sleeping enough."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu duración de sueño es adecuada pero el horario no se alinea con el ritmo natural de luz y oscuridad. Podrías sentirte cansado a pesar de dormir suficiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre durée de sommeil est adéquate mais le timing n'est pas aligné avec le rythme naturel lumière-obscurité. Vous pourriez vous sentir fatigué malgré un sommeil suffisant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間は十分ですが、タイミングが自然の明暗リズムと合っていません。十分眠っているにもかかわらず疲れを感じるかもしれません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的睡眠时长足够，但时间安排与自然光暗节律不匹配，可能即使睡够了也感到疲倦。"
          }
        }
      }
    },
    "coach.issue.sufficientButMisaligned.title": {
