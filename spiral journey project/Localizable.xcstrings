    "coach.insight.irregular.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أوقات نومك تتباين كثيراً. عدم الانتظام يضعف الساعة البيولوجية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els teus horaris de son varien molt. La irregularitat debilita el rellotge circadià."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Schlafzeiten variieren stark. Unregelmäßigkeit schwächt die innere Uhr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sleep times vary a lot. Irregularity weakens the circadian clock."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus horarios de sueño varían mucho. La irregularidad debilita el reloj circadiano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tes horaires de sommeil varient beaucoup. L'irrégularité affaiblit l'horloge circadienne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡眠時間のばらつきが大きいです。不規則性は概日時計を弱めます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的睡眠时间变化很大。不规律会削弱昼夜节律时钟。"
          }
        }
      }
    },
    "coach.insight.irregular.title" : {
