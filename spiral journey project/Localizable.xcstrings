    "coach.insight.shift.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أكروفاز ساعتك البيولوجية تتحول. قد يكون هذا علامة تكيّف أو اضطراب."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva acrofase circadiana s'està desplaçant. Pot ser un signe d'adaptació o pertorbació."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine zirkadiane Akrophase verschiebt sich. Das kann ein Zeichen von Anpassung oder Störung sein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your circadian acrophase is shifting. This may be a sign of adaptation or disruption."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu acrofase circadiana se está desplazando. Puede ser señal de adaptación o perturbación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton acrophase circadienne se déplace. Cela peut être un signe d'adaptation ou de perturbation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概日アクロフェーズがシフトしています。適応または乱れのサインかもしれません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的昼夜节律高峰期正在移动，这可能是适应或紊乱的信号。"
          }
        }
      }
    },
    "coach.insight.shift.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحول الطور"
          }
        },
        "ca": {
          "stringUnit": {
