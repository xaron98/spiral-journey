        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a fixed wake alarm — same time as yesterday."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pon una alarma fija — misma hora que ayer."
