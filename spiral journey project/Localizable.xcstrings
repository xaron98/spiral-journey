    "coach.insight.jetlag.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنام متأخراً جداً في عطلة نهاية الأسبوع، مما يسبب تأثير التفاوت الاجتماعي ويؤثر على الأيض."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dorms gaire més tard els caps de setmana. Això crea un efecte de jet lag social que afecta el metabolisme."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du schläfst am Wochenende viel später. Das erzeugt einen sozialen Jetlag-Effekt, der den Stoffwechsel beeinflusst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You sleep much later on weekends. This creates a social jet-lag effect that affects metabolism."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duermes mucho más tarde los fines de semana. Esto crea un efecto de jet lag social que afecta al metabolismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu dors bien plus tard le week-end. Cela crée un effet de jet-lag social qui affecte le métabolisme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "週末はかなり遅く寝ています。これが社会的時差ぼけを生み、代謝に影響します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您周末睡得比工作日晚很多，产生社会性时差效应，影响代谢。"
          }
        }
      }
    },
    "coach.insight.jetlag.title" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
