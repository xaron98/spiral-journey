    "coach.chat.download.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعمل مدرب الذكاء الاصطناعي بالكامل على جهازك. يحتاج إلى تحميل نموذج لغوي أولاً (~2.4 جيجابايت). يتم ذلك مرة واحدة فقط."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El coach d'IA s'executa completament al teu dispositiu. Necessita descarregar un model de llenguatge (~2,4 GB). Només cal fer-ho una vegada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der KI-Coach läuft vollständig auf Ihrem Gerät. Er muss zuerst ein Sprachmodell herunterladen (~2,4 GB). Dies geschieht nur einmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The AI coach runs entirely on your device. It needs to download a language model first (~2.4 GB). This only happens once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El coach IA funciona completamente en tu dispositivo. Necesita descargar un modelo de lenguaje (~2,4 GB). Solo se descarga una vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le coach IA fonctionne entièrement sur votre appareil. Il doit d'abord télécharger un modèle de langage (~2,4 Go). Cela ne se fait qu'une seule fois."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIコーチはデバイス上で完全に動作します。まず言語モデルをダウンロードする必要があります（約2.4 GB）。ダウンロードは1回のみです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 教练完全在您的设备上运行。需要先下载语言模型（约 2.4 GB）。仅需下载一次。"
          }
        }
