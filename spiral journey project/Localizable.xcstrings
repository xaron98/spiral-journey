    "stats.glossary.acrophase" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "وقت ذروة نشاطك اليومي. الفترة التي يكون فيها جسمك أكثر يقظة وأداءً. في نمط النوم الصحي، تقع عادةً بين الساعة 14:00 و18:00." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Hora del pic d'activitat del teu ritme circadià. Quan el teu cos és més actiu i alerta. En un patró saludable, sol caure entre les 14:00 i les 18:00." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeitpunkt des Aktivitätsgipfels deines circadianen Rhythmus. Wann dein Körper am wachsten und leistungsfähigsten ist. Bei einem gesunden Muster liegt er meist zwischen 14:00 und 18:00 Uhr." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The time of peak activity in your circadian rhythm. When your body is most alert and productive. In a healthy pattern, it usually falls between 14:00 and 18:00." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La hora de máxima actividad de tu ritmo circadiano. Cuando tu cuerpo está más alerta y productivo. En un patrón saludable, suele caer entre las 14:00 y las 18:00." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'heure du pic d'activité de votre rythme circadien. Quand votre corps est le plus alerte et productif. Dans un schéma sain, elle se situe généralement entre 14h00 et 18h00." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "概日リズムの活動ピーク時刻。体が最も覚醒し生産的な時間帯。健康なパターンでは通常14:00〜18:00の間に現れます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "昼夜节律活动峰值时间。身体最警觉、最有效率的时刻。健康模式下通常在14:00至18:00之间。" } }
      }
    },
    "stats.glossary.acroSigma" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "مدى تفاوت وقت الذروة من يوم لآخر. الانحراف المعياري ≤ 1 ساعة يدل على انتظام جيد؛ فوق ساعتين يشير إلى عدم انتظام ملحوظ." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Quant varia l'hora del pic d'un dia a l'altre. Una desviació ≤ 1 hora indica bona regularitat; per sobre de 2 hores suggereix irregularitat notable." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wie sehr die Gipfelzeit von Tag zu Tag schwankt. Eine Standardabweichung ≤ 1 Stunde zeigt gute Regelmäßigkeit; über 2 Stunden deutet auf erhebliche Unregelmäßigkeit hin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How much the peak time varies from day to day. A standard deviation ≤ 1 hour indicates good regularity; above 2 hours suggests notable irregularity." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuánto varía la hora del pico de un día a otro. Una desviación estándar ≤ 1 hora indica buena regularidad; por encima de 2 horas sugiere irregularidad notable." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Variation de l'heure du pic d'un jour à l'autre. Un écart-type ≤ 1 heure indique une bonne régularité ; au-dessus de 2 heures, il y a une irrégularité notable." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ピーク時刻の日々のばらつき。標準偏差≤1時間は規則性が良好、2時間超は不規則性が顕著。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "峰值时间每天的变化程度。标准差≤1小时表示规律性好；超过2小时表示不规律性明显。" } }
      }
    },
    "stats.glossary.amplitude" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "قوة إشارة الساعة البيولوجية الداخلية. قيمة أعلى تعني تباين واضح بين اليقظة والنوم. الأمراض أو التوتر أو قلة ضوء النهار تقلل من هذه القيمة." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "La força del senyal del teu rellotge intern. Un valor més alt significa un contrast clar entre l'estat d'alerta i el son. Les malalties, l'estrès o la poca llum diürna redueixen aquest valor." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Stärke des Signals deiner inneren Uhr. Ein höherer Wert bedeutet einen klaren Kontrast zwischen Wach- und Schlafphase. Krankheit, Stress oder wenig Tageslicht verringern diesen Wert." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The strength of your internal clock's signal. A higher value means a clear contrast between alertness and sleep. Illness, stress, or low daylight reduce this value." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La fuerza de la señal de tu reloj interno. Un valor mayor significa un contraste claro entre alerta y sueño. La enfermedad, el estrés o poca luz diurna reducen este valor." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La force du signal de votre horloge interne. Une valeur plus élevée signifie un contraste net entre l'éveil et le sommeil. La maladie, le stress ou peu de lumière du jour réduisent cette valeur." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "体内時計の信号強度。値が高いほど覚醒と睡眠の明確なコントラストがあります。病気、ストレス、日照不足でこの値は低下します。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "体内时钟信号的强度。值越高表示清醒与睡眠之间的对比越明显。疾病、压力或日照不足会降低此值。" } }
      }
    },
    "stats.glossary.rhythm" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "مدى ثبات دورة النشاط والراحة اليومية على مدار الأسابيع. النسب المئوية العالية تدل على إيقاع منتظم ومتوقع." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Estabilitat del cicle activitat-descans al llarg de les setmanes. Percentatges alts indiquen un ritme regular i predictible." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stabilität des Aktivitäts-Ruhe-Zyklus über Wochen. Hohe Prozentwerte deuten auf einen gleichmäßigen, vorhersehbaren Rhythmus hin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stability of your activity-rest cycle across weeks. High percentages indicate a regular, predictable rhythm." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Estabilidad del ciclo actividad-descanso a lo largo de las semanas. Porcentajes altos indican un ritmo regular y predecible." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Stabilité du cycle activité-repos au fil des semaines. Des pourcentages élevés indiquent un rythme régulier et prévisible." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "数週間にわたる活動-休息サイクルの安定性。高い割合は規則的で予測可能なリズムを示します。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "数周内活动-休息周期的稳定性。高百分比表示有规律、可预测的节律。" } }
      }
    },
    "stats.glossary.sri" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "مؤشر انتظام النوم: مقياس علمي لمدى تشابه أنماط نومك من يوم لآخر. فوق 85% ممتاز؛ ما بين 70-85% جيد؛ أقل من 70% يستحق التحسين." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Índex de Regularitat del Son: mesura científica de com es repeteix el teu patró de son cada dia. Per sobre del 85% és excel·lent; 70-85% és bo; per sota del 70% val la pena millorar." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sleep Regularity Index: wissenschaftliches Maß dafür, wie ähnlich dein Schlafmuster von Tag zu Tag ist. Über 85% ist ausgezeichnet; 70-85% ist gut; unter 70% lohnt sich eine Verbesserung." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sleep Regularity Index: scientific measure of how similar your sleep pattern is day to day. Above 85% is excellent; 70-85% is good; below 70% is worth improving." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Índice de Regularidad del Sueño: medida científica de cuánto se repite tu patrón de sueño cada día. Por encima del 85% es excelente; 70-85% es bueno; por debajo del 70% vale la pena mejorar." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Indice de Régularité du Sommeil : mesure scientifique de la similitude de votre schéma de sommeil d'un jour à l'autre. Au-dessus de 85% est excellent ; 70-85% est bon ; en dessous de 70% mérite d'être amélioré." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "睡眠規則性指数：毎日の睡眠パターンの類似度を測る科学的指標。85%超は優秀、70-85%は良好、70%未満は改善の余地あり。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "睡眠规律性指数：衡量睡眠模式每天相似程度的科学指标。85%以上优秀，70-85%良好，70%以下值得改善。" } }
      }
    },
    "stats.glossary.socialJL" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "الفارق بين أوقات النوم في أيام العمل وأيام العطلة. أشبه بتغيير المنطقة الزمنية كل أسبوع. فوق 60 دقيقة يمكن أن يؤثر سلباً على مستوى طاقتك ومزاجك." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Diferència entre els horaris de son en dies laborables i caps de setmana. Com canviar de zona horària cada setmana. Per sobre de 60 minuts pot afectar negativament l'energia i l'humor." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Unterschied zwischen Schlafzeiten an Werktagen und am Wochenende. Wie ein Zeitzonenwechsel jede Woche. Über 60 Minuten kann sich negativ auf Energie und Stimmung auswirken." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The difference between sleep timing on workdays vs. weekends. Like changing time zones every week. Above 60 minutes can negatively affect your energy and mood." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La diferencia entre los horarios de sueño en días laborables y fines de semana. Como cambiar de zona horaria cada semana. Por encima de 60 minutos puede afectar negativamente la energía y el estado de ánimo." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La différence entre les horaires de sommeil les jours de travail et le week-end. Comme changer de fuseau horaire chaque semaine. Au-dessus de 60 minutes, cela peut affecter négativement votre énergie et votre humeur." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "平日と週末の睡眠時刻の差。毎週タイムゾーンを変えるようなもの。60分超ではエネルギーと気分に悪影響が出ることがあります。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "工作日与周末睡眠时间的差异。就像每周换时区一样。超过60分钟可能对精力和情绪产生负面影响。" } }
      }
    },
    "stats.glossary.wkndAmp" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "قوة إشارة الساعة البيولوجية خلال عطلة نهاية الأسبوع. إذا كانت أضعف بكثير من الأيام العادية، فقد يعني ذلك ضعف ضبط الساعة البيولوجية في أيام الراحة." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "La força del senyal circadià durant el cap de setmana. Si és molt més feble que els dies laborables, pot indicar una sincronització del rellotge deficient els dies de descans." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Stärke des circadianen Signals am Wochenende. Wenn es deutlich schwächer als an Werktagen ist, könnte das auf eine schlechte Uhr-Synchronisierung an Ruhetagen hindeuten." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The strength of the circadian signal on weekends. If much weaker than weekdays, it may indicate poor clock entrainment on rest days." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La fuerza de la señal circadiana durante el fin de semana. Si es mucho más débil que en días laborables, puede indicar un mal anclaje del reloj en los días de descanso." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La force du signal circadien pendant le week-end. Si beaucoup plus faible qu'en semaine, cela peut indiquer un mauvais entraînement de l'horloge les jours de repos." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "週末の概日信号強度。平日より大幅に低い場合、休息日の体内時計の同期が不十分な可能性があります。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周末昼夜节律信号的强度。若明显弱于工作日，可能表明休息日体内时钟的同步性较差。" } }
      }
    },
    "stats.glossary.sleep" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "متوسط مدة نومك عبر جميع السجلات المحفوظة. البالغون يحتاجون عادةً بين 7 و9 ساعات. أقل من 6.5 ساعة بشكل منتظم يرتبط بتراجع الأداء والصحة." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Durada mitjana del teu son a través de tots els registres guardats. Els adults necessiten normalment entre 7 i 9 hores. Menys de 6,5 hores regularment s'associa a un rendiment i una salut reduïts." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Durchschnittliche Schlafdauer über alle gespeicherten Aufzeichnungen. Erwachsene benötigen normalerweise 7-9 Stunden. Weniger als 6,5 Stunden regelmäßig ist mit schlechterer Leistung und Gesundheit verbunden." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Average sleep duration across all saved records. Adults typically need 7-9 hours. Less than 6.5 hours regularly is associated with reduced performance and health." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Duración media del sueño a través de todos los registros guardados. Los adultos suelen necesitar entre 7 y 9 horas. Menos de 6,5 horas de forma regular se asocia con menor rendimiento y salud." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Durée moyenne du sommeil sur tous les enregistrements sauvegardés. Les adultes ont généralement besoin de 7 à 9 heures. Moins de 6,5 heures régulièrement est associé à des performances et une santé réduites." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "保存された全記録の平均睡眠時間。成人は通常7〜9時間必要です。6.5時間未満が続くとパフォーマンスと健康に悪影響があります。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "所有保存记录的平均睡眠时长。成年人通常需要7-9小时。长期少于6.5小时与表现下降和健康问题相关。" } }
      }
    },
    "stats.glossary.r2" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "مدى ملاءمة نمط نومك لنموذج الإيقاع اليومي الرياضي (تحليل الكوسينور). قيمة ≥ 0.6 تعني إيقاع متسق؛ أقل من 0.3 يعني إيقاع ضعيف أو غائب." } },
        "ca" : { "stringUnit" : { "state" : "translated", "value" : "Com d'ajustat és el teu patró de son a un model matemàtic de ritme diari (anàlisi cosinor). Un valor ≥ 0,6 significa un ritme consistent; per sota de 0,3 significa un ritme feble o absent." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wie gut dein Schlafmuster zu einem mathematischen Tagesrhythmusmodell passt (Cosinor-Analyse). Ein Wert ≥ 0,6 bedeutet einen konsistenten Rhythmus; unter 0,3 bedeutet einen schwachen oder fehlenden Rhythmus." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How well your sleep pattern fits a mathematical daily rhythm model (cosinor analysis). A value ≥ 0.6 means a consistent rhythm; below 0.3 means a weak or absent rhythm." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Qué tan bien se ajusta tu patrón de sueño a un modelo matemático de ritmo diario (análisis cosinor). Un valor ≥ 0,6 significa un ritmo consistente; por debajo de 0,3 significa un ritmo débil o ausente." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "À quel point votre schéma de sommeil correspond à un modèle mathématique de rythme quotidien (analyse cosinor). Une valeur ≥ 0,6 signifie un rythme cohérent ; en dessous de 0,3, le rythme est faible ou absent." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "睡眠パターンが数学的な日周リズムモデル（コサイノル解析）にどれだけ適合するか。≥0.6は一貫したリズム、0.3未満は弱いまたは存在しないリズム。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "睡眠模式与数学日周期节律模型（余弦分析）的拟合程度。≥0.6表示节律一致；低于0.3表示节律微弱或缺失。" } }
      }
    }
  },
  "version" : "1.1"
}