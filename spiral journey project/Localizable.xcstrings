    "neurospiral.transitions.explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتقالات Hamming-1 (تغيّر بت واحد) تشير إلى تقدّم سلس. قفزات Hamming ≥ 2 تشير إلى تغيّر مفاجئ."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transicions Hamming-1 (un sol bit flip) indiquen progressió suau. Salts Hamming ≥ 2 suggereixen canvi brusc."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hamming-1-Übergänge (ein Bit-Flip) zeigen sanfte Progression. Hamming ≥ 2 deutet auf abrupten Wechsel."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hamming-1 transitions (single bit flip) indicate smooth progression. Hamming ≥ 2 jumps suggest abrupt change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transiciones Hamming-1 (un solo bit flip) indican progresión suave. Saltos Hamming ≥ 2 sugieren cambio brusco."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les transitions Hamming-1 (un seul bit flip) indiquent une progression douce. Les sauts Hamming ≥ 2 suggèrent un changement brusque."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ハミング距離1の遷移（1ビットフリップ）はスムーズな進行を示します。ハミング距離2以上は急激な変化を示唆します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "汉明距离1的转换（单比特翻转）表示平滑过渡。汉明距离≥2的跳跃表示突变。"
          }
        }
      }
    },
    "neurospiral.transitions.none" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
