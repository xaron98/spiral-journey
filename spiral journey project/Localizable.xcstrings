    "dna.disclaimer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحليل النوم لأغراض تعليمية فقط ولا يشكل نصيحة طبية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'anàlisi del son és només amb finalitats educatives i no constitueix consell mèdic."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Schlafanalyse dient nur Bildungszwecken und stellt keine medizinische Beratung dar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep analysis is for educational purposes only and does not constitute medical advice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El análisis del sueño es solo con fines educativos y no constituye consejo médico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'analyse du sommeil est uniquement à des fins éducatives et ne constitue pas un avis médical."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠分析は教育目的のみであり、医療アドバイスを構成するものではありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠分析仅用于教育目的，不构成医疗建议。"
          }
        }
      }
    },
    "dna.empty": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجّل أسبوعًا واحدًا على الأقل من النوم\nلفتح حمضك النووي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra almenys una setmana de son\nper desbloquejar el teu ADN."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeichne mindestens eine Woche Schlaf auf,\num deine DNA freizuschalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record at least one week of sleep\nto unlock your DNA."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra al menos una semana de sueño\npara desbloquear tu ADN."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre au moins une semaine de sommeil\npour débloquer ton ADN."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DNAをアンロックするには\n少なくとも1週間の睡眠を記録してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录至少一周的睡眠\n以解锁你的DNA。"
          }
        }
      }
    },
    "dna.health.alert.anarchy": {
      "localizations": {
        "ar": {
          "stringUnit": {
