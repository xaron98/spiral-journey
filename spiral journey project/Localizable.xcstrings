    "coach.issue.fragmentedSleep.action" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تجنب الكافيين بعد الساعة 14:00، وقلّل من الكحول، واجعل غرفة النوم باردة ومظلمة وهادئة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evita la cafeïna després de les 14:00, redueix l'alcohol i mantén la habitació fresca, fosca i silenciosa."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeide Koffein nach 14:00 Uhr, reduziere Alkohol und halte das Schlafzimmer kühl, dunkel und ruhig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid caffeine after 14:00, reduce alcohol, and keep your bedroom cool, dark, and quiet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evita la cafeína después de las 14:00, reduce el alcohol y mantén el dormitorio fresco, oscuro y silencioso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Évitez la caféine après 14:00, réduisez l'alcool et gardez la chambre fraîche, sombre et calme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "14:00以降のカフェインを避け、アルコールを減らし、寝室を涼しく暗く静かに保ちましょう。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "14:00后避免咖啡因，减少饮酒，保持卧室凉爽、黑暗和安静。"
          }
        }
      }
    },
    "coach.issue.fragmentedSleep.outcome" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحسين البيئة سيُقلّل الاستيقاظ الليلي ويزيد نسبة النوم العميق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Millorar l'ambient reduirà els despertars nocturns i augmentarà la proporció de son profund."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine bessere Schlafumgebung wird nächtliche Aufwachzeiten reduzieren und den Tiefschlafanteil erhöhen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improving the environment will reduce night waking and increase the proportion of deep sleep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mejorar el ambiente reducirá los despertares nocturnos y aumentará la proporción de sueño profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Améliorer l'environnement réduira les réveils nocturnes et augmentera la proportion de sommeil profond."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
