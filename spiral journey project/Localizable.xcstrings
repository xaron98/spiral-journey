    "hrv.description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعكس تقلبات معدل ضربات قلبك الليلية جودة النوم العميق وصحة الجهاز العصبي اللاإرادي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva variabilitat cardíaca nocturna reflecteix la qualitat del son profund i la salut del sistema nerviós autònom."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre nächtliche Herzfrequenzvariabilität spiegelt die Tiefschlafqualität und die Gesundheit des autonomen Nervensystems wider."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your nocturnal heart rate variability reflects deep sleep quality and autonomic nervous system health."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu variabilidad cardíaca nocturna refleja la calidad del sueño profundo y la salud del sistema nervioso autónomo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre variabilité cardiaque nocturne reflète la qualité du sommeil profond et la santé du système nerveux autonome."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "夜間の心拍変動は深い睡眠の質と自律神経系の健康を反映しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的夜间心率变异性反映了深度睡眠质量和自主神经系统健康状况。"
          }
        }
      }
    },
